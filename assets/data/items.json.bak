    "coolness": 0.0,
    "wiki": {
      "effects": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "Creates chains of damaging electricity between fired bullets."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Doubles the damage of Beam style "
            },
            {
              "t": "ref",
              "v": "Guns",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": "."
            }
          ]
        }
      ],
      "notes": [
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "synref",
              "v": "Alistair's Ladder"
            },
            {
              "t": "text",
              "v": " - If the player has "
            },
            {
              "t": "ref",
              "v": "Thunderclap",
              "kind": "gun"
            },
            {
              "t": "text",
              "v": ", it fires two parallel balls of lightning with every shot, connecting the bullets in a ladder pattern."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "synref",
              "v": "Battery Powered"
            },
            {
              "t": "text",
              "v": " - If the player has "
            },
            {
              "t": "ref",
              "v": "Shock Rifle",
              "kind": "gun"
            },
            {
              "t": "text",
              "v": ", the gun's appearance changes and it automatically regenerates ammo over time."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "synref",
              "v": "Chain Lightning"
            },
            {
              "t": "text",
              "v": " - If the player has "
            },
            {
              "t": "ref",
              "v": "Shadow Bullets",
              "kind": "item"
            },
            {
              "t": "text",
              "v": ", the range that Shock Bullets can connect bullets is increased, and lightning can connect to enemy bullets."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "synref",
              "v": "Future Gangster"
            },
