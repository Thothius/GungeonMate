  {
    "name": "Chaos Ammolet",
    "icon": "https://static.wikia.nocookie.net/enterthegungeon_gamepedia/images/9/9e/Chaos_Ammolet.png",
    "type": "Passive",
    "quote": "What Can Will",
    "quality": "A",
    "effect": "Blanks have a chance to poison, freeze, and ignite enemies. Grants an extra blank per floor.",
    "curse": 0.0,
    "coolness": 0.0,
    "wiki": {
      "effects": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "When a  "
            },
            {
              "t": "ref",
              "v": "Blank",
              "kind": "shrine"
            },
            {
              "t": "text",
              "v": " is triggered, all enemies within a 25 tile radius of its center point will suffer the following effects;\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "ref",
                  "v": "Status Effects",
                  "kind": "lore"
                },
                {
                  "t": "text",
                  "v": " for 1 second."
                }
              ]
            },
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "50% chance to be "
                },
                {
                  "t": "ref",
                  "v": "Status Effects",
                  "kind": "lore"
                },
                {
                  "t": "text",
                  "v": " for 4 seconds, dealing 24 damage over time."
                }
              ]
            },
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "50% chance to be "
                },
                {
                  "t": "ref",
                  "v": "Status Effects",
                  "kind": "lore"
                },
                {
                  "t": "text",
                  "v": " for 6 seconds, dealing 18 damage over time."
                }
              ]
            },
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "50% chance to be completely "
                },
                {
                  "t": "ref",
                  "v": "Status Effects",
                  "kind": "lore"
                },
                {
                  "t": "text",
                  "v": " for 5 seconds, incapacitating them and dealing 33% of their max health as damage when they thaw."
                }
              ]
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Each possible effect is applied independently, meaning multiple effects can be applied to the same enemy."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Adds 1 to the player's minimum number of  "
            },
            {
              "t": "ref",
              "v": "Blank",
              "kind": "shrine"
            },
            {
              "t": "text",
              "v": ", restored at the start of every floor."
            }
          ]
        }
      ],
      "item_interactions": [
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "ref",
              "v": "Armor",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": " /  "
            },
            {
              "t": "ref",
              "v": "Old Crest",
              "kind": "item"
            },
            {
              "t": "text",
              "v": " - Triggers the effect of a blank when broken by damage, which in turn triggers Chaos Ammolet."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The following items can trigger blank effects, which will in turn trigger the effects of Chaos Ammolet;\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": " "
                },
                {
                  "t": "ref",
                  "v": "Full Metal Jacket",
                  "kind": "item"
                },
                {
                  "t": "text",
                  "v": " - Automatically triggers a blank when the player would take damage, preventing it. Unlike other blank triggering effects, this item actually uses a blank from the players stockpile and cannot activate if the player has no blanks."
