            },
            {
              "t": "text",
              "v": ", which resemble "
            },
            {
              "t": "ref",
              "v": "Rubber Kin",
              "kind": "unresolved"
            },
            {
              "t": "text",
              "v": "."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Prior to the "
            },
            {
              "t": "ref",
              "v": "A Farewell to Arms Update",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": ", Shock Rounds was an  item."
            }
          ]
        }
      ]
    }
  },
