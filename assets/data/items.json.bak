              "v": "Phoenix Up"
            },
            {
              "t": "text",
              "v": " - If Baby Good Mimic copies the Phoenix, it will continue to copy the Phoenix regardless of if the Synergy is lost."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "synref",
              "v": "Blank Generations"
            },
            {
              "t": "text",
              "v": " /  "
            },
            {
              "t": "synref",
              "v": "To Serve Android"
            },
            {
              "t": "text",
              "v": " /  "
            },
