                  "v": "Holey Grail",
                  "kind": "item"
                },
                {
                  "t": "text",
                  "v": " - Triggers the effect of a blank when the player takes damage."
                }
              ]
            },
            {
              "tokens": [
                {
                  "t": "text",
                  "v": " "
