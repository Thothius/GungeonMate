            {
              "t": "text",
              "v": " "
            },
            {
              "t": "synref",
              "v": "Shell-A-Ton"
            },
            {
              "t": "text",
              "v": " - If the player has "
            },
            {
              "t": "ref",
              "v": "Shelleton Key",
              "kind": "item"
            },
            {
              "t": "text",
              "v": ", Baby Good Shelleton moves and shoots much faster."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "synref",
              "v": "Tea For Two"
            },
            {
              "t": "text",
              "v": " - If the player also has "
            },
            {
              "t": "ref",
              "v": "Teapot",
              "kind": "gun"
            },
            {
              "t": "text",
              "v": ", the companion will have Teapot's AoE effect while reloading."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "If the player stands outside the "
            },
            {
              "t": "ref",
              "v": "Bullet King",
              "kind": "unresolved"
            },
            {
              "t": "text",
              "v": "'s boss door, the Baby Good Shelleton may kill the Chancellor."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The description of the item is an altered version of the "
            },
            {
              "t": "ref",
              "v": "Shelleton",
              "kind": "unresolved"
            },
            {
              "t": "text",
              "v": "'s Ammonomicon entry."
            }
          ]
        }
      ]
    }
  },
  {
    "name": "Badge",
    "icon": "https://static.wikia.nocookie.net/enterthegungeon_gamepedia/images/8/8b/Badge.png",
    "type": "Passive",
    "quote": "By The Book",
    "quality": "A",
    "effect": "Summons a police officer that follows the player, firing bullets at enemies. Can be talked to. Can die after taking too much damage. Talking to him after he dies increases the player's damage by 20% and curse by 2.",
    "curse": 2.0,
    "coolness": 0.0,
    "wiki": {
      "effects": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "Summons a police officer that follows the player, firing bullets that do 5 damage each at enemies.\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "The officer can be talked to."
                }
              ]
            },
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "The officer will die after taking too much damage.\n"
                }
              ],
              "sub": [
                {
                  "tokens": [
                    {
                      "t": "text",
                      "v": "The officer will permanently die and increase the player's "
                    },
                    {
                      "t": "ref",
                      "v": "Curse",
                      "kind": "stat"
                    },
                    {
                      "t": "text",
                      "v": " by 2 if he dies and the player talks to him. This increases the player's "
                    },
                    {
                      "t": "ref",
                      "v": "Damage",
                      "kind": "lore"
                    },
                    {
                      "t": "text",
                      "v": " by 20% and removes the item from inventory."
                    }
                  ]
                },
                {
                  "tokens": [
                    {
                      "t": "text",
                      "v": "The officer can take indirect damage from the player's doing (such as electrified water and explosions)."
                    }
                  ]
                }
              ]
            },
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "The officer will heal to full health at the start of each map."
                }
              ]
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Summons a police officer that will fly in a jetpack, following and shooting at enemies."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Unlike in "
            },
            {
              "t": "text",
              "v": "Enter the Gungeon",
              "style": "i"
            },
            {
              "t": "text",
              "v": ", the policeman will not block bullets, and cannot be damaged, die, or be interacted with."
            }
          ]
        }
      ],
      "item_interactions": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "  "
            },
            {
              "t": "ref",
              "v": "Book of Chest Anatomy",
              "kind": "item"
            },
            {
              "t": "text",
              "v": " +  "
            },
            {
              "t": "synref",
              "v": "Detective Mode"
            },
            {
              "t": "text",
              "v": " - Because Book of Chest Anatomy raises the chance of broken chests dropping an item to 55%, all chests effectively have a 55% chance to drop the item they were predicted to contain when broken."
            }
          ]
        }
      ],
      "notes": [
        {
          "tokens": [
            {
              "t": "text",
              "v": " While the police officers health is not insignificant, his inability to dodge enemy bullets makes him very vulnerable.\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "Because of this, Badge essentially only gives 20% damage up at the cost of curse, making it worse than even lower-rarity items such as "
                },
                {
                  "t": "ref",
                  "v": "+1 Bullets",
                  "kind": "item"
                }
              ]
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": " Dropping the Badge and picking it back up again fully heals the officer."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": " If the player is in the "
            },
            {
              "t": "ref",
              "v": "Forge",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": ", the cop will instantly die if the player is in a fight room and within half a screen-length of the player for more than 5 seconds, unless the player has the  "
            },
            {
              "t": "synref",
              "v": "To Serve Android"
            },
            {
              "t": "text",
              "v": " synergy.\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "The officer will also die when entering the door that goes to "
                },
                {
                  "t": "ref",
                  "v": "High Dragun",
                  "kind": "lore"
                },
                {
                  "t": "text",
                  "v": "."
                }
              ]
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "This item is a reference to the \""
            },
            {
              "t": "ext",
              "v": "last day before retirement",
              "url": "http://tvtropes.org/pmwiki/pmwiki.php/Main/Retirony"
            },
            {
              "t": "text",
              "v": "\" trope that often appears in cop dramas.\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "In the Officer's dialogue, there is a reference to the Gungeoneer as the cop-drama character trope of the \""
                },
                {
                  "t": "ext",
                  "v": "loose cannon",
                  "url": "http://tvtropes.org/pmwiki/pmwiki.php/Main/CowboyCop"
                },
                {
                  "t": "text",
                  "v": ".\" The two roles are often seen together as partners or \"buddies\" in movies ranging from "
                },
                {
                  "t": "ext",
                  "v": "Lethal Weapon",
                  "url": "https://www.imdb.com/title/tt0093409/?ref_=nv_sr_2?ref_=nv_sr_2"
                },
                {
                  "t": "text",
                  "v": " to "
                },
                {
                  "t": "ext",
                  "v": "Seven",
                  "url": "https://en.wikipedia.org/wiki/Seven_(1995_film)"
                },
                {
                  "t": "text",
                  "v": "."
                }
              ]
            },
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "The tagline is also a reference to this trope, as the retiring officer is often characterized as more lawful than their partner."
                }
              ]
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The shots fired by the Policeman are similar in appearance to the "
            },
            {
              "t": "ref",
              "v": "38 Special",
              "kind": "gun"
            },
            {
              "t": "text",
              "v": " bullets."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The quote referring to McNutty may be a reference to "
            },
            {
              "t": "ext",
              "v": "Jimmy McNulty",
              "url": "https://en.wikipedia.org/wiki/Jimmy_McNulty"
            },
            {
              "t": "text",
              "v": ", an arrogant and unpredictable character from "
            },
            {
              "t": "ext",
              "v": "The Wire",
              "url": "https://en.wikipedia.org/wiki/The_Wire"
            },
            {
              "t": "text",
              "v": "."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The officers dead body can be detonated with the "
            },
            {
              "t": "ref",
              "v": "Melted Rock",
              "kind": "item"
            },
            {
              "t": "text",
              "v": "."
            }
          ]
        }
      ]
    }
  },
  {
    "name": "Chicken Flute",
    "icon": "https://static.wikia.nocookie.net/enterthegungeon_gamepedia/images/d/dc/Chicken_Flute.png",
    "type": "Passive",
    "quote": "Fowl Play",
    "quality": "B",
    "effect": "Summons a chicken that follows the player and blocks bullets. After taking a certain amount of damage, it summons an army of chickens to attack enemies.",
    "curse": 0.0,
    "coolness": 0.0,
    "wiki": {
      "effects": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "Spawns a chicken that follows the player, blocks bullets, and deals 2.5 contact damage per frame to enemies it touches."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "If the chicken takes damage 8 or more times in quick succession, it will summon an army of 20 chickens to attack all enemies in the room.\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "The chickens summoned by this attack each deal 5 damage for a total of 100 damage per chicken swarm."
                }
              ]
            },
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "The chicken tracks the number of times it has taken damage, summoning the swarm when the number reaches 8- however the counter is reduced by 1 every 7 seconds."
                }
              ]
            },
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "The chicken swarm has a 10 second cooldown between activations, but there is no limit on how many times it can be summoned per room."
                }
              ]
            },
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "Damage taken while the chicken is summoning will not count towards its next activation."
                }
              ]
            }
          ]
        }
      ],
      "item_interactions": [
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "ref",
              "v": "Battle Standard",
              "kind": "item"
            },
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "text",
              "v": "or",
              "style": "i"
            },
            {
              "t": "text",
              "v": "  "
            },
            {
              "t": "ref",
              "v": "Really Special Lute",
              "kind": "gun"
            },
            {
              "t": "text",
              "v": " - Every hit taken by the chicken adds 2 to its hit tally instead of 1, functionally halving the amount of hits the chicken needs to take in order to activate (from 8 to 4).\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "Unlike most other effects of the Really Special Lute, the Lute does "
                },
                {
                  "t": "text",
                  "v": "not",
                  "style": "i"
                },
                {
                  "t": "text",
                  "v": " need to be playing for this effect to be active. It only has to be the players currently held gun."
                }
              ]
            },
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "If both Battle Standard "
                },
                {
                  "t": "text",
                  "v": "and",
                  "style": "i"
                },
                {
                  "t": "text",
                  "v": " Really Special Lute are held, this effect does not stack."
                }
              ]
            },
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "Has no effect on the rate at which the hit counter is reset."
                }
              ]
            },
            {
              "tokens": [
                {
                  "t": "text",
                  "v": " Possible Bug Battle Standard and Really Special Lute have no effect on the damage of the chicken swarm on their own, "
                },
                {
                  "t": "text",
                  "v": "however",
                  "style": "i"
                },
                {
                  "t": "text",
                  "v": " if the Really Special Lute is held "
                },
                {
                  "t": "text",
                  "v": "while",
                  "style": "i"
                },
                {
                  "t": "text",
                  "v": " the Battle Standard is in the players inventory, the damage of the chicken swarm will be increased by 80%."
                }
              ]
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "ref",
              "v": "Battery Bullets",
              "kind": "item"
            },
            {
              "t": "text",
              "v": ",  "
            },
            {
              "t": "ref",
              "v": "Shock Rifle",
              "kind": "gun"
            },
            {
              "t": "text",
              "v": ",  "
            },
            {
              "t": "ref",
              "v": "Thunderclap",
              "kind": "gun"
            },
            {
              "t": "text",
              "v": " - Electrified "
            },
            {
              "t": "ref",
              "v": "Goop",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": " deals rapid damage to the chicken, quickly summoning the chicken swarm."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "ref",
              "v": "Shock Rounds",
              "kind": "item"
            },
            {
              "t": "text",
              "v": " - The electric links created by Shock Rounds can damage the chicken."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "ref",
              "v": "Grappling Hook",
              "kind": "item"
            },
            {
              "t": "text",
              "v": " - The grappling hook can hit the chicken, dealing damage one time and stunning it."
            }
          ]
        }
      ],
      "notes": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "This item is a reference to Cuccos in the "
            },
            {
              "t": "ext",
              "v": "Legend of Zelda",
              "url": "https://en.wikipedia.org/wiki/Legend_of_Zelda"
            },
            {
              "t": "text",
              "v": " series, where if Link attacks a Cucco three times, an army of Cuccos will appear, attacking the player."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The appearance of the item itself is also a reference to The Fairy Ocarina in the "
            },
            {
              "t": "ext",
              "v": "Legend of Zelda",
              "url": "https://en.wikipedia.org/wiki/Legend_of_Zelda"
            },
            {
              "t": "text",
              "v": " series, which can play different songs which serve different purposes."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The "
            },
            {
              "t": "ref",
              "v": "Ammonomicon",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": " quote, "
            },
            {
              "t": "text",
              "v": "\"Fowl play\"",
              "style": "i"
            },
            {
              "t": "text",
              "v": ", is a play on the common expression \"Foul play\" and the fact that chickens are a type of fowl."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The synergy  "
            },
            {
              "t": "synref",
              "v": "Bullet or the Egg"
            },
            {
              "t": "text",
              "v": " is a reference to the famous question \"Which came first: the chicken or the egg?\"."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": " Possible Bug Since the contact damage dealt by the chicken is applied "
            },
            {
              "t": "text",
              "v": "per frame",
              "style": "i"
            },
            {
              "t": "text",
              "v": " it is making contact with an enemy, it can be incredibly powerful- especially on higher end machines. It is limited, however, to the sheer difficulty of getting the chicken to press up against enemies consistently for any length of time."
            }
          ]
        }
      ]
    }
  },
  {
    "name": "Space Friend",
    "icon": "https://static.wikia.nocookie.net/enterthegungeon_gamepedia/images/0/06/Space_Friend.png",
    "type": "Passive",
    "quote": "A Friend From The Space",
    "quality": "B",
    "effect": "Follows the player, firing lasers at enemies and blocking enemy bullets.",
    "curse": 0.0,
    "coolness": 0.0,
    "wiki": {
      "effects": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "Follows the player and fires lasers at enemies which deal 5 damage."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Blocks enemy bullets."
            }
          ]
        }
      ],
      "notes": [
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "synref",
              "v": "RAIDEN"
            },
            {
              "t": "text",
              "v": " - If the player also has "
            },
            {
              "t": "ref",
              "v": "Raiden Coil",
              "kind": "gun"
            },
            {
              "t": "text",
              "v": ", its maximum ammo is increased by 25%, it will fire pairs of bullets alongside its laser, and its ammo consumption is significantly reduced."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "synref",
              "v": "Space Best Friend"
            },
            {
              "t": "text",
              "v": " - If the player also has "
            },
            {
              "t": "ref",
              "v": "Alien Engine",
              "kind": "gun"
            },
            {
              "t": "text",
              "v": ", Space Friend will turn blue and fire its lasers at a much faster rate."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "If positioned carefully, the Space Friend will almost entirely protect you from "
            },
            {
              "t": "ref",
              "v": "Wallmonger",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": "'s attacks."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Space Friend is affected by "
            },
            {
              "t": "ref",
              "v": "Magic Bullets",
              "kind": "item"
            },
            {
              "t": "text",
              "v": "."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "If the player has "
            },
            {
              "t": "ref",
              "v": "Helix Bullets",
              "kind": "item"
            },
            {
              "t": "text",
              "v": ", Space Friend's bullets travel in a zigzag pattern, but its shots will not be doubled and its damage is unaffected."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Space Friend's laser can be captured by "
            },
            {
              "t": "ref",
              "v": "Gunjurer",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": "."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Once you enter the "
            },
            {
              "t": "ref",
              "v": "Aimless Void",
              "kind": "unresolved"
            },
            {
              "t": "text",
              "v": ", Space Friend will fly in from off-screen and begin following you again. This is due to the Aimless Void being a separate room in the forge, to the right of the rest of the map."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "If duplicates of this item are somehow obtained, grants another Space Friend ally to the player.\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "The Space Friends follow behind each other in a single file fashion, similar to duplicated "
                },
                {
                  "t": "ref",
                  "v": "Owl",
                  "kind": "item"
                },
                {
                  "t": "text",
                  "v": "."
                }
              ]
            }
          ]
        }
      ],
      "trivia": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "This passive's appearance references the player ship in the arcade shoot 'em up series "
            },
            {
              "t": "text",
              "v": "Raiden",
              "style": "i"
            },
            {
              "t": "text",
              "v": ", specifically that of player 1; the Space Best Friend synergy changes it to the second player's color scheme instead."
            }
          ]
        }
      ]
    }
  },
  {
    "name": "Pig",
    "icon": "https://static.wikia.nocookie.net/enterthegungeon_gamepedia/images/3/30/Pig.png",
    "type": "Passive",
    "quote": "Shifty",
    "quality": "A",
    "effect": "Upon death, instantly revives the player with full health.",
    "curse": 0.0,
    "coolness": 0.0,
    "wiki": {
      "effects": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "Summons a pig "
            },
            {
              "t": "ref",
              "v": "Companion",
              "kind": "shrine"
            },
            {
              "t": "text",
              "v": " who mostly does nothing but follow the player around."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "If the player dies, the pig will jump in the way of the finishing shot, sparing the player and effectively granting an extra life. This fully heals the player and removes the item from the player's inventory.\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "In Exit the Gungeon, the Pig only heals a small amount of health."
                }
              ]
            }
          ]
        }
      ],
      "notes": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "Does not revive a player in coop mode if they are not the last player standing, and may softlock the game."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "If the player has "
            },
            {
              "t": "ref",
              "v": "Baby Good Mimic",
              "kind": "item"
            },
            {
              "t": "text",
              "v": ", acquiring Pig creates a second identical Pig companion. Both companions will sacrifice themselves to save the player."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "If the player has "
            },
            {
              "t": "ref",
              "v": "Clone",
              "kind": "item"
            },
            {
              "t": "text",
              "v": ", Pig dies before Clone can trigger."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "When the player has fire immunity and  "
            },
            {
              "t": "synref",
              "v": "The Line of Fire"
            },
            {
              "t": "text",
              "v": ", the player can safely cover a room in fire with a few shots, especially if they also have "
            },
            {
              "t": "ref",
              "v": "Scattershot",
              "kind": "item"
            },
            {
              "t": "text",
              "v": "."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "If the player has "
            },
            {
              "t": "ref",
              "v": "Fightsabre",
              "kind": "gun"
            },
            {
              "t": "text",
              "v": ", the pig will be knocked back a significant distance when reloading."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "You do not gain temporary invulnerability like you normally would when you take damage upon being revived, making it easy to take damage after coming back to life."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Since "
            },
            {
              "t": "ref",
              "v": "The Robot",
              "kind": "character"
            },
            {
              "t": "text",
              "v": " does not have maximum health or permanent health upgrades, they will always have the default six "
            },
            {
              "t": "ref",
              "v": "Armor",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": " upon being revived."
            }
          ]
        }
      ],
      "trivia": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "After the effect of the item occurs, it will be permanently renamed to \"Hero Pig\", with a new description and pick-up quote that remain even after the run is over.\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "In Exit the Gungeon, the Pig's name and description does not change."
                }
              ]
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "This item may be a reference to the German movie \"Siegfried\", where a pig saves the protagonist's life by jumping in front of an arrow."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The name may be a reference to a viral video titled \"Pig rescues baby goat\", in which a pig appears out of nowhere to assist a drowning baby goat. (However, there was no sacrifice and the video was staged.)"
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "This item may be a reference to the anime \"Seven Deadly Sins\", where the talking pig Hawk, the Captain of the Order of Scraps Disposal, has identical properties."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The  "
            },
            {
              "t": "synref",
              "v": "Hyper Beam"
            },
            {
              "t": "text",
              "v": " synergy is a reference to the final fight against Mother Brain in Super Metroid, in which after the baby Metroid is killed, Samus gains the Hyper Beam."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The  "
            },
            {
              "t": "synref",
              "v": "The Line of Fire"
            },
            {
              "t": "text",
              "v": " synergy refers to the stuffed pig carried by Marvin Boggs (played by John Malkovich) in "
            },
            {
              "t": "text",
              "v": "RED.",
              "style": "i"
            },
            {
              "t": "text",
              "v": " Malkovich also played the assassin in "
            },
            {
              "t": "text",
              "v": "In the Line of Fire",
              "style": "i"
            },
            {
              "t": "text",
              "v": " which the Composite Gun is based on."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The  "
            },
            {
              "t": "synref",
              "v": "The Return"
            },
            {
              "t": "text",
              "v": " synergy is a reference to the in-game boss Cannon, himself a reference to Ganon from the "
            },
            {
              "t": "ext",
              "v": "Legend of Zelda",
              "url": "https://en.wikipedia.org/wiki/The_Legend_Of_Zelda"
            },
            {
              "t": "text",
              "v": " video game series. The synergy name refers to Cannon returning in some form via the appearance of the pig. The synergy being named \"The Return\" may also be a reference to the game-over screen from Legend of Zelda 2: Adventure of Link, which includes the line \"RETURN OF GANON\".\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "The pig's green color may also be an Angry Birds reference."
                }
              ]
            },
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "The pig also possible might be a reference to the anime \"seven deadly sins\" in which Hog the pet of the protagonists loves to use his body as a meat shield in heroic moments."
                }
              ]
            }
          ]
        }
      ]
    }
  },
  {
    "name": "Turkey",
    "icon": "https://static.wikia.nocookie.net/enterthegungeon_gamepedia/images/b/b3/Turkey.png",
    "type": "Passive",
    "quote": "Triple Tap",
    "quality": "C",
    "effect": "Recovers 1 ammo after landing three sequential hits.",
    "curse": 0.0,
    "coolness": 0.0,
    "wiki": {
      "effects": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "Recovers 1 ammo after landing three sequential shots."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Grants a turkey familiar."
            }
          ]
        }
      ],
      "notes": [
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "synref",
              "v": "The Elephant in the Room"
            },
            {
              "t": "text",
              "v": " - If the player has "
            },
            {
              "t": "ref",
              "v": "Elephant Gun",
              "kind": "gun"
            },
            {
              "t": "text",
              "v": ", it becomes an elephant head and shoots elephants instead of bullets."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "synref",
              "v": "Tea For Two"
            },
            {
              "t": "text",
              "v": " - If the player also has "
            },
            {
              "t": "ref",
              "v": "Teapot",
              "kind": "gun"
            },
            {
              "t": "text",
              "v": ", while reloading the Teapot, a small red aura will appear around the turkey. Every enemy in this aura will be ignited."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "For weapons that fire explosive, piercing, or multiple projectiles (including guns under the effects of "
            },
            {
              "t": "ref",
              "v": "Double Vision",
              "kind": "item"
            },
            {
              "t": "text",
              "v": ", "
            },
            {
              "t": "ref",
              "v": "Scattershot",
              "kind": "item"
            },
            {
              "t": "text",
              "v": ", or "
            },
            {
              "t": "ref",
              "v": "Helix Bullets",
              "kind": "item"
            },
            {
              "t": "text",
              "v": "), landing multiple hits does not contribute to ammo recovery. Ammo is only recovered if the weapon is fired three separate times, and at least one projectile landed each time.\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "The turkey does, however, count bullets fired by the "
                },
                {
                  "t": "ref",
                  "v": "Super Space Turtle",
                  "kind": "item"
                },
                {
                  "t": "text",
                  "v": " (and maybe other familiars) as if they were your own, allowing you to farm free ammo by simply allowing the turtle to attack enemies."
                }
              ]
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The effect applies even if the player switches weapons between shots. This can be used to endlessly restore ammo for guns with low ammo such as "
            },
            {
              "t": "ref",
              "v": "Makeshift Cannon",
              "kind": "gun"
            },
            {
              "t": "text",
              "v": "."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "If duplicates of this item are somehow obtained, further increases the amount of ammo recovered when three shots land.\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "Theoretically, obtaining at least three Turkeys will net the player no loss of ammo if they can manage to land every bullet."
                }
              ]
            }
          ]
        }
      ],
      "trivia": [
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "ref",
              "v": "Unused and Cut Content/Synergies",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": " - ("
            },
            {
              "t": "text",
              "v": "CustomSynergyType.FEATHER_PILLOW",
              "style": "code"
            },
            {
              "t": "text",
              "v": ") If the player has "
            },
            {
              "t": "ref",
              "v": "Silencer",
              "kind": "gun"
            },
            {
              "t": "text",
              "v": ", Silencer fires an exploding pillow that shoots feather projectiles each time it reloads."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "ref",
              "v": "Unused and Cut Content/Synergies",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": " - ("
            },
            {
              "t": "text",
              "v": "CustomSynergyType.GET_IT_ITS_BOWLING",
              "style": "code"
            },
            {
              "t": "text",
              "v": ") If the player has "
            },
            {
              "t": "ref",
              "v": "Serious Cannon",
              "kind": "gun"
            },
            {
              "t": "text",
              "v": ", it causes an unknown effect."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "This item's quote, as well as its primary function, are a reference to the \"Triple-Tap\" perk from the Destiny series."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The item itself and its description are a reference to bowling, where getting three strikes in a row is commonly referred to as a 'turkey'."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The item's picture resembles a drawing of a turkey, created by tracing the outline of a right hand."
            }
          ]
        }
      ]
    }
  },
  {
    "name": "Turtle Problem",
    "icon": "https://static.wikia.nocookie.net/enterthegungeon_gamepedia/images/e/e7/Turtle_Problem.png",
    "type": "Passive",
    "quote": "Is This Normal?",
    "quality": "C",
    "effect": "Clearing a room spawns a turtle companion. Turtles block enemy bullets and die after taking enough damage.",
    "curse": 0.0,
    "coolness": 0.0,
    "wiki": {
      "effects": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "Upon clearing a room, spawns a turtle familiar.\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "Turtles can block bullets and deal contact damage to enemies. They will die if they take a certain amount of damage."
                }
              ]
            }
          ]
        }
      ],
      "notes": [
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "synref",
              "v": "Turtle Solutions"
            },
            {
              "t": "text",
              "v": " - If the player has "
            },
            {
              "t": "ref",
              "v": "Super Space Turtle",
              "kind": "item"
            },
            {
              "t": "text",
              "v": ", each room clear will add another Super Space Turtle to a maximum of 4. These Super Space Turtles will no longer block bullets or collide with enemies. Dropping either item removes all active turtles.\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "If the player also has "
                },
                {
                  "t": "ref",
                  "v": "Yellow Chamber",
                  "kind": "item"
                },
                {
                  "t": "text",
                  "v": ", the spawned turtles will be jammed."
                }
              ]
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "If the player has "
            },
            {
              "t": "ref",
              "v": "Baby Good Mimic",
              "kind": "item"
            },
            {
              "t": "text",
              "v": ", it will become a turtle familiar, but will not add more turtles.\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "It is possible for the "
                },
                {
                  "t": "ref",
                  "v": "Baby Good Mimic",
                  "kind": "item"
                },
                {
                  "t": "text",
                  "v": " to die as a turtle."
                }
              ]
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "If duplicates of this item are somehow obtained, further increases the amount of turtles that will spawn after each room clear."
            }
          ]
        }
      ],
      "trivia": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "The item was originally cut from the main game, but reintroduced in "
            },
            {
              "t": "ref",
              "v": "A Farewell to Arms",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": "."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Most likely a reference to the philosophical conundrum of the Great Turtle (or any being) holding up the Earth.  \"What's holding up that turtle?\"  \"Another turtle.\"  \"So what's holding up that turtle?\"  \"It's turtles, all the way down.\""
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Possibly a reference to the Great God Om in Terry Pratchett's "
            },
            {
              "t": "text",
              "v": "Small Gods,",
              "style": "i"
            },
            {
              "t": "text",
              "v": " who was reduced to a talking turtle accompanying his one remaining true believer."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Could also be a reference to the quote \"It's turtles all the way down,\" which is often used to express a code problem that has many complex layers. This would explain the statement \"You’ve just inherited a big problem,\" since often in enterprise software, developers inherit a lot of complex code with complex problems."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The turtles can be stunned and killed with "
            },
            {
              "t": "ref",
              "v": "Grappling Hook",
              "kind": "item"
            },
            {
              "t": "text",
              "v": "."
            }
          ]
        }
      ]
    }
  },
  {
    "name": "Sprun",
    "icon": "https://static.wikia.nocookie.net/enterthegungeon_gamepedia/images/5/5a/Sprun.png",
    "type": "Passive",
    "quote": "The Way of Guns",
    "quality": "A",
    "effect": "Temporarily transforms into Windgunner under special circumstances.",
    "curse": 0.0,
    "coolness": 0.0,
    "wiki": {
      "effects": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "Summons a friendly green sprite to follow the player. This sprite can block enemy bullets."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "When picked up, Sprun will select a random trigger from a list of possible events. When this trigger is met, the sprite will vanish, and the player will be granted the  "
            },
            {
              "t": "ref",
              "v": "Windgunner",
              "kind": "unresolved"
            },
            {
              "t": "text",
              "v": " for around 10 seconds."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The full list of possible triggers for Sprun is as follows;\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "Player uses their last blank."
                }
              ]
            },
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "Player takes damage to hearts.\n"
                }
              ],
              "sub": [
                {
                  "tokens": [
                    {
                      "t": "text",
                      "v": "If playing as the Robot, taking armor damage also counts."
                    }
                  ]
                }
              ]
            },
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "Player loses their last piece of armor."
                }
              ]
            },
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "Player goes down to half a heart."
                }
              ]
            },
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "Player's gun runs out of ammo."
                }
              ]
            },
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "Player is set on fire."
                }
              ]
            },
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "Player takes damage from electrocution or poison."
                }
              ]
            },
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "Player falls into a pit."
                }
              ]
            },
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "Player flips a table."
                }
              ]
            },
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "Player uses an active item."
                }
              ]
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Once a trigger has been chosen, it will remain the same for the entire run."
            }
          ]
        }
      ],
      "item_interactions": [
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "ref",
              "v": "Metronome",
              "kind": "item"
            },
            {
              "t": "text",
              "v": " - Gaining and losing Windgunner does "
            },
            {
              "t": "text",
              "v": "not",
              "style": "i"
            },
            {
              "t": "text",
              "v": " reset the damage bonus of the Metronome."
            }
          ]
        }
      ],
      "notes": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "Sprun can trigger even while in a "
            },
            {
              "t": "ref",
              "v": "Sorceress",
              "kind": "unresolved"
            },
            {
              "t": "text",
              "v": "."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "If Sprun's trigger is falling into a pit, entering the "
            },
            {
              "t": "ref",
              "v": "Oubliette",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": " may trigger Sprun until the player falls into a pit again."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Even if the player has fire immunity, Sprun can activate when standing inside of it.\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "This does not apply to the poison/electrocution trigger, as the player must take damage."
                }
              ]
            },
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "Sprun will not activate if the player has fire immunity through flight."
                }
              ]
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Saving can reset the trigger to something else."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "If the trigger is falling into a pit, the player can jump into the pit left by the elevator and get the ability for no damage."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "If the trigger is using an active item, Windgunner can be used infinitely if the player has "
            },
            {
              "t": "ref",
              "v": "Jetpack",
              "kind": "item"
            },
            {
              "t": "text",
              "v": ", "
            },
            {
              "t": "ref",
              "v": "Busted Television",
              "kind": "item"
            },
            {
              "t": "text",
              "v": ", "
            },
            {
              "t": "ref",
              "v": "Grappling Hook",
              "kind": "item"
            },
            {
              "t": "text",
              "v": ", or any other item that has no cooldown time."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "If the trigger is using the last blank, "
            },
            {
              "t": "ref",
              "v": "Elder Blank",
              "kind": "item"
            },
            {
              "t": "text",
              "v": " cannot be used to activate Windgunner."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "While playing as The Robot, if the trigger is to be brought down to your last heart, Sprun will never activate and is effectively useless."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Even if its trigger is undesirable, such as requiring damage to be taken, it can still act as a decent shield due to its ability to be manually positioned. This is most useful against large directional barrages of bullets such as those fired by "
            },
            {
              "t": "ref",
              "v": "Wallmonger",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": " or "
            },
            {
              "t": "ref",
              "v": "High Dragun",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": "."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "If duplicates of this item are somehow obtained, adds another Sprun from behind in a similar behavior to duplicated "
            },
            {
              "t": "ref",
              "v": "Owl",
              "kind": "item"
            },
            {
              "t": "text",
              "v": "."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Entering a new chamber while Windgunner is active will end the effect."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": " Bug If Sprun is dropped and stolen by the "
            },
            {
              "t": "ref",
              "v": "Resourceful Rat",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": ", or eaten by the "
            },
            {
              "t": "ref",
              "v": "Serpent",
              "kind": "unresolved"
            },
            {
              "t": "text",
              "v": ", while Windgunner is active, Windgunner will never de-activate. This allows the player to use the immensely strong Windgunner for the remainder of their run, but prevents them from switching to, using, or dropping any other guns.\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "While this bug is active, entering a new chamber will "
                },
                {
                  "t": "text",
                  "v": "not",
                  "style": "i"
                },
                {
                  "t": "text",
                  "v": " remove Windgunner."
                }
              ]
            },
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "Saving and continuing a run with the "
                },
                {
                  "t": "ref",
                  "v": "Cryo Button?action=edit&redlink=1",
                  "kind": "unresolved"
                },
                {
                  "t": "text",
                  "v": " while this bug is active will 'fix' it, removing Windgunner from the player and allowing them to change guns."
                }
              ]
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": " Bug Trying to play Winchester's game while Windgunner is active will softlock the game."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": " Bug In "
            },
            {
              "t": "ref",
              "v": "Co-op",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": " mode, dropping Sprun while Windgunner is active and allowing the second player to pick it up will remove all of the first players guns when Windgunner disappears. Saving and reloading the run with the aid of the "
            },
            {
              "t": "ref",
              "v": "Cryo Button?action=edit&redlink=1",
              "kind": "unresolved"
            },
            {
              "t": "text",
              "v": " will return the missing guns."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "This item is a reference to "
            },
            {
              "t": "ext",
              "v": "Spren",
              "url": "https://coppermind.net/wiki/Spren"
            },
            {
              "t": "text",
              "v": " in the "
            },
            {
              "t": "text",
              "v": "Stormlight Archive",
              "style": "i"
            },
            {
              "t": "text",
              "v": " novel series. In the series, Spren are spirits of thought, and forces of nature which are harnessed by so-called 'Radiants', one type which is called a "
            },
            {
              "t": "text",
              "v": "Windrunner",
              "style": "i"
            },
            {
              "t": "text",
              "v": ".\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "The protagonist, Kaladin, is forced to carry bridges and is also a Windrunner."
                }
              ]
            },
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "The appearance of the Sprun somewhat matches the description of a "
                },
                {
                  "t": "ext",
                  "v": "Lifespren",
                  "url": "https://stormlightarchive.fandom.com/wiki/Spren_Types"
                },
                {
                  "t": "text",
                  "v": "."
                }
              ]
            },
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "The ten triggers are a reference to the ten orders of the "
                },
                {
                  "t": "ext",
                  "v": "Knights Radiant",
                  "url": "https://stormlightarchive.fandom.com/wiki/Knights%20Radiant"
                },
                {
                  "t": "text",
                  "v": " the books. Ten is considered a holy number in the series."
                }
              ]
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": " Fixed Bug On the release of "
            },
            {
              "t": "ref",
              "v": "A Farewell To Arms",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": ", the Polish, Spanish, and Portugese translation of Spruns "
            },
            {
              "t": "ref",
              "v": "Ammonomicon",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": " description read "
            },
            {
              "t": "text",
              "v": "\"Some description here. Don't Localize\"",
              "style": "i"
            },
            {
              "t": "text",
              "v": " in English."
            }
          ]
        }
      ]
    }
  },
  {
    "name": "Baby Good Mimic",
    "icon": "https://static.wikia.nocookie.net/enterthegungeon_gamepedia/images/d/d9/Baby_Good_Mimic.png",
    "type": "Passive",
    "quote": "Imitation Love",
    "quality": "B",
    "effect": "If no other familiars are present, follows the player and attacks enemies. If familiars are present, transforms into another one of the player's familiars.",
    "curse": 0.0,
    "coolness": 0.0,
    "wiki": {
      "effects": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "Follows the player around. When in a room with enemies, Baby Good Mimic will sit still and pretend to be a chest. If an enemy shoots Baby Good Mimic in this state, it will open and shoot projectiles in random directions for a few moments before resuming its pretence."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Enemies that touch Baby Good Mimic directly will take contact damage."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "If the player has other "
            },
            {
              "t": "ref",
              "v": "Companions",
              "kind": "unresolved"
            },
            {
              "t": "text",
              "v": ", Baby Good Mimic will permanently transform itself into a second copy of the oldest companion the player has. This copies all the effects and abilities of that companion, replacing Baby Good Mimics default behaviours.\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "As "
