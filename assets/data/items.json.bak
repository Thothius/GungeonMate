    "quote": "Unfinished Business",
    "quality": "C",
    "effect": "Adds a chance to refund ammo when a shot misses.",
    "curse": 0.0,
    "coolness": 0.0,
    "wiki": {
      "effects": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "Adds a 25% chance to refund ammo when a shot misses."
            }
          ]
        }
      ],
      "notes": [
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "synref",
              "v": "Dawn of the Gundead"
            },
            {
              "t": "text",
              "v": " - If the player also has "
            },
            {
              "t": "ref",
              "v": "Gunslinger's Ashes",
              "kind": "gun"
            },
            {
              "t": "text",
              "v": ", "
            },
            {
              "t": "ref",
              "v": "Shellegun",
              "kind": "gun"
            },
            {
              "t": "text",
              "v": ", "
            },
            {
              "t": "ref",
              "v": "Skull Spitter",
              "kind": "gun"
            },
            {
              "t": "text",
              "v": ", "
            },
            {
              "t": "ref",
              "v": "Fossilized Gun",
              "kind": "gun"
            },
            {
              "t": "text",
              "v": " or "
            },
            {
              "t": "ref",
              "v": "VertebraeK-47",
              "kind": "gun"
