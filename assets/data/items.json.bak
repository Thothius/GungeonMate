            },
            {
              "t": "text",
              "v": " item in the game "
            },
            {
              "t": "text",
              "v": "Crypt of the Necrodancer",
              "style": "i"
            },
            {
              "t": "text",
              "v": "."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The \"Two Heavy\" synergy is a nod to the adage, \"Heavy is the head that wears the crown,\" as in this case, you would be wearing two."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "A Coin Crown can be seen among the pile of items that makes up the "
            },
            {
              "t": "ref",
              "v": "Resourceful Rat",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": " throne in the "
            },
            {
              "t": "ref",
              "v": "Resourceful Rat's Lair",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": "."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "In pre-release versions of "
            },
            {
              "t": "text",
              "v": "Enter the Gungeon",
              "style": "i"
            },
            {
              "t": "text",
              "v": ", the Coin Crowns sprite was used in the UI pop up announcing that the player had completed one of the "
            },
            {
              "t": "ref",
              "v": "Gunsling King",
              "kind": "unresolved"
            },
            {
              "t": "text",
              "v": " challenges."
            }
          ]
        }
      ]
    }
