  {
    "name": "Silver Bullets",
    "icon": "https://static.wikia.nocookie.net/enterthegungeon_gamepedia/images/c/c3/Silver_Bullets.png",
    "type": "Passive",
    "quote": "Blessed Metal",
    "quality": "C",
    "effect": "Increases damage to jammed enemies by 225% and Increases damage to bosses by 25%.",
    "curse": 0.0,
    "coolness": 0.0,
    "wiki": {
      "effects": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "Increases damage to "
            },
            {
              "t": "ref",
              "v": "Curse",
              "kind": "stat"
            },
            {
              "t": "text",
              "v": " enemies by 225% for a total damage output of 325%."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Increases damage to "
            },
            {
              "t": "ref",
              "v": "Bosses",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": " by 25%."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Tints player projectiles and beams a silver colour."
            }
          ]
        }
      ],
      "notes": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "This item is a reference to the common folklore trope of "
            },
            {
              "t": "ext",
              "v": "silver bullets",
              "url": "https://en.wikipedia.org/wiki/Silver_bullet"
            },
            {
              "t": "text",
              "v": ", often spoken of as the only effective weapon capable of dispatching werewolves, vampires, or other supernatural entities."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The name of the synergy  "
            },
            {
              "t": "synref",
              "v": "Hell Singing"
            },
            {
              "t": "text",
              "v": " is in reference to "
            },
            {
              "t": "ext",
              "v": "Abraham Van Helsing",
              "url": "https://en.wikipedia.org/wiki/Abraham_Van_Helsing"
            },
            {
              "t": "text",
              "v": ", a fictional doctor and scientist from Bram Stoker's "
            },
            {
              "t": "text",
              "v": "Dracula",
              "style": "i"
            },
            {
              "t": "text",
              "v": ". In the original novel, Van Helsing is a normal man who assists in studying the mysterious vampire-induced illness afflicting Lucy Westenra. In subsequent adaptations of the "
            },
            {
              "t": "text",
              "v": "Dracula",
              "style": "i"
            },
            {
              "t": "text",
              "v": " story Van Helsing has been reimagined in popular culture as an active vampire expert and hunter."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The  "
            },
            {
              "t": "ref",
              "v": "Trick Gun",
              "kind": "gun"
            },
            {
              "t": "text",
              "v": " synergising with Silver Bullets for the  "
            },
            {
              "t": "synref",
              "v": "Hell Singing"
            },
            {
              "t": "text",
              "v": " is likely a reference to the "
            },
            {
              "t": "ext",
              "v": "Quicksilver Bullets",
              "url": "https://bloodborne.wiki.fextralife.com/Quicksilver+Bullets"
            },
            {
              "t": "text",
              "v": " used as ammunition for the original Trick Gun in "
            },
            {
              "t": "text",
              "v": "Bloodborne",
              "style": "i"
            },
            {
              "t": "text",
              "v": "."
            }
          ]
