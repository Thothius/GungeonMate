  {
    "name": "Shotgun Coffee",
    "icon": "https://static.wikia.nocookie.net/enterthegungeon_gamepedia/images/0/02/Shotgun_Coffee.png",
    "type": "Passive",
    "quote": "Speed Up",
    "quality": "C",
    "effect": "Increases movement speed.",
    "curse": 0.0,
    "coolness": 0.0,
    "wiki": {
      "effects": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "Increases movement speed by 1.2."
            }
          ]
        }
      ],
      "notes": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "This item's description is a reference to Futurama where Fry drinks 100 cups of coffee, which causes him to move at extreme speeds."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "\"Shotgun\" coffee may be a reference to so-called \"Bulletproof\" coffee, in which mixing unsalted butter into a cup of hot coffee is said to enhance mental clarity."
            }
          ]
        }
      ]
    }
  },
  {
    "name": "Shotga Cola",
    "icon": "https://static.wikia.nocookie.net/enterthegungeon_gamepedia/images/e/ea/Shotga_Cola.png",
    "type": "Passive",
    "quote": "Speed Up",
    "quality": "C",
    "effect": "Increases movement speed.",
    "curse": 0.0,
    "coolness": 0.0,
    "wiki": {
      "effects": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "Increases movement speed by 1.5."
            }
          ]
        }
      ],
      "notes": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "The name and effect of this item are a reference to the caffeinated German chocolate "
            },
            {
              "t": "ext",
              "v": "Scho-Ka-Kola",
              "url": "https://en.wikipedia.org/wiki/Scho-Ka-Kola"
            },
            {
              "t": "text",
              "v": ", which was initially advertised as an athletic performance enhancer in the 1930s. It would later go on to be a stimulant to boost wakefulness and alertness for pilots, tank crews, and U-boat operators in Nazi Germany during World War II."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The "
            },
            {
              "t": "ref",
              "v": "Ammonomicon",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": " description "
            },
            {
              "t": "text",
              "v": "\"save the cap\"",
              "style": "i"
            },
            {
              "t": "text",
              "v": " is a reference to the "
            },
            {
              "t": "text",
              "v": "Fallout",
              "style": "i"
            },
            {
              "t": "text",
              "v": " franchise, where the caps of beverages such as "
            },
            {
              "t": "ext",
              "v": "Nuka-Cola",
              "url": "https://fallout.wiki/wiki/Overview:Nuka-Cola"
            },
            {
              "t": "text",
              "v": " are used as currency."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "This item may also be a reference to the practice of '"
            },
            {
              "t": "ext",
              "v": "shotgunning",
              "url": "https://en.wikipedia.org/wiki/Shotgunning"
            },
            {
              "t": "text",
              "v": "' a canned beverage, done by poking a hole in the side of the can to drink through instead of the top."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The name of  "
            },
            {
              "t": "synref",
              "v": "Five O'Clock Somewhere"
            },
            {
              "t": "text",
              "v": " is a reference to the idiom "
            },
            {
              "t": "text",
              "v": "\"",
              "style": "i"
            },
            {
              "t": "ext",
              "v": "it's five o'clock somewhere",
