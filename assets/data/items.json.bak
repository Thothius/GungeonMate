  {
    "name": "Chance Bullets",
    "icon": "https://static.wikia.nocookie.net/enterthegungeon_gamepedia/images/f/fa/Chance_Bullets.png",
    "type": "Passive",
    "quote": "Good RNG",
    "quality": "B",
    "effect": "Upon firing, adds a chance to fire projectiles from the player's other guns.",
    "curse": 0.0,
    "coolness": 0.0,
    "wiki": {
      "effects": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "Upon firing, adds a chance to fire projectiles from the player's other guns. Shots fired this way from other guns do not consume ammo from that gun."
            }
          ]
        }
      ],
      "notes": [
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "synref",
              "v": "Maximize Spell"
            },
            {
              "t": "text",
              "v": " - If the player also has "
            },
            {
              "t": "ref",
              "v": "Flame Hand",
              "kind": "gun"
            },
            {
              "t": "text",
              "v": ", Flame Hand becomes green and creates pools of green fire. Green fire does not damage the player, and enemies that touch green fire are permanently aflame."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "synref",
              "v": "Turret Link"
            },
            {
              "t": "text",
              "v": " - If the player also has "
            },
            {
              "t": "ref",
              "v": "Portable Turret",
              "kind": "item"
            },
            {
              "t": "text",
              "v": ", Portable Turret will sometimes fire shots from guns in the player's inventory."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "This item has no effect if the player only has one gun."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "This item does not work when wielding a weapon with infinite ammo, and other guns using this effect will not shoot bullets from infinite-ammo weapons."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Shots from this weapon will not refill ammo on the "
            },
            {
              "t": "ref",
              "v": "Hyper Light Blaster",
              "kind": "gun"
            },
            {
              "t": "text",
              "v": "."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "This item can occasionally shoot "
            },
            {
              "t": "ref",
              "v": "Makeshift Cannon",
              "kind": "gun"
            },
            {
              "t": "text",
              "v": "'s bullets with other guns, but the chance is smaller than with other guns."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "This item will not cause beam guns to fire other projectiles."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "If a beam gun's beam is fired from another gun, it will be fired for about a second in the direction the player was initially aiming, and will not move to follow the crosshair."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "ref",
              "v": "Bubble Blaster",
              "kind": "gun"
            },
            {
              "t": "text",
              "v": " bubbles created while holding another gun do not accelerate upon reloading, even if the proper gun is switched to."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "This item also works on the "
            },
            {
              "t": "ref",
              "v": "Prize Pistol",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": ".\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "Other shots fired from the gun do not break the targets."
                }
              ]
            },
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "It is recommended to drop the item before playing Winchester's game, as items cannot be dropped while playing.                                                             * Beam type weapons activating upon other weapons through chance bullets while dodge rolling or on co-op may crash the game."
                }
              ]
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "This item is less effective if multiple automatic type guns are held, due to the shots from the other automatic guns having low damage. If an automatic gun is used then it will be a bit stronger than usual."
            }
          ]
        }
      ],
      "trivia": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "This item has a D20 at its top, which is a die used in RPG games to determine the intensity of what happens to players. It also references "
            },
            {
              "t": "ref",
              "v": "Daisuke",
              "kind": "unresolved"
            },
            {
              "t": "text",
              "v": ", "
            },
            {
              "t": "ref",
              "v": "Challenge Mode",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": " and the factor of luck of the item itself."
            }
          ]
        }
      ]
    }
  },
  {
    "name": "Helix Bullets",
    "icon": "https://static.wikia.nocookie.net/enterthegungeon_gamepedia/images/f/f7/Helix_Bullets.png",
    "type": "Passive",
    "quote": "Praise Be",
    "quality": "B",
    "effect": "Doubles fired bullets and makes them move in a helix pattern, but slightly decreases damage.",
    "curse": 0.0,
    "coolness": 0.0,
    "wiki": {
      "effects": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "Doubles the player's bullets and causes them to travel through the air in a helical pattern.\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "Each bullet deals 66% of its original damage, for a net 32% increase in damage if both bullets hit their target."
                }
              ]
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Doubles fired beams. Beams will also travel in progressing helical wave patterns."
            }
          ]
        }
      ],
      "item_interactions": [
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "ref",
              "v": "Orbital Bullets",
              "kind": "item"
            },
            {
              "t": "text",
              "v": " - Instead of orbiting in smooth circles, projectiles will instead follow a rotating elliptical orbit. Instead of traveling in perfect circles around the player, beams will form rotating overlapping shapes with a number of hills and valleys- merging the orbital and helical patterns together."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "ref",
              "v": "Homing Bullets",
              "kind": "item"
            },
            {
              "t": "text",
              "v": " /  "
            },
            {
              "t": "ref",
              "v": "Crutch",
