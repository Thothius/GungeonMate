        },
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "ref",
              "v": "Ring of the Resourceful Rat",
              "kind": "item"
            },
            {
              "t": "text",
              "v": " - Trading a cursed item created by the Lament Configurum with the "
            },
