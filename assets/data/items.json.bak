    "quote": "Fourth Chamber",
    "quality": "N",
    "effect": "Grants a heart container.",
    "curse": 0.0,
    "coolness": 0.0,
    "wiki": {
      "effects": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "Grants a "
            },
            {
              "t": "ref",
              "v": "Health",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": "."
            }
          ]
        }
      ],
      "notes": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "Master Rounds are one of the necessary materials to unlock "
            },
            {
              "t": "ref",
              "v": "Shortcuts",
              "kind": "unresolved"
            },
            {
              "t": "text",
              "v": ". When they are used for this purpose, the "
            },
            {
              "t": "ref",
              "v": "Tinker",
              "kind": "unresolved"
            },
            {
              "t": "text",
              "v": " will take away one Master Round, and therefore remove a heart container from the player."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Master Rounds will not appear if the player takes any kind of damage during a boss fight, including falling into pits and other kinds of damage not inflicted by the boss itself.\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "Master Rounds will also not appear if the player takes damage during a boss fight, and then restarts the boss fight using the "
                },
                {
                  "t": "ref",
                  "v": "Escape Rope",
                  "kind": "item"
                },
                {
                  "t": "text",
                  "v": " or "
                },
                {
                  "t": "ref",
                  "v": "Teleporter Prototype",
                  "kind": "item"
                },
                {
                  "t": "text",
                  "v": "."
                }
              ]
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Master Rounds can be dropped, which will remove a heart container. When they are picked up after being dropped, they will add an empty heart container."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Master Rounds give one piece of armor to "
            },
            {
              "t": "ref",
              "v": "The Robot",
              "kind": "character"
            },
            {
              "t": "text",
              "v": "."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Master Rounds can be sold to the "
            },
            {
              "t": "ref",
              "v": "Sell Creep",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": " for 3 , if sold in a special room in the "
            },
            {
              "t": "ref",
              "v": "Hollow",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": " along with two "
            },
            {
              "t": "ref",
              "v": "Items",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": ", it will open the entrance to the "
            },
            {
              "t": "ref",
              "v": "R&G Dept.",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": "."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Master Rounds can't be stolen by the "
            },
            {
              "t": "ref",
              "v": "Resourceful Rat",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": "."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Acquiring five master rounds in a single run unlocks the "
            },
            {
              "t": "ref",
              "v": "Achievements",
              "kind": "unresolved"
            },
            {
              "t": "text",
              "v": " and "
            },
            {
              "t": "ref",
              "v": "Super Hot Watch",
              "kind": "item"
            },
            {
              "t": "text",
              "v": ".\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "The achievement can still be unlocked via "
                },
                {
                  "t": "ref",
                  "v": "Boss Rush",
                  "kind": "lore"
                },
                {
                  "t": "text",
                  "v": " or by acquiring duplicate Master Rounds with "
                },
                {
                  "t": "ref",
                  "v": "Clone",
                  "kind": "item"
                },
                {
                  "t": "text",
                  "v": ". For example, if the player gets four master rounds, then dies with Clone and respawns in the Keep of the Lead Lord, the achievement will be unlocked as soon as they get another Master Round."
                }
              ]
            },
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "It is not necessary to pick up the Master Rounds to unlock Lead God (although there is no reason not to pick them up). The achievement will still unlock if the player beats the five bosses flawlessly without picking up the Master Rounds that they drop."
                }
              ]
            },
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "Killing a secret boss without taking damage counts toward unlocking the achievement."
                }
              ]
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "There exists an unused "
            },
            {
              "t": "ref",
              "v": "Master Round (VI)",
              "kind": "unresolved"
            },
            {
              "t": "text",
              "v": ", likely as a prize for defeating the "
            },
            {
              "t": "ref",
              "v": "Lich",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": " without taking any damage."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "In co-op, the Master Round only affects the player who is holding it."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The  "
            },
            {
              "t": "synref",
              "v": "Chief Master"
            },
            {
              "t": "text",
              "v": " synergy is a reference to "
            },
            {
              "t": "ext",
              "v": "Master Chief",
              "url": "https://en.wikipedia.org/wiki/Master_Chief_(Halo)"
            },
            {
              "t": "text",
              "v": " from the "
            },
            {
              "t": "ext",
              "v": "Halo",
              "url": "https://en.wikipedia.org/wiki/Halo_(franchise)"
            },
            {
              "t": "text",
              "v": " video game series."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "ref",
              "v": "Unused and Cut Content",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": " - "
            },
            {
              "t": "ref",
              "v": "Lil' Bomber",
              "kind": "gun"
            },
            {
              "t": "text",
              "v": " used to be able to synergize with the first Master Round for the synergy  "
            },
            {
              "t": "synref",
              "v": "King Bomber"
            },
            {
              "t": "text",
              "v": ", but was removed because it was too easy to obtain."
            }
          ]
        }
      ]
    }
  },
