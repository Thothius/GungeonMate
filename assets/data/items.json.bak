          ]
        }
      ],
      "item_interactions": [
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "ref",
              "v": "Knight's Gun",
              "kind": "gun"
            },
            {
              "t": "text",
              "v": " - The Knight's Gun is capable of digging up Spice on reloading. If Spice has been used, generic items or pickups dug up by the Knight's Gun have an "
            },
            {
              "t": "text",
              "v": "additional",
              "style": "i"
            },
            {
              "t": "text",
              "v": " chance to be replaced by even more Spice."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "ref",
              "v": "Clone",
              "kind": "item"
            },
            {
              "t": "text",
              "v": " - Dying and resurrecting with Clone does "
            },
            {
              "t": "text",
              "v": "not",
              "style": "i"
            },
            {
              "t": "text",
              "v": " reset the player's Spice addiction."
            }
          ]
        }
      ],
      "notes": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "In "
            },
            {
              "t": "ref",
              "v": "Co-op",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": " mode, effects of spice usage are counted separately for each player. The sole exception is the increased spice wieght, which is based on the combined number of times both players have used Spice. (For example, if both players have used Spice twice, Spice will have a 80% chance to replace future items, the same as if one player had used it four times).\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": " Possible Bug Dying in co-op mode removes any stat modifiers that the dead player gained through spice. These stats are "
                },
                {
                  "t": "text",
                  "v": "not",
                  "style": "i"
                },
                {
                  "t": "text",
                  "v": " returned on being resurrected. The number of times spice has been used is "
                },
                {
                  "t": "text",
                  "v": "not",
                  "style": "i"
                },
                {
                  "t": "text",
                  "v": " reset."
                }
              ]
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The health reduction from Spice "
            },
            {
              "t": "text",
              "v": "cannot",
              "style": "i"
            },
            {
              "t": "text",
              "v": " put the player below 1 heart container, however continuing to put the "
            },
            {
              "t": "ref",
              "v": "Health",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": " stat into the negatives by Spice usage will prevent "
            },
            {
              "t": "text",
              "v": "future",
              "style": "i"
            },
            {
              "t": "text",
              "v": " health upgrades from having any effect until the number of heart containers gained exceeds the amount of negative health created by spice."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Spice usage has no effect on  "
            },
            {
              "t": "ref",
              "v": "Armor",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": ", and as such has no negative effect on the health of "
            },
            {
              "t": "ref",
              "v": "The Robot",
              "kind": "character"
            },
            {
              "t": "text",
              "v": "."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Like other limited-use active items, Spice will stack with itself and multiple Spice can be carried at once."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Each time Spice is used, the pickup quote changes:\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "On first pickup: A tantalizing cube of power."
                }
              ]
            },
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "After first use: One more couldn't hurt."
                }
              ]
            },
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "After second use: Just one more hit..."
                }
              ]
            },
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "After third use: MORE"
                }
              ]
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "If the player has 40 Spice in their inventory, the game will stop spawning more Spice.\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "If the player has the  "
                },
                {
                  "t": "ref",
                  "v": "Knight's Gun",
                  "kind": "gun"
                },
                {
                  "t": "text",
                  "v": ", Spice can still be dug up even after 40 have been obtained."
                }
              ]
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The effects of Spice do not persist to "
            },
            {
              "t": "ref",
              "v": "The past",
              "kind": "unresolved"
            },
            {
              "t": "text",
              "v": "."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Spice can still appear as a boss reward, or in "
            },
            {
              "t": "ref",
              "v": "Shops",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": " in "
            },
            {
              "t": "ref",
              "v": "Rainbow Mode",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": ". While it can also appear in the  "
            },
            {
              "t": "ref",
              "v": "Rainbow Chest",
              "kind": "unresolved"
            },
            {
              "t": "text",
              "v": " at the start of each floor, it will only replace "
            },
            {
              "t": "text",
              "v": "one",
              "style": "i"
            },
            {
              "t": "text",
              "v": " of the items on offer."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": " Possible Bug Stacks of Spice will sell for the same amount to the "
            },
            {
              "t": "ref",
              "v": "Sell Creep",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": " as individual Spice cubes, making hoarding Spice to sell it ineffectual."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": " Bug Saving and reloading a run at the "
            },
            {
              "t": "ref",
              "v": "Cryo Button?action=edit&redlink=1",
              "kind": "unresolved"
            },
            {
              "t": "text",
              "v": " will reset the number of times spice has been used in the run to 0, while keeping the previously gained stats. This resets the likelihood of finding spice to its base values, the same likelihood as any other item.\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "If Spice is found and used again, the game will consider it the first usage again, potentially allowing the player to farm heart containers by saving and quitting between every floor."
                }
              ]
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "This item is a reference to "
            },
            {
              "t": "ext",
              "v": "Dune",
              "url": "https://en.wikipedia.org/wiki/Dune_(franchise)"
            },
            {
              "t": "text",
              "v": ". In the novel, Spice is a highly addictive drug that gives heightened awareness and considerably increased longevity, but withdrawal is fatal."
            }
          ]
        }
      ]
    }
  },
  {
    "name": "Liquid Valkyrie",
    "icon": "https://static.wikia.nocookie.net/enterthegungeon_gamepedia/images/2/25/Liquid_Valkyrie.png",
    "type": "Passive",
    "quote": "Maximum Pain",
    "quality": "A",
    "effect": "Decreases enemy bullet speed by 20%.",
    "curse": 0.0,
    "coolness": 0.0,
    "wiki": {
      "effects": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "Decreases enemy bullet speed by 20%."
            }
          ]
        }
      ],
      "item_interactions": [
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "ref",
              "v": "Bloody Eye",
              "kind": "item"
            },
            {
              "t": "text",
              "v": " - Enemy bullet speed is reduced by 32%."
            }
          ]
        }
      ],
      "notes": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "This item can be counterproductive; since bullets are slower than usual, the time the bullets are in midair is increased, meaning the player can run into bullets that would have already disappeared without Liquid Valkyrie. This is noticeable when fighting "
            },
            {
              "t": "ref",
              "v": "Old King",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": " while he does his spinning attack; the bullets move slower at the same spread, making it harder to navigate through the gaps. The same applies to "
            },
            {
              "t": "ref",
              "v": "Bloody Eye",
              "kind": "item"
            },
            {
              "t": "text",
              "v": "."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The name and "
            },
            {
              "t": "ref",
              "v": "Ammonomicon",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": " quote of this item are references to "
            },
            {
              "t": "text",
              "v": "Max Payne,",
              "style": "i"
            },
            {
              "t": "text",
              "v": " specifically the performance-enhancing drug "
            },
            {
              "t": "text",
              "v": "Valkyr.",
              "style": "i"
            }
          ]
        }
      ]
    }
  },
