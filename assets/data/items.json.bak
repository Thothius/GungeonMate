    }
  },
  {
    "name": "Big Boy",
    "icon": "https://static.wikia.nocookie.net/enterthegungeon_gamepedia/images/7/7b/Big_Boy.png",
    "type": "Active",
    "quote": "Set The World On Fire",
    "quality": "B",
    "effect": "Calls down a missile at the crosshair, causing a large explosion that leaves behind a large pool of poison creep. Increases curse by 1 while held.",
    "curse": 1.0,
    "coolness": 0.0,
    "wiki": {
      "effects": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "Calls down a missile at the crosshair, causing a large nuclear explosion that deals 150 damage and leaves behind a large pool of poison goop.\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "Enemies within a large radius of the explosion turn into "
                },
                {
                  "t": "ref",
                  "v": "Mutant Bullet Kin",
                  "kind": "unresolved"
                },
                {
                  "t": "text",
                  "v": ". This effect can transform enemies that are normally invulnerable, such as "
                },
                {
                  "t": "ref",
                  "v": "Gunreaper",
                  "kind": "unresolved"
                },
                {
                  "t": "text",
                  "v": "."
                }
              ]
            },
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "The explosion will clear enemy bullets in a large area."
                }
              ]
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Increases  "
            },
            {
              "t": "ref",
              "v": "Curse",
              "kind": "stat"
            },
            {
              "t": "text",
              "v": " by 1 while held."
            }
          ]
        }
      ],
      "notes": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "The damage done upon use will contribute to its recharge, even without "
            },
            {
              "t": "ref",
              "v": "Ice Cube",
              "kind": "item"
            },
            {
              "t": "text",
              "v": "."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The Big Boy's explosion transforming enemies into "
            },
            {
              "t": "ref",
              "v": "Mutant Bullet Kin",
              "kind": "unresolved"
            },
            {
              "t": "text",
              "v": " is a reference to the mutagenic effects of radiation, such as would contaminate the environment in the wake of a nuclear explosion.\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "It may also be a secondary reference to the "
                },
                {
                  "t": "ext",
                  "v": "Ghoul",
                  "url": "https://fallout.fandom.com/wiki/Ghoul"
                },
                {
                  "t": "text",
                  "v": " enemies from the "
                },
                {
                  "t": "text",
                  "v": "Fallout",
                  "style": "i"
                },
                {
                  "t": "text",
                  "v": " franchise, which are humans that have been mutated by nuclear radiation."
                }
              ]
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The Ammonomicon quote "
            },
            {
              "t": "text",
              "v": "\"Set The World On Fire\"",
              "style": "i"
            },
            {
              "t": "text",
              "v": " is a reference to the song "
            },
            {
              "t": "text",
              "v": "I Don't Want To Set The World On Fire",
              "style": "i"
            },
            {
              "t": "text",
              "v": " by the Ink Spots. This song is famously and prominently used in the "
            },
            {
              "t": "text",
              "v": "Fallout",
              "style": "i"
            },
            {
              "t": "text",
              "v": " franchise."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The name "
            },
            {
              "t": "text",
              "v": "Big Boy",
              "style": "i"
            },
            {
              "t": "text",
              "v": " is a reference to "
            },
            {
              "t": "ext",
              "v": "Little Boy",
              "url": "https://en.wikipedia.org/wiki/Little_Boy"
            },
            {
              "t": "text",
              "v": ", the code-name for the nuclear bomb which was dropped on the city of "
            },
            {
              "t": "ext",
              "v": "Hiroshima",
              "url": "https://en.wikipedia.org/wiki/Hiroshima"
            },
            {
              "t": "text",
              "v": " in 1945.\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "It may also be a secondary reference to the "
                },
                {
                  "t": "ext",
                  "v": "weapon of the same name",
                  "url": "https://fallout.fandom.com/wiki/Big_Boy"
                },
                {
                  "t": "text",
                  "v": " in "
                },
                {
                  "t": "text",
                  "v": "Fallout 4",
                  "style": "i"
                },
                {
                  "t": "text",
                  "v": "."
                }
              ]
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The appearance of the Big Boy is a reference to the "
            },
            {
              "t": "ext",
              "v": "Moscow-Washington hotline",
              "url": "https://en.wikipedia.org/wiki/Moscow%E2%80%93Washington_hotline"
            },
            {
              "t": "text",
              "v": ", a direct communications link between the "
            },
            {
              "t": "ext",
              "v": "Pentagon",
              "url": "https://en.wikipedia.org/wiki/The_Pentagon"
            },
            {
              "t": "text",
              "v": " in Washington D.C. and the "
            },
            {
              "t": "ext",
              "v": "Kremlin",
              "url": "https://en.wikipedia.org/wiki/Kremlin"
            },
            {
              "t": "text",
              "v": " in Moscow. This communication was established to increase co-operation between the United States of America and the Russian Federation (formerly the Soviet Union), and potentially prevent the escalation of nuclear warfare between the two superpowers.\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "This hotline is commonly referred to as the \"Red Telephone\" in pop culture (Hence the appearance of the Big Boy). Despite this, the hotline is not actually a telephone, but rather a text-based system."
                }
              ]
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Big Boy was reduced in quality from  to  in ."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The explosion created by Big Boy looks identical to that which appears when defeating the "
            },
            {
              "t": "ref",
              "v": "Lich",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": "."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The "
            },
            {
              "t": "ref",
              "v": "Sniper Shell",
              "kind": "unresolved"
            },
            {
              "t": "text",
              "v": " spawned atop the "
            },
            {
              "t": "ref",
              "v": "Wallmonger",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": " by the  "
            },
            {
              "t": "ref",
              "v": "Challenge Mode",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": " challenge modifier are usually completely invulnerable, but can still be transmogrified into "
            },
            {
              "t": "ref",
              "v": "Mutant Bullet Kin",
              "kind": "unresolved"
            },
            {
              "t": "text",
              "v": " by the Big Boy's blast."
            }
          ]
        }
      ]
    }
  },
  {
    "name": "Roll Bomb",
