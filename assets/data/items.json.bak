        {
          "tokens": [
            {
              "t": "text",
              "v": "If duplicates of this item are somehow obtained, allows the effect to happen on each separate Nanomachine.\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "Obtaining 4 Nanomachines allows the player to be invincible, as the amount of Nanomachines grants enough armor to negate the damage outright."
                }
              ]
            }
          ]
