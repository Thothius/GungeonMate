          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The synergy \"Heart-Shaped Box\" is a reference to the song of the same name by "
            },
            {
              "t": "text",
              "v": "Nirvana",
              "style": "i"
            },
            {
              "t": "text",
              "v": "."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "If you take damage from Lament Configurum that kills you when a gun or item spawns while you have Clone in your inventory you get the gun or item put directly into your inventory after you revive, despite the fact that the guns and items spawn on the ground."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "A depiction of the Lament Configurum can be seen in the opening scroll of the "
            },
            {
              "t": "ext",
              "v": "Supply Drop Trailer",
              "url": "https://www.youtube.com/watch?v=x3YN0qhy8R8"
            },
            {
              "t": "text",
              "v": "."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": " Bug If the player triggers a challenge shrine, completes it, then uses Lament Configurum before leaving the room, upon completion, a new chest will spawn. This does not work if the player exits and re-enters the room."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": " Bug Because the player is not immune to damage during transitions between boss fights, it is possible to take damage from spawned enemies during that transition, such as during the "
            },
            {
              "t": "ref",
              "v": "Lich",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": " boss fight."
            }
          ]
        }
      ]
    }
  },
  {
