  {
    "name": "Table Tech Shotgun",
    "icon": "https://static.wikia.nocookie.net/enterthegungeon_gamepedia/images/1/11/Table_Tech_Shotgun.png",
    "type": "Passive",
    "quote": "Flip Out",
    "quality": "D",
    "effect": "Tables release a homing shotgun blast of bullets when flipped.",
    "curse": 0.0,
    "coolness": 0.0,
    "wiki": {
      "effects": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "Flipping a "
            },
            {
              "t": "ref",
              "v": "Table",
              "kind": "unresolved"
            },
            {
              "t": "text",
              "v": " releases a shotgun blast of 10 homing bullets in the direction the table was flipped.\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "These bullets deal 6 damage each, with a combined damage of 60 per table flip if all bullets find a target."
                }
              ]
            },
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "These bullets can also bounce up to 4 times, and are affected by the players bullet modifiers."
                }
              ]
            }
          ]
        }
      ],
      "notes": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "There is a small chance for the bullets to overlap with the table when flipped, destroying them instantly and giving the illusion that nothing was fired. This is more common for tables flipped upwards.\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "The chance greatly increases with items that increase bullet size, like "
                },
                {
                  "t": "ref",
                  "v": "Fat Bullets",
                  "kind": "item"
                },
                {
                  "t": "text",
                  "v": " and "
                },
                {
                  "t": "ref",
                  "v": "Stout Bullets",
                  "kind": "item"
                },
                {
                  "t": "text",
                  "v": "."
                }
              ]
            }
          ]
        },
        {
          "tokens": [
