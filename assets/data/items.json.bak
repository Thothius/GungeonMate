  {
    "name": "R2G2",
    "icon": "https://static.wikia.nocookie.net/enterthegungeon_gamepedia/images/b/bd/R2G2.png",
    "type": "Passive",
    "quote": "Gunmech Robot",
    "quality": "1S",
    "effect": "Follows the player, firing bullets at enemies.",
    "curse": 0.0,
    "coolness": 0.0,
    "wiki": {
      "effects": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "Summons a robotic companion that follows the player."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "When an enemy is in range, it prioritizes following the target and periodically fires a rapid burst of 6 bullets at them.\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "A barrage is fired every 4 seconds, firing 6 bullets that deal 5 damage each."
                }
              ]
            }
          ]
        }
      ],
      "notes": [
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "synref",
              "v": "Battery Powered"
            },
            {
              "t": "text",
              "v": " - If the player has "
            },
            {
              "t": "ref",
              "v": "Shock Rifle",
              "kind": "gun"
            },
            {
              "t": "text",
              "v": ", it automatically regenerates ammo over time."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "synref",
              "v": "Tea For Two"
            },
            {
              "t": "text",
              "v": " - If the player has the "
            },
            {
              "t": "ref",
              "v": "Teapot",
              "kind": "gun"
            },
            {
              "t": "text",
              "v": ", a small red aura will appear around the R2G2, when the player reloads the Teapot. Every enemy in this aura will be ignited."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Unlike most familiars, R2G2 possesses flight via rocket jets which activate when over a pit, allowing the companion to operate in a larger variety of spaces."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "R2G2's bullets are affected by all bullet modifiers."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "ref",
              "v": "Scouter",
              "kind": "item"
            },
            {
              "t": "text",
              "v": " will show R2G2's health bar."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "If R2G2 takes an extreme amount of damage, he will die and make the Bullet Kin death noise, leaving nothing. The item will still be in the player's inventory, and he will only come back if the item is dropped and picked up again."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "If multiple copies of the item are obtained, more R2G2's are summoned."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "R2G2 won't attack "
            },
            {
              "t": "ref",
              "v": "Bullet Kin",
              "kind": "lore"
            }
          ]
        }
      ],
      "trivia": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "This item is a reference to "
            },
            {
              "t": "ext",
              "v": "R2-D2",
              "url": "https://en.wikipedia.org/wiki/R2-D2"
            },
            {
              "t": "text",
              "v": " from "
            },
            {
              "t": "ext",
              "v": "Star Wars",
              "url": "https://en.wikipedia.org/wiki/Star_Wars"
            },
            {
              "t": "text",
              "v": ".\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "It's possible this reference was chosen since said character somewhat resembles a bullet."
                }
              ]
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The item's description is a reference to a scene from Return of the Jedi, where R2-D2 is forced to serve drinks aboard Jabba the Hutt's sail barge."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Like most companions, R2G2 can appear to be hurt by certain hazards such as explosions or electrocuted water. When this happens the companion may play the hurt sound that a Bullet Kin makes."
            }
          ]
        }
      ]
    }
  },
  {
    "name": "Baby Good Shelleton",
    "icon": "https://static.wikia.nocookie.net/enterthegungeon_gamepedia/images/9/94/Baby_Good_Shelleton.png",
