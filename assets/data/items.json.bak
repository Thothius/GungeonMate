                  "kind": "lore"
                },
                {
                  "t": "text",
                  "v": ", as the chests will be inaccessible if spawned in the starting room."
                }
              ]
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "ref",
              "v": "Chests",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": " will remain glitched on the next floor."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "If the player teleports a chest in "
            },
            {
              "t": "ref",
              "v": "Bullet Hell",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": ", it will not reappear."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "If an unlocked chest is teleported it will remain unlocked in the next floor."
            }
          ]
        }
      ],
      "trivia": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "The  "
            },
            {
              "t": "synref",
              "v": "Telefrag"
            },
            {
              "t": "text",
              "v": " synergy is a reference to a common trope in media with teleporters, where teleporting into a space occupied by another living being kills them."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The \"leveling up\" of chests might be a reference to the Sealed Chests in Chrono Trigger, which had a similar mechanic."
            }
          ]
        }
      ]
    }
  },
  {
    "name": "Relodestone",
    "icon": "https://static.wikia.nocookie.net/enterthegungeon_gamepedia/images/4/4d/Relodestone.png",
    "type": "Active",
    "quote": "Magunetic North",
    "quality": "1S",
    "effect": "Halves reload times. While active, the player absorbs enemy bullets and regains ammo.",
    "curse": 0.0,
    "coolness": 0.0,
    "wiki": {
      "effects": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "While active, attracts nearby bullets and converts them to ammo."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Halves reload times when held."
            }
          ]
        }
      ],
      "notes": [
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "synref",
              "v": "Relodestar"
            },
            {
              "t": "text",
              "v": " - If the player has any "
            },
            {
              "t": "ref",
              "v": "Ammolets",
              "kind": "unresolved"
            },
            {
              "t": "text",
              "v": ", after Relodestone's effect ends, the bullets that were absorbed are shot out of the player dealing damage to enemies."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Relodestone prevents damage from bullets while it's active, but does not prevent other damage such as falling, burning, poison and contact damage."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Relodestone can refill the "
            },
            {
              "t": "ref",
              "v": "Makeshift Cannon",
              "kind": "gun"
            },
            {
              "t": "text",
              "v": " right after firing it, making it possible to fire multiple Makeshift Cannon shots in rapid succession."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Relodestone does not stay active if the player uses it then switches to a different active item."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Relodestone does not convert the "
            },
            {
              "t": "ref",
              "v": "Treadnaught",
              "kind": "unresolved"
            },
            {
              "t": "text",
              "v": "'s explosive bullet into ammo."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Does not prevent damage from the "
            },
            {
              "t": "ref",
              "v": "Beholster",
              "kind": "shrine"
            },
            {
              "t": "text",
              "v": "'s laser attack."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The buffed "
            },
            {
              "t": "ref",
              "v": "Reload Speed",
              "kind": "unresolved"
            },
            {
              "t": "text",
              "v": " interacts with the "
            },
            {
              "t": "ref",
              "v": "Cog of Battle",
              "kind": "item"
            },
            {
              "t": "text",
              "v": " 33% pseudo-buff to the same stat via active reload. This in turn greatly impacts the difficulty of a successful trigger."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "If somehow another Relodestone is obtained, it has no effect."
            }
          ]
        }
      ],
      "trivia": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "Relodestone is the only -rank item unlocked when starting a new game."
            }
          ]
        }
      ]
    }
  },
