              "v": "cannot",
              "style": "i"
            },
            {
              "t": "text",
              "v": " be used to purchase items from "
            },
            {
              "t": "ref",
              "v": "Flynt",
              "kind": "unresolved"
            },
            {
              "t": "text",
              "v": "."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "This item is a reference to "
            },
            {
              "t": "ext",
              "v": "Skeleton Keys",
              "url": "https://en.wikipedia.org/wiki/Skeleton_key"
            },
            {
              "t": "text",
              "v": ", special master keys that have been stripped down to their essential parts in order to open a wide variety of different locks. Its name and appearance are based on the "
            },
            {
              "t": "ref",
              "v": "Shelleton",
              "kind": "unresolved"
            },
            {
              "t": "text",
              "v": " enemy."
