  {
    "name": "Ruby Bracelet",
    "icon": "https://static.wikia.nocookie.net/enterthegungeon_gamepedia/images/f/f4/Ruby_Bracelet.png",
    "type": "Passive",
    "quote": "Thrown Guns Explode",
    "quality": "D",
    "effect": "Thrown guns will explode.",
    "curse": 0.0,
    "coolness": 0.0,
    "wiki": {
      "effects": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "Thrown guns will explode, dealing 30 damage to all nearby enemies.\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "Guns can be thrown by holding the fire button with an empty gun equipped."
                }
              ]
            },
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "Guns that explode will not be lost.\n"
                }
              ],
              "sub": [
                {
                  "tokens": [
                    {
                      "t": "text",
                      "v": "Remember to retrieve thrown weapons before leaving. Otherwise, they will be stolen by the "
                    },
                    {
                      "t": "ref",
                      "v": "Resourceful Rat",
                      "kind": "lore"
                    },
                    {
                      "t": "text",
                      "v": "."
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Grants the ability to charge a roll by moving constantly without rolling or taking damage for 4 seconds, indicated by a pink aura. Charged rolls deal 300 damage."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Grants immunity to contact damage."
            }
          ]
        }
      ],
      "notes": [
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "synref",
              "v": "Alternative Rock"
            },
            {
              "t": "text",
              "v": " - If the player has "
            },
            {
              "t": "ref",
              "v": "Face Melter",
              "kind": "gun"
            },
            {
              "t": "text",
              "v": ", instead of firing four streams, Face Melter fires two parallel columns of notes. Reloading fires a guitar pick with a chance to stun."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "synref",
              "v": "Backdraft"
            },
            {
              "t": "text",
              "v": " - If the player has "
            },
            {
              "t": "ref",
              "v": "Armor of Thorns",
              "kind": "item"
            },
            {
              "t": "text",
              "v": ", touching enemies sets them on fire."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "synref",
              "v": "Ruby Carbine"
            },
            {
              "t": "text",
              "v": " - If the player has "
            },
            {
              "t": "ref",
              "v": "Hegemony Carbine",
              "kind": "gun"
            },
            {
              "t": "text",
              "v": ", its shots bounce and light enemies on fire."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "synref",
              "v": "Saved the Best for Last"
            },
            {
              "t": "text",
              "v": " - If the player has "
            },
            {
              "t": "ref",
              "v": "Hip Holster",
              "kind": "item"
            },
            {
              "t": "text",
              "v": ", shots fired by Hip Holster explode."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The explosion effect does not apply to the gun that "
            },
            {
              "t": "ref",
              "v": "Slinger",
              "kind": "gun"
            },
            {
              "t": "text",
              "v": " throws upon reloading."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "When playing as "
            },
            {
              "t": "ref",
              "v": "The Paradox",
              "kind": "character"
            },
            {
              "t": "text",
              "v": ", the player can get the upgraded version of the Ruby Bracelet as a starting item."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Thrown guns will be lost if thrown into a pit."
            }
          ]
        }
      ]
    }
  },
  {
    "name": "Sixth Chamber",
    "icon": "https://static.wikia.nocookie.net/enterthegungeon_gamepedia/images/9/94/Sixth_Chamber.png",
    "type": "Passive",
    "quote": "Blessing Of Kaliber",
    "quality": "A",
    "effect": "Increases Coolness by 2 for each point of Curse the player has. Increases curse by 2 while held. Removes the usual curse penalty towards getting a room clearing reward.",
    "curse": 2.0,
    "coolness": 2.0,
    "wiki": {
      "effects": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "Reduces the cooldown of active items by 5% per point of "
            },
            {
              "t": "ref",
              "v": "Curse",
              "kind": "stat"
            },
            {
              "t": "text",
              "v": " up to a maximum of 50%.\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "This cooldown reduction stacks with the effects of "
                },
                {
                  "t": "ref",
                  "v": "Coolness",
                  "kind": "stat"
                },
                {
                  "t": "text",
                  "v": ", but is still capped to a 50% reduction even when combined."
                }
              ]
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Inverts the negative effect of Curse upon room drops, causing each point of Curse to make room drops more common.\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "This effect stacks with the room drop chance increase of Coolness, but is twice as powerful (i.e, while Sixth Chamber is held, each point of Curse has the equivalent effect of two points of Coolness on room drop rates)."
                }
              ]
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Increases  "
            },
            {
              "t": "ref",
              "v": "Curse",
              "kind": "stat"
            },
            {
              "t": "text",
              "v": " by 2."
            }
          ]
        }
      ],
      "notes": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "This item can be purchased from "
            },
            {
              "t": "ref",
              "v": "Cursula",
              "kind": "unresolved"
            },
            {
              "t": "text",
              "v": ", and doing so is more beneficial than any other means of obtaining the item. Because Cursula gives 2.5 Curse every time an item is purchased, buying the Sixth Chamber from her results in it gaining a substantial boost in initial power."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "It is sufficient to kill just one jammed "
            },
            {
              "t": "ref",
              "v": "Trigger Twins",
              "kind": "unresolved"
            },
            {
              "t": "text",
              "v": " in order to unlock the item. Killing minibosses, such as "
            },
            {
              "t": "ref",
              "v": "Fuselier",
              "kind": "unresolved"
            },
            {
              "t": "text",
              "v": ", while they're jammed, will also unlock the item."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Outside of room clear rewards, this item does not negate the other effects of curse. Jammed enemies will spawn at the rate of your current curse, mimic chances will be increased, and so forth."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "With the Sixth Chamber equipped, the exact formula for room drops is (1+[coolness]+ 2x["
            },
            {
              "t": "ref",
              "v": "Curse",
              "kind": "stat"
            },
            {
              "t": "text",
              "v": "])%."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Despite having similar effects to the "
            },
            {
              "t": "ref",
              "v": "Coolness",
              "kind": "stat"
            },
            {
              "t": "text",
              "v": " stat, the Sixth Chamber has no effect on "
            },
            {
              "t": "ref",
              "v": "Chests",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": " fuse chances or the "
            },
            {
              "t": "ref",
              "v": "Vorpal Gun",
              "kind": "gun"
            },
            {
              "t": "text",
              "v": " crit chance."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "It is a common misconception that the Sixth Chamber modifies the players Coolness, but this is not the case, as it interacts with the item cooldown and loot drop systems directly."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The appearance of the item is a reference to the number "
            },
            {
              "t": "ext",
              "v": "666",
              "url": "https://en.wikipedia.org/wiki/Number_of_the_beast"
            },
            {
              "t": "text",
              "v": ", identified as \"the number of the beast\" in the Book of Revelations of the Christian Bible and widely associated with evil and the devil."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The item is also a reference to the sixth chamber within the game, "
            },
            {
              "t": "ref",
              "v": "Bullet Hell",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": "."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Defeating the Paradox "
            },
            {
              "t": "ref",
              "v": "Lich",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": " from the "
            },
            {
              "t": "ref",
              "v": "The Gunslinger",
              "kind": "character"
            },
            {
              "t": "text",
              "v": "'s past counts as a Jammed boss for the purpose of unlocking this item."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Defeating the "
            },
            {
              "t": "ref",
              "v": "High Dragun",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": " while it is jammed will only unlock this item so long as the "
            },
            {
              "t": "ref",
              "v": "Advanced Dragun",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": " fight is not triggered."
            }
          ]
        }
      ]
    }
  },
  {
    "name": "Busted Television",
    "icon": "https://static.wikia.nocookie.net/enterthegungeon_gamepedia/images/5/50/Busted_Television.png",
    "type": "Active",
    "quote": "Broken And Heavy",
    "quality": "N",
    "effect": "Upon use, the television is thrown in the direction of the cursor. Dropped upon dodge rolling.",
    "curse": 0.0,
    "coolness": 0.0,
    "wiki": {
      "effects": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "Upon use, the television is thrown in the direction of the cursor. This does not deal damage to enemies."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Dropped upon dodge rolling."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Giving the item to the "
            },
            {
              "t": "ref",
              "v": "Blacksmith",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": " in the "
            },
            {
              "t": "ref",
              "v": "Forge",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": " unlocks "
            },
            {
              "t": "ref",
              "v": "The Robot",
              "kind": "character"
            },
            {
              "t": "text",
              "v": "."
            }
          ]
        }
      ],
      "notes": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "The television can be stolen from any room by the "
            },
            {
              "t": "ref",
              "v": "Resourceful Rat",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": ", but only after the player enters the elevator maintenance shaft room for the first time in the run. Do not enter this room until you are ready to pick up the television! If you exit the room without picking up the television, the rat may steal it while you are elsewhere."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "If the player scares away the "
            },
            {
              "t": "ref",
              "v": "Resourceful Rat",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": " from stealing the Busted Television, he does "
            },
            {
              "t": "text",
              "v": "not",
              "style": "i"
            },
            {
              "t": "text",
              "v": " become \"scared away\" from the room. As long as it is on the ground, he will repeatedly return to the room when the player leaves and attempt to steal it, ad infinitum."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "It can be collected at any point during the "
            },
            {
              "t": "ref",
              "v": "Gungeon Proper",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": ". Wait to pick up the television until the elevator to the "
            },
            {
              "t": "ref",
              "v": "Black Powder Mine",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": " is unlocked to reduce the time spent babysitting it."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The television has a small amount of unseen health. When dropped on the ground, it is vulnerable to enemy bullets, though there is no visual indicator when it takes damage. If it loses all its health, it will disappear and will no longer be obtainable in the current run."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "If thrown into a pit, it will disappear and will no longer be obtainable in the current run."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "If thrown during a fight with the "
            },
            {
              "t": "ref",
              "v": "Wallmonger",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": ", it can be hidden behind the wall and no longer be able to be picked back up."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "It is possible for the Busted Television to float inside of the neon barricades inside the elevator shaft. Once it's there, you cannot get it back."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "It is also possible for the Busted Television to clip through room walls if dropped against them, preventing the player from picking it back up."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Finding an item that grants flight will help in getting this item to the Blacksmith."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "It is possible to pick this item up after unlocking The Robot, even "
            },
            {
              "t": "text",
              "v": "as",
              "style": "i"
            },
            {
              "t": "text",
              "v": " The Robot."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "ref",
              "v": "Escape Rope",
              "kind": "item"
            },
            {
              "t": "text",
              "v": " makes it easy to bring to the Blacksmith, as every room in the Forge can be skipped."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The cutscene that occurs when the Blacksmith is given the Busted Television must finish for the Robot to be unlocked. Be careful if you are being chased by the "
            },
            {
              "t": "ref",
              "v": "Lord of the Jammed",
              "kind": "unresolved"
            },
            {
              "t": "text",
              "v": ", as he can kill you during the cutscene."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "It cannot be sold to the Sell Creep."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "If the player has "
            },
            {
              "t": "ref",
              "v": "Blank Companion's Ring",
              "kind": "item"
            },
            {
              "t": "text",
              "v": ", throwing the Television will cause the blank companion to use a blank, with its usual cooldown."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Should you lose the Television and later respawn at the beginning of the run with the "
            },
            {
              "t": "ref",
              "v": "Clone",
              "kind": "item"
            },
            {
              "t": "text",
              "v": ", the television will have returned to the elevator shaft on floor two."
            }
          ]
        }
      ]
    }
  },
