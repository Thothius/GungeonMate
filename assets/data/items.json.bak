              "v": " is a reference to the idiom, "
            },
            {
              "t": "ext",
              "v": "Cleanliness is next to Godliness",
              "url": "http://idioms.thefreedictionary.com/Cleanliness+is+next+to+Godliness"
            },
            {
              "t": "text",
              "v": "."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The  "
            },
            {
              "t": "synref",
              "v": "Spengbab"
            },
            {
              "t": "text",
              "v": " synergy is a reference to "
