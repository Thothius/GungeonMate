  {
    "name": "Prime Primer",
    "icon": "https://static.wikia.nocookie.net/enterthegungeon_gamepedia/images/f/f8/Prime_Primer.png/revision/latest?cb=20160310052713",
    "type": "Passive",
    "quote": "Old Magic",
    "quality": "N",
    "effect": "Ingredient for the Bullet That Can Kill The Past .",
    "curse": 0.0,
    "coolness": 0.0,
    "wiki": {
      "effects": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "One of four components of the  "
            },
            {
              "t": "ref",
              "v": "Bullet That Can Kill The Past",
              "kind": "unresolved"
            },
            {
              "t": "text",
              "v": "."
            }
          ]
        }
      ],
      "notes": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "This item is useless on "
            },
            {
              "t": "ref",
              "v": "The Cultist",
              "kind": "character"
            },
            {
              "t": "text",
              "v": " as it cannot be dropped and the Blacksmith will refuse to talk with the second player."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "As it is in a glass display case, it can't be stolen with the "
            },
            {
              "t": "ref",
              "v": "Grappling Hook",
              "kind": "item"
            },
            {
              "t": "text",
              "v": " or the "
            },
            {
              "t": "ref",
              "v": "Directional Pad",
              "kind": "gun"
            },
            {
              "t": "text",
              "v": " grappling hook ability."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Surviving "
            },
            {
              "t": "ref",
              "v": "Shop",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": "'s onslaught of bullets in an attempt to steal it will close the shop and the Primer will disappear."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "As it is a passive item that can be bought from a shop, it can be replaced by "
            },
            {
              "t": "ref",
              "v": "Spice",
              "kind": "item"
            },
            {
              "t": "text",
              "v": " if Spice has been used enough."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Items which grant "
            },
            {
              "t": "ref",
              "v": "Shop",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": " do not reduce the price of this item."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "After giving the Prime Primer to the "
            },
            {
              "t": "ref",
              "v": "Blacksmith",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": ", it will appear on the "
            },
            {
              "t": "ref",
              "v": "Hero of Time Statue",
              "kind": "unresolved"
            },
            {
              "t": "text",
              "v": " in the "
            },
            {
              "t": "ref",
              "v": "Breach",
              "kind": "unresolved"
            },
            {
              "t": "text",
              "v": " as a shield.\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "The Unity object of the Prime Primer shield is called "
                },
                {
                  "t": "text",
                  "v": "Primer Targe",
                  "style": "i"
                },
                {
                  "t": "text",
                  "v": ". A "
                },
                {
                  "t": "ext",
                  "v": "Targe",
                  "url": "https://en.wikipedia.org/wiki/Targe"
                },
                {
                  "t": "text",
                  "v": " is a type of round shield of Scottish origin."
                }
              ]
            }
          ]
        }
      ]
    }
  },
