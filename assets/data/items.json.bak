              "tokens": [
                {
                  "t": "text",
                  "v": " "
                },
                {
                  "t": "ref",
                  "v": "Elder Blank",
                  "kind": "item"
                },
                {
                  "t": "text",
                  "v": " - Triggers the effect of a blank when used."
