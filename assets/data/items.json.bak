              "v": "\\o/"
            },
            {
              "t": "text",
              "v": " and  "
            },
            {
              "t": "synref",
              "v": "Praise the Gun"
            },
            {
              "t": "text",
              "v": " synergies are references to Solaire of Astora from "
            },
            {
              "t": "text",
              "v": "Dark Souls",
              "style": "i"
            },
            {
              "t": "text",
              "v": " and his well-known catchphrase, \"Praise the Sun!\""
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "This item's synergy with "
            },
            {
              "t": "ref",
              "v": "Crestfaller",
              "kind": "gun"
            },
            {
              "t": "text",
              "v": " is a reference to the NPC Crestfallen Warrior in "
            },
            {
              "t": "text",
              "v": "Dark Souls",
              "style": "i"
            },
            {
              "t": "text",
              "v": "."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Based on the fact that "
            },
            {
              "t": "ref",
              "v": "Old Knight's Helm",
              "kind": "item"
            },
            {
              "t": "text",
              "v": " and "
            },
            {
              "t": "ref",
              "v": "Old Knight's Shield",
              "kind": "item"
            },
            {
              "t": "text",
              "v": " belonged to "
            },
            {
              "t": "ref",
              "v": "Ser Manuel",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": ", this likely also belonged to him."
            }
          ]
        }
      ]
    }
  },
  {
    "name": "Old Crest",
    "icon": "https://static.wikia.nocookie.net/enterthegungeon_gamepedia/images/a/a1/Old_Crest.png",
    "type": "Passive",
    "quote": "Armor Up",
    "quality": "N",
    "effect": "Grants a piece of armor. Consumed upon taking any damage.",
    "curse": 0.0,
    "coolness": 0.0,
    "wiki": {
      "effects": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "Grants a piece of armor.\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "This piece of armor will always appear at the end of the health bar, and is destroyed upon taking damage.\n"
                }
              ],
              "sub": [
                {
                  "tokens": [
                    {
                      "t": "text",
                      "v": "Picking up regular armor before or after the Old Crest will move the Old Crest forward, making it impossible to protect it with armor."
                    }
                  ]
                },
                {
                  "tokens": [
                    {
                      "t": "text",
                      "v": "The Old Crest can be protected by "
                    },
                    {
                      "t": "ref",
                      "v": "Full Metal Jacket",
                      "kind": "item"
                    },
                    {
                      "t": "text",
                      "v": "."
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Can be placed on an altar in the "
            },
            {
              "t": "ref",
              "v": "Gungeon Proper",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": ", which will reveal stairs leading to the "
            },
            {
              "t": "ref",
              "v": "Abbey of the True Gun",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": ".\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "The player will receive one regular piece of armor as replacement."
                }
              ]
            }
          ]
        }
      ],
      "notes": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "Cannot be dropped."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Self-damage from "
            },
            {
              "t": "ref",
              "v": "Cigarettes",
              "kind": "item"
            },
            {
              "t": "text",
              "v": " will destroy Old Crest."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Cannot be stolen by the "
            },
            {
              "t": "ref",
              "v": "Resourceful Rat",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": " because it is on a pedestal."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "On the Google Stadia version of the game, it is possible for multiple Old Crests to generate."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Picking the Old Crest up on the "
            },
            {
              "t": "ref",
              "v": "The Bullet",
              "kind": "character"
            },
            {
              "t": "text",
              "v": " gives a slight attack power buff."
            }
          ]
        }
      ]
    }
  },
  {
    "name": "Armor of Thorns",
    "icon": "https://static.wikia.nocookie.net/enterthegungeon_gamepedia/images/1/1c/Armor_of_Thorns.png",
    "type": "Passive",
    "quote": "Your Body Is A Weapon",
    "quality": "C",
    "effect": "Provides immunity to contact damage, and increases damage dealt by dodge rolling into enemies. Grants armor upon pickup.",
    "curse": 0.0,
    "coolness": 0.0,
    "wiki": {
      "effects": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "Increases damage dealt by "
            },
            {
              "t": "ref",
              "v": "Dodge Roll (Move)",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": " into enemies by 600% (7x multiplier).\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "For most characters this increases damage dealt per roll from 3 to 21."
                }
              ]
            },
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "As "
                },
                {
                  "t": "ref",
                  "v": "The Robot",
                  "kind": "character"
                },
                {
                  "t": "text",
                  "v": " stats with innately higher dodge roll damage, Armor of Thorns instead increases damage dealt per roll from 4 to 28."
                }
              ]
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Grants one piece of  "
            },
            {
              "t": "ref",
              "v": "Armor",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": " upon pickup."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Grants contact damage immunity.\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "This does "
                },
                {
                  "t": "text",
                  "v": "not",
                  "style": "i"
                },
                {
                  "t": "text",
                  "v": " prevent  "
                },
                {
                  "t": "ref",
                  "v": "Muzzle Wisp",
                  "kind": "unresolved"
                },
                {
                  "t": "text",
                  "v": " and  "
                },
                {
                  "t": "ref",
                  "v": "Muzzle Flare",
                  "kind": "unresolved"
                },
                {
                  "t": "text",
                  "v": " from setting the player on fire on contact."
                }
              ]
            }
          ]
        }
      ],
      "item_interactions": [
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "ref",
              "v": "Live Ammo",
              "kind": "item"
            },
            {
              "t": "text",
              "v": " - Roll damage increases stack together multiplicatively, increasing damage per roll to 105 (140 as "
            },
            {
              "t": "ref",
              "v": "The Robot",
              "kind": "character"
            },
            {
              "t": "text",
              "v": ")."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "ref",
              "v": "Blast Helmet",
              "kind": "item"
            },
            {
              "t": "text",
              "v": " - Roll damage increases stack together multiplicatively, increasing damage per roll to 63 (84 as "
            },
            {
              "t": "ref",
              "v": "The Robot",
              "kind": "character"
            },
            {
              "t": "text",
              "v": ")."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "ref",
              "v": "Live Ammo",
              "kind": "item"
            },
            {
              "t": "text",
              "v": " +  "
            },
            {
              "t": "ref",
              "v": "Blast Helmet",
              "kind": "item"
            },
            {
              "t": "text",
              "v": " - All three items stack together multiplicatively, increasing damage per roll to 315 (420 as "
            },
            {
              "t": "ref",
              "v": "The Robot",
              "kind": "character"
            },
            {
              "t": "text",
              "v": ") if all are held.\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "This is 105x base dodge roll damage, and surpasses the damage boost given by  "
                },
                {
                  "t": "ref",
                  "v": "Ruby Bracelet",
                  "kind": "item"
                },
                {
                  "t": "text",
                  "v": " in its upgraded form."
                }
              ]
            }
          ]
        }
      ],
      "notes": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "Even with this item, "
            },
            {
              "t": "ref",
              "v": "Gatling Gull",
              "kind": "unresolved"
            },
            {
              "t": "text",
              "v": " melee swipe and "
            },
            {
              "t": "ref",
              "v": "Wallmonger",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": " body still deal contact damage."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Prior to the "
            },
            {
              "t": "ref",
              "v": "Advanced Gungeons & Draguns Update",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": ", Armor of Thorns multiplied dodge roll damage by 16."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Prior to the "
            },
            {
              "t": "ref",
              "v": "Advanced Gungeons & Draguns Update",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": ", this item did not prevent contact damage, making it difficult to use without getting hurt."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "This item references Knight of Thorns Kirk's armor set from \""
            },
            {
              "t": "text",
              "v": "Dark Souls\"",
              "style": "i"
            },
            {
              "t": "text",
              "v": " franchise, which also allows players to damage enemies by rolling."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "\"Your Body Is a Weapon\" is likely a reference to the song of the same name by The Wombats."
            }
          ]
        }
      ]
    }
  },
  {
    "name": "Full Metal Jacket",
    "icon": "https://static.wikia.nocookie.net/enterthegungeon_gamepedia/images/d/de/Full_Metal_Jacket.png",
    "type": "Passive",
    "quote": "Automated Defenses",
    "quality": "B",
    "effect": "Automatically activates one of the player's blanks when they are about to take damage.",
    "curse": 0.0,
    "coolness": 0.0,
    "wiki": {
      "effects": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "Automatically uses one of the player's  "
            },
            {
              "t": "ref",
              "v": "Blank",
              "kind": "shrine"
            },
            {
              "t": "text",
              "v": " if they are about to take damage, preventing it.\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "This can negate contact damage, which regular blanks do not normally prevent."
                }
              ]
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Grants one piece of  "
            },
            {
              "t": "ref",
              "v": "Armor",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": " when picked up for the first time."
            }
          ]
        }
      ],
      "item_interactions": [
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "ref",
              "v": "Elder Blank",
              "kind": "item"
            },
            {
              "t": "text",
              "v": " - If Elder Blank is charged, taking damage will automatically trigger the Elder Blank, and prevent that damage.\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "Fall damage does not trigger Full Metal Jacket unless the player has "
                },
                {
                  "t": "ref",
                  "v": "Elder Blank",
                  "kind": "item"
                },
                {
                  "t": "text",
                  "v": "."
                }
              ]
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "ref",
              "v": "Polaris",
              "kind": "gun"
            },
            {
              "t": "text",
              "v": ",  "
            },
            {
              "t": "ref",
              "v": "Metronome",
              "kind": "item"
            },
            {
              "t": "text",
              "v": ",  "
            },
            {
              "t": "ref",
              "v": "Meatbun",
              "kind": "item"
            },
            {
              "t": "text",
              "v": " - Since damage prevented by Full Metal Jacket does not count as taking damage, it is very valuable for protecting the bonuses of these items."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "ref",
              "v": "Old Crest",
              "kind": "item"
            },
            {
              "t": "text",
              "v": ",  "
            },
            {
              "t": "ref",
              "v": "Glass Guon Stone",
              "kind": "item"
            },
            {
              "t": "text",
              "v": ",  "
            },
            {
              "t": "ref",
              "v": "Glass Cannon",
              "kind": "gun"
            },
            {
              "t": "text",
              "v": ",  "
            },
            {
              "t": "ref",
              "v": "Balloon Gun",
              "kind": "gun"
            },
            {
              "t": "text",
              "v": " - Damage prevented by Full Metal Jacket will not cause these items to break."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "ref",
              "v": "Crisis Stone",
              "kind": "item"
            },
            {
              "t": "text",
              "v": " - Full Metal Jacket will still trigger a blank when bullets collide with the player "
            },
            {
              "t": "text",
              "v": "even",
              "style": "i"
            },
            {
              "t": "text",
              "v": " while crisis stone is active."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "ref",
              "v": "Cigarettes",
              "kind": "item"
            },
            {
              "t": "text",
              "v": " - Full Metal Jacket can prevent damage caused by Cigarettes, which is normally impossible to prevent."
            }
          ]
        }
      ],
      "notes": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "Full Metal Jacket is extremely valuable for collecting "
            },
            {
              "t": "ref",
              "v": "Master Round I",
              "kind": "item"
            },
            {
              "t": "text",
              "v": "."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "When damaged by harmful "
            },
            {
              "t": "ref",
              "v": "Status Effects",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": ", Full Metal Jacket will still use a blank, despite the damage not being caused by bullets."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "This item is a reference to "
            },
            {
              "t": "ext",
              "v": "full metal jacket ammunition",
              "url": "https://en.wikipedia.org/wiki/Full_metal_jacket_(ammunition)"
            },
            {
              "t": "text",
              "v": ", where the lead slug is encased in a 'jacket' comprised of a harder alloy to improve the rounds piercing capability."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The  "
            },
            {
              "t": "synref",
              "v": "To Serve Android"
            },
            {
              "t": "text",
              "v": " synergy is a reference to the real full metal jackets used by police, as well as "
            },
            {
              "t": "ext",
              "v": "Robocop",
              "url": "https://en.wikipedia.org/wiki/Robocop"
            },
            {
              "t": "text",
              "v": ".\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "It is also a reference to the short story \"To Serve Man\" by Damon Knight which was adapted for use as a Twilight Zone episode."
                }
              ]
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": " Bug If the player has at least one "
            },
            {
              "t": "ref",
              "v": "Pickups",
              "kind": "unresolved"
            },
            {
              "t": "text",
              "v": " and has the map open, they become immune to all types of damage except for fall damage. If the player falls into a pit while the map is open, the damage immunity will be removed until they close and reopen the map, even if "
            },
            {
              "t": "ref",
              "v": "Amulet of the Pit Lord",
              "kind": "item"
            },
            {
              "t": "text",
              "v": " is in the player's inventory.\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "If the player has the map open and has the "
                },
                {
                  "t": "ref",
                  "v": "Elder Blank",
                  "kind": "item"
                },
                {
                  "t": "text",
                  "v": ", it will still activate, starting the cooldown. This means that the bug can not be exploited with the Elder Blank alone."
                }
              ]
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "A depiction of Full Metal Jacket can be seen in the opening scroll of the "
            },
            {
              "t": "ext",
              "v": "Supply Drop Trailer",
              "url": "https://www.youtube.com/watch?v=x3YN0qhy8R8"
            },
            {
              "t": "text",
              "v": "."
            }
          ]
        }
      ]
    }
  },
  {
    "name": "Ticket",
    "icon": "https://static.wikia.nocookie.net/enterthegungeon_gamepedia/images/1/1e/Ticket.png",
    "type": "Active",
    "quote": "Do You Have Yours?",
    "quality": "A",
    "effect": "Summons Gatling Gull as a temporary ally for the current room. Recharges after he leave or die.",
    "curse": 0.0,
    "coolness": 0.0,
    "wiki": {
      "effects": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "Upon use, spawns a friendly "
            },
            {
              "t": "ref",
              "v": "Gatling Gull",
              "kind": "unresolved"
            },
            {
              "t": "text",
              "v": " that periodically fires spreads of bullets and flies off once the room is cleared. He will also block damage dealt to him, so he can be used as a shield.\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "He will die if he sustains enough damage."
                }
              ]
            }
          ]
        }
      ],
      "notes": [
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "synref",
              "v": "Secret Twin"
            },
            {
              "t": "text",
              "v": " - If the player also has "
            },
            {
              "t": "ref",
              "v": "Vulcan Cannon",
              "kind": "gun"
            },
            {
              "t": "text",
              "v": ", holding Vulcan Cannon while using Ticket will spawn two friendly Gatling Gulls instead of one."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Gatling Gull gains the effects of most bullet modifiers."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "If the Ticket is used a second time in the same room the first "
            },
            {
              "t": "ref",
              "v": "Gatling Gull",
              "kind": "unresolved"
            },
            {
              "t": "text",
              "v": " (or first two with  "
            },
            {
              "t": "synref",
              "v": "Secret Twin"
            },
            {
              "t": "text",
              "v": "), if still alive, will disappear."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The Ticket can be used to cheese the final phase of the High Dragun fight, as it blocks bullets, letting you stand behind it. Keep in mind he can only sustain 3-4 waves before he will die to the damage."
            }
          ]
        }
      ],
      "trivia": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "In previous versions of the game, there were files for an item that spawned "
            },
            {
              "t": "ref",
              "v": "Gatling Gull",
              "kind": "unresolved"
            },
            {
              "t": "text",
              "v": " as an ally, but couldn't shoot."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The item is likely a reference to the saying \"Ticket to the gun show\", in which someone shows off their muscles, just like "
            },
            {
              "t": "ref",
              "v": "Gatling Gull",
              "kind": "unresolved"
            },
            {
              "t": "text",
              "v": " does."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "This item is most likely a reference to "
            },
            {
              "t": "ext",
              "v": "The Last Action Hero",
              "url": "https://en.wikipedia.org/wiki/Last_Action_Hero"
            },
            {
              "t": "text",
              "v": " where a young boy uses a golden ticket to transport into a movie where he meets his favorite action hero."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Prior to "
            },
            {
              "t": "ref",
              "v": "V2.1.3",
              "kind": "unresolved"
            },
            {
              "t": "text",
              "v": ", "
            },
            {
              "t": "ref",
              "v": "Baby Good Mimic",
              "kind": "item"
            },
            {
              "t": "text",
              "v": " could turn into Gatling Gull.\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "If you have the  "
                },
                {
                  "t": "synref",
                  "v": "Secret Twin"
                },
                {
                  "t": "text",
                  "v": " synergy, the "
                },
                {
                  "t": "ref",
                  "v": "Baby Good Mimic",
                  "kind": "item"
                },
                {
                  "t": "text",
                  "v": " will still turn into Gatling Gull."
                }
              ]
            }
          ]
        }
      ]
    }
  },
  {
    "name": "Heavy Boots",
    "icon": "https://static.wikia.nocookie.net/enterthegungeon_gamepedia/images/5/51/Heavy_Boots.png",
    "type": "Passive",
    "quote": "Low Center Of Mass",
    "quality": "D",
    "effect": "Prevents the player from being affected by enemy knockback, gun recoil, and conveyor belts.",
    "curse": 0.0,
    "coolness": 0.0,
    "wiki": {
      "effects": [
        {
          "tokens": [
            {
              "t": "text",
              "v": " Prevents the players movement from being interfered with by external forces, such as knockback from enemies, gun recoil, conveyor belts, and patches of ice. The player will still be moved around by moving platforms."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": " Causes the player to release a shockwave upon landing. Enemies caught in the shockwave will be knocked back and take light damage.\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "Has a short cooldown before the effect can be activated again."
                }
              ]
            }
          ]
        }
      ],
      "item_interactions": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "  "
            },
            {
              "t": "ref",
              "v": "Alien Engine",
              "kind": "gun"
            },
            {
              "t": "text",
              "v": ",  "
            },
            {
              "t": "ref",
              "v": "Blasphemy",
              "kind": "gun"
            },
            {
              "t": "text",
              "v": ",  "
            },
            {
              "t": "ref",
              "v": "Casey",
              "kind": "gun"
            },
            {
              "t": "text",
              "v": ",  "
            },
            {
              "t": "ref",
              "v": "Crusader's Blade",
              "kind": "unresolved"
            },
            {
              "t": "text",
              "v": " - Firing these guns will no longer push the player around."
            }
          ]
        }
      ],
      "notes": [
        {
          "tokens": [
            {
              "t": "text",
              "v": " This item can be very useful on elevators with holes. Knocking grounded enemies into pits will instantly kill them, which is easy to do with this item."
            }
          ]
        }
      ]
    }
  },
  {
    "name": "Bug Boots",
    "icon": "https://static.wikia.nocookie.net/enterthegungeon_gamepedia/images/3/32/Bug_Boots.png",
    "type": "Passive",
    "quote": "Yikes!",
    "quality": "B",
    "effect": "Dodge rolling leaves a trail of poison creep. Makes the player immune to poison.",
    "curse": 0.0,
    "coolness": 0.0,
    "wiki": {
      "effects": [
        {
          "tokens": [
            {
              "t": "ref",
              "v": "Dodge Roll (Move)",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": " leaves a trail of poison "
            },
            {
              "t": "ref",
              "v": "Goop",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": "."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Grants immunity to poison."
            }
          ]
        }
      ],
      "item_interactions": [
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "ref",
              "v": "Sponge",
              "kind": "item"
            },
            {
              "t": "text",
              "v": " - Poison left by the Bug Boots is immediately soaked up by the Sponge, completely negating the boots effect."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "ref",
              "v": "Gungine",
              "kind": "gun"
            },
            {
              "t": "text",
              "v": " /  "
            },
            {
              "t": "ref",
              "v": "Plunger",
              "kind": "gun"
            },
            {
              "t": "text",
              "v": " - Since these guns restore ammo when reloading while standing on Goop, Bug Boots can be used to generate infinite ammo for these weapons."
            }
          ]
        }
      ],
      "notes": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "Use of this item allows the player to spread poison over the entrance to "
            },
            {
              "t": "ref",
              "v": "Bullet Hell",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": ", despite there visually being no ground to spread it on."
            }
          ]
        }
      ]
    }
  },
  {
    "name": "Gunboots",
    "icon": "https://static.wikia.nocookie.net/enterthegungeon_gamepedia/images/9/9f/Gunboots.png",
    "type": "Passive",
    "quote": "They Go Down Well",
    "quality": "C",
    "effect": "Dodge rolling fires a spread of five bullets backwards. Slightly increases movement speed.",
    "curse": 0.0,
    "coolness": 0.0,
    "wiki": {
      "effects": [
        {
          "tokens": [
            {
              "t": "ref",
              "v": "Dodge Roll (Move)",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": " fires a spread of five bullets backwards, which deal 8 damage each."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Increases movement speed by 1 (approximately 14%)."
            }
          ]
        }
      ],
      "notes": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "Gunboots has a cooldown of about 2 seconds between bursts of bullets."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Can be used to break targets in Winchester's game."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "synref",
              "v": "Double Down"
            },
            {
              "t": "text",
              "v": " - If the player also has "
            },
            {
              "t": "ref",
              "v": "Springheel Boots",
              "kind": "item"
            },
            {
              "t": "text",
              "v": ", the cooldown is removed and every roll will fire bullets."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "synref",
              "v": "Spelunker"
            },
            {
              "t": "text",
              "v": " - If the player also has "
            },
            {
              "t": "ref",
              "v": "Blast Helmet",
              "kind": "item"
            },
            {
              "t": "text",
              "v": ", dodge rolling will create a small explosion behind the player instead of firing bullets. This explosion erases enemy bullets near it"
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The bullets can reveal secret rooms.\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "The Shopkeeper ignores Gunboots firing in the "
                },
                {
                  "t": "ref",
                  "v": "Shop",
                  "kind": "lore"
                },
                {
                  "t": "text",
                  "v": ", even if a bullet makes contact with him, making it useful for finding secret rooms in the shop."
                }
              ]
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Passive items like "
            },
            {
              "t": "ref",
              "v": "Hot Lead",
              "kind": "item"
            },
            {
              "t": "text",
              "v": ", "
            },
            {
              "t": "ref",
              "v": "Frost Bullets",
              "kind": "item"
            },
            {
              "t": "text",
              "v": ", and "
            },
            {
              "t": "ref",
              "v": "Irradiated Lead",
              "kind": "item"
            },
            {
              "t": "text",
              "v": " affect the bullets.\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "Strangely, the bullets are not affected by "
                },
                {
                  "t": "ref",
                  "v": "Bouncy Bullets",
                  "kind": "item"
                },
                {
                  "t": "text",
                  "v": "."
                }
              ]
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "ref",
              "v": "Remote Bullets",
              "kind": "item"
            },
            {
              "t": "text",
              "v": " will cause these bullets to home in on the cursor."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Killing enemies with the bullets counts as a kill for the equipped weapon for "
            },
            {
              "t": "ref",
              "v": "Metronome",
              "kind": "item"
            },
            {
              "t": "text",
              "v": "."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "This item is affected by "
            },
            {
              "t": "ref",
              "v": "Macho Brace",
              "kind": "item"
            },
            {
              "t": "text",
              "v": "."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "If duplicates of this item are somehow obtained, increases the damage of the Gunboots' bullets and further increases player's movement speed.\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "Interestingly, rather than increasing the damage of the bullets, it shoots another set of bullets stacked upon the first. This is most apparent when using the "
                },
                {
                  "t": "ref",
                  "v": "Scouter",
                  "kind": "item"
                }
              ]
            }
          ]
        }
      ],
      "trivia": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "This item, and possibly its method of unlock (found in the elevator by Tailor) are a reference to "
            },
            {
              "t": "ext",
              "v": "Downwell",
              "url": "https://en.wikipedia.org/wiki/Downwell_(video_game)"
            },
            {
              "t": "text",
              "v": "."
            }
          ]
        }
      ]
    }
  },
  {
    "name": "Springheel Boots",
    "icon": "https://static.wikia.nocookie.net/enterthegungeon_gamepedia/images/8/86/Springheel_Boots.png",
    "type": "Passive",
    "quote": "Double Jump",
    "quality": "D",
    "effect": "Allows the player to roll again mid-roll.",
    "curse": 0.0,
    "coolness": 0.0,
    "wiki": {
      "effects": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "Allows the player to "
            },
            {
              "t": "ref",
              "v": "Dodge Roll (Move)",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": " again mid-roll, interrupting their initial roll and allowing them to quickly change directions."
            }
          ]
        }
      ],
      "item_interactions": [
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "ref",
              "v": "Bloodied Scarf",
              "kind": "item"
            },
            {
              "t": "text",
              "v": " - Overrides Springheel Boots."
            }
          ]
        }
      ],
      "notes": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "This item is a reference to "
            },
            {
              "t": "ext",
              "v": "Spring-heeled Jack",
              "url": "https://en.wikipedia.org/wiki/Spring-heeled_Jack"
            },
            {
              "t": "text",
              "v": ", an English urban legend from the Victorian era.\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "Its "
                },
                {
                  "t": "ref",
                  "v": "Ammonomicon",
                  "kind": "lore"
                },
                {
                  "t": "text",
                  "v": " entry is a reference to the "
                },
                {
                  "t": "ext",
                  "v": "Boots of Springheel Jak",
                  "url": "https://elderscrolls.fandom.com/wiki/Boots_of_Springheel_Jak_(Item)"
                },
                {
                  "t": "text",
                  "v": " from "
                },
                {
                  "t": "text",
                  "v": "The Elder Scrolls IV: Oblivion",
                  "style": "i"
                },
                {
                  "t": "text",
                  "v": ", which are used to survive a long fall as part of "
                },
                {
                  "t": "ext",
                  "v": "The Ultimate Heist",
                  "url": "https://en.uesp.net/wiki/Oblivion:The_Ultimate_Heist"
                },
                {
                  "t": "text",
                  "v": " quest."
                }
              ]
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "This item was originally suggested by a now-deleted account in a "
            },
            {
              "t": "ext",
              "v": "suggestion Reddit thread",
              "url": "https://www.reddit.com/r/EnterTheGungeon/comments/4ktxpw/lets_get_creative_what_are_some_passive_item/item"
            },
            {
              "t": "text",
              "v": ". This suggestion, calling the item \"Pegasus Boots\", was reacted to positively by "
            },
            {
              "t": "ref",
              "v": "Dodge Roll",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": " programmer "
            },
            {
              "t": "ref",
              "v": "Brent Sodman",
              "kind": "unresolved"
            },
            {
              "t": "text",
              "v": "."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "A depiction of the Springheel Boots can be seen in the opening scroll of the "
            },
            {
              "t": "ext",
              "v": "Supply Drop Trailer",
              "url": "https://www.youtube.com/watch?v=x3YN0qhy8R8"
            },
            {
              "t": "text",
              "v": "."
            }
          ]
        }
      ]
    }
  },
  {
    "name": "Rat Boots",
    "icon": "https://static.wikia.nocookie.net/enterthegungeon_gamepedia/images/4/40/Rat_Boots.png",
    "type": "Passive",
    "quote": "Hover Craft",
    "quality": "C",
    "effect": "Grants temporary invulnerability and flight when the player steps over a pit.",
    "curse": 0.0,
    "coolness": 0.0,
    "wiki": {
      "effects": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "Grants temporary invulnerability and flight when the wearer walks out over a pit for about 1 second."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Increases movement speed by 1.5."
            }
          ]
        }
      ],
      "notes": [
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "synref",
              "v": "Resourceful Indeed"
            },
            {
              "t": "text",
              "v": " - If the player also has "
            },
            {
              "t": "ref",
              "v": "Partially-Eaten Cheese",
              "kind": "item"
            },
            {
              "t": "text",
              "v": ", "
            },
            {
              "t": "ref",
              "v": "Elimentaler",
              "kind": "gun"
            },
            {
              "t": "text",
              "v": ", and "
            },
            {
              "t": "ref",
              "v": "Resourceful Sack",
              "kind": "item"
            },
            {
              "t": "text",
              "v": ", the player becomes the Resourceful Rat, preventing items from being stolen when they're left behind in rooms."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Use of "
            },
            {
              "t": "ref",
              "v": "Cigarettes",
              "kind": "item"
            },
            {
              "t": "text",
              "v": " is not possible during the invincibility period."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Can be used to cheat in some of Winchester's games by walking over the gaps and onto solid ground inside the game area."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The effect does not activate if the player has flight."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "If you stand above a pit with Rat Boots after killing "
            },
            {
              "t": "ref",
              "v": "Lich",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": "'s first stage, it's possible to soft-lock the game. To do this, you have to fall and take damage as the hand grabs you."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "If duplicates of this item are somehow obtained, further increases player's movement speed."
            }
          ]
        }
      ],
      "trivia": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "This item is a reference to the Hover Boots from the game "
            },
            {
              "t": "ext",
              "v": "The Legend of Zelda: Ocarina of Time",
              "url": "https://zelda.gamepedia.com/The_Legend_of_Zelda:_Ocarina_of_Time"
            },
            {
              "t": "text",
              "v": ", sharing a similar appearance (albeit with a more cheese-like look) and effect, however the Hover Boots don't provide invincibility. The \"pointy-eared adventurer\" mentioned in the description is also a reference to Link, the protagonist of the Legend of Zelda series."
            }
          ]
        }
      ]
    }
  },
  {
    "name": "Coin Crown",
    "icon": "https://static.wikia.nocookie.net/enterthegungeon_gamepedia/images/9/9f/Coin_Crown.png",
    "type": "Passive",
    "quote": "Play Well, Get Money",
    "quality": "C",
    "effect": "Increases the chance to find shells upon completing rooms.",
    "curse": 0.0,
    "coolness": 0.0,
    "wiki": {
      "effects": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "Has a 10% chance to give 5  upon clearing a room without taking damage."
            }
          ]
        }
      ],
      "item_interactions": [
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "ref",
              "v": "Loot Bag",
              "kind": "item"
            },
            {
              "t": "text",
              "v": " - Loot Bag does "
            },
            {
              "t": "text",
              "v": "not",
              "style": "i"
            },
            {
              "t": "text",
              "v": " double the 5  payout given when Coin Crown activates. It does, however, affect several of Coin Crowns synergies;\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": " "
                },
                {
                  "t": "synref",
                  "v": "Queen of Hearts"
                },
                {
                  "t": "text",
                  "v": " - The amount of  given when touching hearts while at full health is doubled."
                }
              ]
            },
            {
              "tokens": [
                {
                  "t": "text",
                  "v": " "
                },
                {
                  "t": "synref",
                  "v": "King Bomber"
                },
                {
                  "t": "text",
                  "v": " - The amount of  spawned when shooting an enemy with "
                },
                {
                  "t": "ref",
                  "v": "Lil' Bomber",
                  "kind": "gun"
                },
                {
                  "t": "text",
                  "v": " is doubled."
                }
              ]
            }
          ]
        }
      ],
      "notes": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "It is easy to unlock with the "
            },
            {
              "t": "ref",
              "v": "Briefcase of Cash",
              "kind": "item"
            },
            {
              "t": "text",
              "v": ". If the player already has 50  then the 250 will immediately unlock it."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Obtaining the "
            },
            {
              "t": "ref",
              "v": "Gold Junk",
              "kind": "item"
            },
            {
              "t": "text",
              "v": " will automatically unlock it. This is because the "
            },
            {
              "t": "ref",
              "v": "Gold Junk",
              "kind": "item"
            },
            {
              "t": "text",
              "v": " grants the player 500  when picked up."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "If duplicates of this item are somehow obtained, increases the chance of a 5 shell spawning upon clearing a room and allows multiple Coin Crowns to be activated at once."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Coin crown may be a reference to the "
            },
            {
              "t": "ext",
              "v": "Crown of Greed",
