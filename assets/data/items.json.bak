            {
              "t": "text",
              "v": " "
            },
            {
              "t": "ref",
              "v": "Secret room",
              "kind": "unresolved"
            },
            {
              "t": "text",
              "v": " exists on the current floor, the Teleporter Prototype will prioritise taking the player to the secret room over other special room types.\n"
            }
