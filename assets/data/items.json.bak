        },
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "ref",
              "v": "Armor of Thorns",
              "kind": "item"
            },
            {
              "t": "text",
              "v": " - Roll damage increases stack together multiplicatively, increasing damage per roll to 63 (84 as "
            },
            {
              "t": "ref",
              "v": "The Robot",
              "kind": "character"
            },
            {
              "t": "text",
              "v": ")."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "ref",
              "v": "Live Ammo",
              "kind": "item"
            },
            {
              "t": "text",
              "v": " +  "
            },
            {
              "t": "ref",
              "v": "Armor of Thorns",
              "kind": "item"
            },
            {
