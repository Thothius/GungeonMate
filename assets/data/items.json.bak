    "quote": "Lucky!",
    "quality": "1S",
    "effect": "Increases the quality of chests found in chest rooms to an equal chance of red or black.",
    "curse": 0.0,
    "coolness": 0.0,
    "wiki": {
      "effects": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "Increases the quality of "
            },
            {
              "t": "ref",
              "v": "Chests",
