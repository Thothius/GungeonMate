              "v": ", it fires lasers."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "synref",
              "v": "Lotus Bloom"
            },
            {
              "t": "text",
              "v": " - If the player has "
            },
            {
              "t": "ref",
              "v": "Laser Lotus",
              "kind": "gun"
            },
            {
              "t": "text",
              "v": ", its magazine size increases to 32, its maximum ammo increases to 300, its fire rate greatly increases, and it deals half damage."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "synref",
              "v": "Neo Tech, Yo"
            },
            {
              "t": "text",
              "v": " - If the player has "
            },
            {
              "t": "ref",
              "v": "Mutation",
              "kind": "gun"
            },
            {
              "t": "text",
              "v": ", its beams turn blue, it creates electrified water, and it grants electricity immunity while held."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "synref",
              "v": "Pistol Machine"
            },
            {
              "t": "text",
              "v": " - If the player has "
            },
            {
              "t": "ref",
              "v": "Machine Pistol",
              "kind": "gun"
            },
            {
              "t": "text",
              "v": ", its shots pierce."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "synref",
              "v": "Wave Beam"
            },
            {
              "t": "text",
