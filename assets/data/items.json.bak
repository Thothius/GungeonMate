          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "synref",
              "v": "Cash Rules Everygun Around Me"
            },
            {
              "t": "text",
              "v": " - If the player has "
            },
            {
              "t": "ref",
              "v": "Brick of Cash",
              "kind": "item"
            },
            {
              "t": "text",
              "v": ", firing any gun occasionally fires money which charms enemies."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "synref",
              "v": "Wicked Sister"
            },
            {
              "t": "text",
              "v": " - If the player also has "
            },
            {
              "t": "ref",
              "v": "Magnum",
              "kind": "gun"
            },
            {
              "t": "text",
              "v": ", it gets 200 max ammo and a knife on the front of the gun that will block bullets when reloading."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Picking up the Briefcase of Cash grants the rewards permanently, which means the Briefcase of Cash itself can then be sold to a "
            },
            {
              "t": "ref",
              "v": "Shop",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": " for an additional 41 .\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "Alternatively, if the player has the "
                },
                {
                  "t": "ref",
                  "v": "Ring of the Resourceful Rat",
                  "kind": "item"
                },
                {
                  "t": "text",
                  "v": ", the player can exchange the Briefcase of Cash with the "
                },
                {
                  "t": "ref",
                  "v": "Resourceful Rat",
                  "kind": "lore"
                },
                {
                  "t": "text",
                  "v": " for a different -rank passive item, as long as they haven't already exchanged an item or gun with him on the current floor."
                }
              ]
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "If the item is for sale in a "
            },
            {
              "t": "ref",
              "v": "Shop",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": ", purchasing it will result in a net gain of money, as it grants more money than it costs."
            }
          ]
        }
      ],
      "trivia": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "Its synergy with "
            },
            {
              "t": "ref",
              "v": "Brick of Cash",
              "kind": "item"
            },
            {
              "t": "text",
              "v": " is a reference to Wu-Tang Clan's \"C.R.E.A.M.\" quote \"Cash rules everything around me\"."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The item may be a reference to Reservoir Dogs, with the item description being directed towards Mr. Pink."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The 3 Hegemony Credits that spawn when the item is first picked up can be obtained multiple times in a single run. If the game is continued after saving and exiting from using the "
            },
            {
              "t": "ref",
              "v": "Save Button",
              "kind": "unresolved"
            },
            {
              "t": "text",
              "v": ", the credits will appear on the floor the player resumes at. This can be done multiple times per run."
            }
          ]
        }
      ]
    }
  },
  {
    "name": "Galactic Medal of Valor",
