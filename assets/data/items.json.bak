    "quote": "It's Delicious",
    "quality": "N",
    "effect": "Single use. Resurrects your co-op partner with full health.",
    "curse": 0.0,
    "coolness": 0.0,
    "wiki": {
      "effects": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "Upon use, resurrects a dead "
            },
            {
              "t": "ref",
              "v": "Co-op",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": " player with full health."
            }
          ]
        }
      ],
      "notes": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "This item is exclusive to co-op mode and cannot be found via normal gameplay.\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "If cheated into the player's inventory in singleplayer, the Friendship Cookie can be used with no effect."
