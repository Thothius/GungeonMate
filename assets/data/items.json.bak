  {
    "name": "Iron Coin",
    "icon": "https://static.wikia.nocookie.net/enterthegungeon_gamepedia/images/3/3c/Iron_Coin.png",
    "type": "Active",
    "quote": "Valar Morgunis",
    "quality": "C",
    "effect": "3 uses. Kills all enemies in a random room on the floor. Increases coolness by 2 and grants a 20% discount at shops while held.",
    "curse": 0.0,
    "coolness": 2.0,
    "wiki": {
      "effects": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "Upon use, kills all enemies in a random unexplored room of the current floor.\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "Where the effect took place, a note can be found lying in a pool of blood on the ground."
