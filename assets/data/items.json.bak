  {
    "name": "Ancient Hero's Bandana",
    "icon": "https://static.wikia.nocookie.net/enterthegungeon_gamepedia/images/7/77/Ancient_Hero%27s_Bandana.png",
    "type": "Passive",
    "quote": "Limitless",
    "quality": "1S",
    "effect": "Quadruples maximum ammo.",
    "curse": 0.0,
    "coolness": 0.0,
    "wiki": {
      "effects": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "Quadruples maximum ammo."
            }
          ]
        }
      ],
      "notes": [
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "synref",
              "v": "I need scissors! 61!"
            },
            {
              "t": "text",
              "v": " - If the player also has "
            },
            {
              "t": "ref",
              "v": "Trank Gun",
              "kind": "gun"
            },
            {
              "t": "text",
              "v": ", Trank Gun changes appearance, its rate of fire is decreased, damage and reload time are increased, and its bullets will inflict "
            },
            {
              "t": "ref",
              "v": "Status Effects",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": " and "
            },
            {
              "t": "ref",
              "v": "Status Effects",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": "."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "synref",
              "v": "What A Thrill"
            },
            {
              "t": "text",
              "v": " - If the player also has "
            },
            {
              "t": "ref",
              "v": "Patriot",
              "kind": "gun"
            },
            {
              "t": "text",
              "v": ", it has a chance to transmogrify enemies into snakes."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Has no effect on the "
            },
            {
              "t": "ref",
              "v": "Prize Pistol",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": "."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Will still quadruple maximum ammo during any character's Past as long as they do not switch weapons."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Guns obtained before bandana will only increase the maximum capacity, not the currently stored ammo."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "If the player finds multiple bandanas, they will stack multiplicatively - two bandanas will grant 16x ammo."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": " Bug Entering a Gungeoneer's past with Ancient Hero's Bandana in your inventory will cause the gun given in that Gungeoneer's past to have its current ammo set to 4x of that of the gun's usual maximum ammo capacity.\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "This affects "
                },
                {
                  "t": "ref",
                  "v": "The Marine",
                  "kind": "character"
                },
                {
                  "t": "text",
                  "v": " with the "
                },
                {
                  "t": "ref",
                  "v": "Hegemony Carbine",
                  "kind": "gun"
                },
                {
                  "t": "text",
                  "v": ", "
                },
                {
                  "t": "ref",
                  "v": "The Convict",
                  "kind": "character"
                },
                {
                  "t": "text",
                  "v": " with the "
                },
                {
                  "t": "ref",
                  "v": "Tommy gun",
                  "kind": "unresolved"
                },
                {
                  "t": "text",
                  "v": ", "
                },
                {
                  "t": "ref",
                  "v": "The Robot",
                  "kind": "character"
                },
                {
                  "t": "text",
                  "v": " with "
                },
                {
                  "t": "ref",
                  "v": "Robot's Left Hand",
                  "kind": "gun"
                },
                {
                  "t": "text",
                  "v": ", and "
                },
                {
                  "t": "ref",
                  "v": "The Hunter",
                  "kind": "character"
                },
                {
                  "t": "text",
                  "v": " with the "
                },
                {
                  "t": "ref",
                  "v": "Sticky Crossbow",
                  "kind": "gun"
                },
                {
                  "t": "text",
                  "v": "."
                }
              ]
            },
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "This bug does NOT affect "
                },
                {
                  "t": "ref",
                  "v": "The Pilot",
                  "kind": "character"
                },
                {
                  "t": "text",
                  "v": " or "
                },
                {
                  "t": "ref",
                  "v": "The Cultist",
                  "kind": "character"
                },
                {
                  "t": "text",
                  "v": ", as their pasts don't involve being given traditional weapons, and does not affect "
                },
                {
                  "t": "ref",
                  "v": "The Paradox",
                  "kind": "character"
                },
                {
                  "t": "text",
                  "v": " or "
                },
                {
                  "t": "ref",
                  "v": "The Gunslinger",
                  "kind": "character"
                },
                {
                  "t": "text",
                  "v": " as they don't have pasts."
                }
              ]
            }
          ]
        }
      ],
      "trivia": [
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "ref",
              "v": "Unused and Cut Content/Synergies",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": " - ("
            },
            {
              "t": "text",
              "v": "CustomSynergyType.THE_TRUE_HERO",
              "style": "code"
            },
            {
              "t": "text",
              "v": ") If the player has "
            },
            {
              "t": "ref",
              "v": "Number 2",
              "kind": "item"
            },
            {
              "t": "text",
              "v": ", it causes an unknown effect. Removed because it contains a starting item."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "This item is a reference to the "
            },
            {
              "t": "ext",
              "v": "Metal Gear Solid",
              "url": "https://metalgear.fandom.com/wiki/Metal_Gear_Wiki"
            },
            {
              "t": "text",
              "v": " series. First appearing in the original Metal Gear Solid, the \""
            },
            {
              "t": "text",
              "v": "Infinity Bandana",
              "style": "i"
            },
            {
              "t": "text",
              "v": "\" was an unlockable item which granted infinite ammo when worn by Snake - whom the title \""
            },
            {
              "t": "text",
              "v": "Ancient Hero",
              "style": "i"
            },
            {
              "t": "text",
              "v": "\" is likely in reference to."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Ancient Hero's Bandana has the same sprite shape as "
            },
            {
              "t": "ref",
              "v": "Bloodied Scarf",
              "kind": "item"
            },
            {
              "t": "text",
              "v": " and "
            },
            {
              "t": "ref",
              "v": "Number 2",
              "kind": "item"
            },
            {
              "t": "text",
              "v": "."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "\"I need scissors! 61!\" is a reference to Metal Gear Solid 2, near the end of the game the player receives a series of nonsense messages with this quote."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "synref",
              "v": "What A Thrill"
            },
            {
              "t": "text",
              "v": " is a reference to the song snake eater from "
            },
            {
              "t": "ext",
              "v": "Metal Gear Solid 3",
              "url": "https://en.wikipedia.org/wiki/Metal_Gear_Solid_3:_Snake_Eater"
            },
            {
              "t": "text",
              "v": "."
