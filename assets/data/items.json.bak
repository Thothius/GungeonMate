  {
    "name": "Blank Companion's Ring",
    "icon": "https://static.wikia.nocookie.net/enterthegungeon_gamepedia/images/a/a3/Blank_Companion%27s_Ring.png",
    "type": "Passive",
    "quote": "He Tries",
    "quality": "A",
    "effect": "Activates a blank each time an active item is used.",
    "curse": 0.0,
    "coolness": 0.0,
    "wiki": {
      "effects": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "Spawns a blank familiar who activates a blank effect each time an active item is used.\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "Has a cooldown of 10 seconds between each activation."
                }
              ]
            }
          ]
        }
      ],
      "notes": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "This item works well with an active item that automatically recharges or has a low cooldown, effectively granting a free blank every 10 seconds. Examples include:\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "ref",
                  "v": "Melted Rock",
                  "kind": "item"
                }
              ]
            },
            {
              "tokens": [
                {
                  "t": "ref",
                  "v": "Shield of the Maiden",
                  "kind": "item"
                }
              ]
            },
            {
              "tokens": [
                {
                  "t": "ref",
                  "v": "Jetpack",
                  "kind": "item"
                }
              ]
            },
            {
              "tokens": [
                {
                  "t": "ref",
                  "v": "Sense of Direction",
                  "kind": "item"
                }
              ]
            },
            {
              "tokens": [
                {
                  "t": "ref",
                  "v": "iBomb Companion App",
                  "kind": "item"
                }
              ]
            },
            {
              "tokens": [
                {
                  "t": "ref",
                  "v": "Grappling Hook",
                  "kind": "item"
                }
              ]
            },
            {
              "tokens": [
                {
                  "t": "ref",
                  "v": "Busted Television",
                  "kind": "item"
                }
              ]
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The blank effect activates in the room the companion is currently in, not necessarily the one the player is in. This is important to note when using the item to open secret rooms."
            }
          ]
        }
      ]
    }
  },
  {
    "name": "Briefcase of Cash",
    "icon": "https://static.wikia.nocookie.net/enterthegungeon_gamepedia/images/4/45/Briefcase_of_Cash.png",
    "type": "Passive",
    "quote": "Avarice",
    "quality": "A",
    "effect": "Grants 250 and 3 .",
    "curse": 0.0,
    "coolness": 0.0,
