  {
    "name": "Bullet Idol",
    "icon": "https://static.wikia.nocookie.net/enterthegungeon_gamepedia/images/c/ce/Bullet_Idol.png",
    "type": "Passive",
    "quote": "Vengeful Spirit",
    "quality": "B",
    "effect": "Deals 45 damage to enemies upon taking damage.",
    "curse": 0.0,
    "coolness": 0.0,
    "wiki": {
      "effects": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "Deals 45 damage to all enemies in the room upon taking damage."
            }
          ]
        }
      ],
      "notes": [
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "synref",
              "v": "Critcaliber"
            },
            {
              "t": "text",
