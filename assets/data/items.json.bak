  {
    "name": "Bullet Time",
    "icon": "https://static.wikia.nocookie.net/enterthegungeon_gamepedia/images/b/bd/Bullet_Time.png",
    "type": "Active",
    "quote": "Dodge This",
    "quality": "D",
    "effect": "Slows down time while active.",
    "curse": 0.0,
    "coolness": 0.0,
    "wiki": {
      "effects": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "Slows down time by 70% while active. The player's movement, firing and reload speeds are unaffected by the slowdown."
            }
          ]
        }
      ],
      "notes": [
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "synref",
              "v": "Bluer Guon Stone"
            },
            {
              "t": "text",
              "v": " - If the player also has "
            },
            {
              "t": "ref",
              "v": "Blue Guon Stone",
              "kind": "item"
            },
            {
              "t": "text",
              "v": ", the size and rotation speed of the Guon Stone is increased and it rotates at a fixed distance from the player while they are moving instead of on a slight delay. If the Guon Stone blocks a bullet, it deals 15 damage to all nearby enemies."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "synref",
              "v": "Thrown For A Bloop"
            },
            {
              "t": "text",
              "v": " - If the player also has "
            },
            {
              "t": "ref",
              "v": "Blooper",
              "kind": "gun"
            },
            {
              "t": "text",
              "v": ", while Bullet Time is active, a Blooper orbits the player and continually fires at enemies."
            }
          ]
        }
      ],
      "trivia": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "The tagline \"Dodge This\" is a reference to a quote made by the character Trinity in "
            },
            {
              "t": "ext",
              "v": "The Matrix",
              "url": "https://en.wikipedia.org/wiki/The_Matrix"
            },
            {
              "t": "text",
              "v": "."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "\"Bullet Time\" is the name of the time-freezing camera technique popularized by The Matrix films, which later inspired the time-slowing \"Bullet Time\" mechanic in the "
            },
            {
              "t": "ext",
              "v": "Max Payne",
              "url": "https://en.wikipedia.org/wiki/Max_Payne"
            },
            {
              "t": "text",
              "v": " series of video games."
            }
          ]
        }
      ]
    }
  },
  {
    "name": "Aged Bell",
    "icon": "https://static.wikia.nocookie.net/enterthegungeon_gamepedia/images/c/c5/Aged_Bell.png",
    "type": "Active",
    "quote": "Lacuna",
    "quality": "A",
    "effect": "Briefly stops enemies and enemy bullets. Can be used to steal from shops.",
    "curse": 0.0,
    "coolness": 0.0,
    "wiki": {
      "effects": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "Stops enemies and enemy bullets for five seconds."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Can be used to "
            },
            {
              "t": "ref",
              "v": "Stealing",
              "kind": "unresolved"
            },
            {
              "t": "text",
              "v": " one item from the "
            },
            {
              "t": "ref",
              "v": "Shop",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": " before being caught."
            }
          ]
        }
      ],
      "notes": [
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "synref",
              "v": "Get Equipped With -F"
            },
            {
              "t": "text",
              "v": " -If the player has "
            },
            {
              "t": "ref",
              "v": "Megahand",
              "kind": "gun"
            },
            {
              "t": "text",
              "v": ", Megahand can be toggled into Time Stopper by reloading at full ammo, which briefly stops time on a fully charged shot for 1.5 seconds."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "synref",
              "v": "Holy Bell"
            },
            {
              "t": "text",
              "v": " - If the player has "
            },
            {
              "t": "ref",
              "v": "Trident",
              "kind": "gun"
            },
            {
              "t": "text",
              "v": ", killing an enemy with the Trident creates a large circular area that slows time."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Using Aged Bell does not stop moving platforms."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Using Aged Bell does not stop bullets that spawn after time has stopped (e.g. when a "
            },
            {
              "t": "ref",
              "v": "Spogre",
              "kind": "unresolved"
            },
            {
              "t": "text",
              "v": " dies)."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Using Aged Bell does not stop the "
            },
            {
              "t": "ref",
              "v": "Lord of the Jammed",
              "kind": "unresolved"
            },
            {
              "t": "text",
              "v": " from moving or shooting, nor does it stop the Serpent from shooting during the first phase of the "
            },
            {
              "t": "ref",
              "v": "Advanced Dragun",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": "."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Using Aged Bell does not stop Kill Pillars or their bullets."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Using the Aged Bell is a good strategy for unlocking the "
            },
            {
              "t": "ref",
              "v": "Shelleton Key",
              "kind": "item"
            },
            {
              "t": "text",
              "v": ". If you activate "
            },
            {
              "t": "ref",
              "v": "Rainbow Mode",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": " and restart on the first floor until you get Aged Bell and then steal from the shop, repeating the process ten times, you can unlock the Shelleton Key more efficiently."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "If the player dies while using the Aged Bell and performs a quick restart, the music will be muted for the rest of the run."
            }
          ]
        }
      ]
    }
  },
  {
    "name": "Singularity",
    "icon": "https://static.wikia.nocookie.net/enterthegungeon_gamepedia/images/d/d0/Singularity.png",
    "type": "Active",
    "quote": "Sucks",
    "quality": "C",
    "effect": "Spawns a black hole that attracts enemies and bullets.",
    "curse": 0.0,
    "coolness": 0.0,
    "wiki": {
      "effects": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "Spawns a black hole that sucks enemies, bullets, and items into it.\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "Enemies in the black hole take damage."
                }
              ]
            },
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "Bullets sucked into the black hole are destroyed."
                }
              ]
            }
          ]
        }
      ],
      "notes": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "Bosses are not pulled into the black hole."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Consumes any  spawned in its proximity."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Beam weapons can be used around the Singularity without being pulled in."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "This item may be a reference to the "
            },
            {
              "t": "ext",
              "v": "Gersh Device",
              "url": "http://callofduty.wikia.com/wiki/Gersh_Device"
            },
            {
              "t": "text",
              "v": " found in the Zombies mode in "
            },
            {
              "t": "ext",
              "v": "Call of Duty: Black Ops",
              "url": "https://en.wikipedia.org/wiki/Call_of_Duty:_Black_Ops"
            },
            {
              "t": "text",
              "v": "."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The Hellhole synergy is likely a reference to the movie "
            },
            {
              "t": "ext",
              "v": "Event Horizon",
              "url": "https://en.wikipedia.org/wiki/Event_Horizon_(film)"
            },
            {
              "t": "text",
              "v": " in which a crew of astronauts attempting to find a missing spaceship find a portal to hell through a machine that uses artificial black holes."
            }
          ]
        }
      ]
    }
  },
  {
    "name": "Decoy",
    "icon": "https://static.wikia.nocookie.net/enterthegungeon_gamepedia/images/b/bb/Decoy.png",
    "type": "Active",
    "quote": "Get Him!",
    "quality": "D",
    "effect": "Places a decoy that enemies will target. The decoy will be destroyed after taking enough damage. Can be used to steal from shops.",
    "curse": 0.0,
    "coolness": 0.0,
    "wiki": {
      "effects": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "Places a decoy at the users current position. This decoy will distract enemies, who will target the decoy instead of the player. This decoy will be destroyed after taking too much damage."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "If a decoy is placed in a "
            },
            {
              "t": "ref",
              "v": "Merchants",
              "kind": "unresolved"
            },
            {
              "t": "text",
              "v": ", it will also distract the shopkeeper, allowing the player to "
            },
            {
              "t": "ref",
              "v": "Stealing",
              "kind": "unresolved"
            },
            {
              "t": "text",
              "v": " from that shop while the Decoy is inside."
            }
          ]
        }
      ],
      "item_interactions": [
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "ref",
              "v": "Ring of Triggers",
              "kind": "item"
            },
            {
              "t": "text",
              "v": " - Using the Decoy will also result in a circle of bullets being shot outwards, which will oftentimes destroy the Decoy, making stealing difficult unless this item is dropped first."
            }
          ]
        }
      ],
      "notes": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "Items cannot be purchased from a shop with a decoy in it; stealing is the only option. Place a decoy close to the shop's entrance and shoot it from outside the shop to enable buying items normally again."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The item itself is a reference to the "
            },
            {
              "t": "ext",
              "v": "Body Replacement Technique",
              "url": "https://naruto.fandom.com/wiki/Body_Replacement_Technique"
            },
            {
              "t": "text",
              "v": " from Naruto, in which the user replaces themselves with a log to avoid an opponents attack."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The  "
            },
            {
              "t": "synref",
              "v": "Kage Bunshin"
            },
            {
              "t": "text",
              "v": " synergy refers to the "
            },
            {
              "t": "ext",
              "v": "Kage Bunshin",
              "url": "http://naruto.wikia.com/wiki/Shadow_Clone_Technique"
            },
            {
              "t": "text",
              "v": " technique from "
            },
            {
              "t": "text",
              "v": "Naruto",
              "style": "i"
            },
            {
              "t": "text",
              "v": "."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The  "
            },
            {
              "t": "synref",
              "v": "Kinjutsu"
            },
            {
              "t": "text",
              "v": " synergy refers to the same technique being considered a "
            },
            {
              "t": "ext",
              "v": "Forbidden Technique",
              "url": "https://naruto.fandom.com/wiki/Kinjutsu"
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The  "
            },
            {
              "t": "synref",
              "v": "Decoy Octorok"
            },
            {
              "t": "text",
              "v": " synergy is a reference to the Metal Gear Solid character, "
            },
            {
              "t": "ext",
              "v": "Decoy Octopus",
              "url": "http://metalgear.wikia.com/wiki/Decoy_Octopus"
            },
            {
              "t": "text",
              "v": " and the purple, tentacled Legend of Zelda "
            },
            {
              "t": "ext",
              "v": "enemies of the same name",
              "url": "https://zelda.gamepedia.com/Octorok"
            },
            {
              "t": "text",
              "v": ".\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "It is also a reference to Dave Crooks, one of Enter the Gungeon's developers, whose handle is DecoyOctorok."
                }
              ]
            }
          ]
        }
      ]
    }
  },
  {
    "name": "Shadow Clone",
    "icon": "https://static.wikia.nocookie.net/enterthegungeon_gamepedia/images/7/7b/Shadow_Clone.png",
    "type": "Active",
    "quote": "No Jutsu",
    "quality": "D",
    "effect": "Creates a copy of the player that mimics their movements in reverse and fires alongside them.",
    "curse": 0.0,
    "coolness": 0.0,
    "wiki": {
      "effects": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "Upon use, spawns a temporary clone of the player.\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "The clone's movements are opposite to the player."
                }
              ]
            },
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "The clone will shoot with the same weapon the player has equipped, and aims where the player aims."
                }
              ]
            },
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "The clone blocks enemies and enemy bullets."
                }
              ]
            }
          ]
        }
      ],
      "notes": [
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "synref",
              "v": "Kinjutsu"
            },
            {
              "t": "text",
              "v": " - If the player also has "
            },
            {
              "t": "ref",
              "v": "Decoy",
              "kind": "item"
            },
            {
              "t": "text",
              "v": ", Shadow Clone spawns three clones.\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "Due to the nature of this synergy, it requires an inventory-expanding item such as "
                },
                {
                  "t": "ref",
                  "v": "Utility Belt",
                  "kind": "item"
                },
                {
                  "t": "text",
                  "v": " or "
                },
                {
                  "t": "ref",
                  "v": "Backpack",
                  "kind": "item"
                },
                {
                  "t": "text",
                  "v": "."
                }
              ]
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Multiple clones can be spawned at the same time."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "If you spawn the shadow clone too close to the wall, then it will clip into the wall."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The clone can block the "
            },
            {
              "t": "ref",
              "v": "Wallmonger",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": ", which is halted and cannot move.\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "However, the camera will keep panning down while the Wallmonger is stuck, causing it to leave the screen (this makes short range weapons unusable); after being stuck for a while the Wallmonger will teleport back to the screen, likely dealing contact damage to the player in the process."
                }
              ]
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The clone won't shoot the "
            },
            {
              "t": "ref",
              "v": "Chamber Gun",
              "kind": "gun"
            },
            {
              "t": "text",
              "v": " (Doesn't matter what version of the Chamber Gun is used)."
            }
          ]
        }
      ],
      "trivia": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "This item is referring to Naruto Uzumaki's favored technique from the namesake anime series Naruto."
            },
            {
              "t": "ext",
              "v": "[1]",
              "url": "https://en.wikipedia.org/wiki/Naruto"
            },
            {
              "t": "text",
              "v": "\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "The words \"Believe it!\" in the item description are a direct reference to his catchphrase early on in the English dubbed series."
                }
              ]
            },
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "The item's icon is that of a ninja scroll, which in the series can be use to store items or techniques for later use."
                }
              ]
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The item description \"No Jutsu\" is meant to be appended to the name (i.e. \"Shadow Clone No Jutsu\"), meaning \"the technique of shadow clone\".\n"
            }
          ],
          "sub": [
            {
              "tokens": []
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The term \"kinjutsu\" is used in the series to refer to forbidden techniques; however, the  "
            },
            {
              "t": "synref",
              "v": "Kinjutsu"
            },
            {
              "t": "text",
              "v": " synergy seems to be referencing the basic Substitution Jutsu, although it is possible that it is referencing the Multi-shadow clone jutsu."
            }
          ]
        }
      ]
    }
  },
  {
    "name": "Explosive Decoy",
    "icon": "https://static.wikia.nocookie.net/enterthegungeon_gamepedia/images/3/32/Explosive_Decoy.png",
    "type": "Active",
    "quote": "KABOOM!",
    "quality": "C",
    "effect": "Places a decoy that enemies will target. The decoy will explode after taking enough damage. Can be used to steal from shops.",
    "curse": 0.0,
    "coolness": 0.0,
    "wiki": {
      "effects": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "Places a decoy that enemies will target. The decoy will explode after taking enough damage or after roughly 11 seconds, dealing 30 damage to nearby enemies."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Can be used to "
            },
            {
              "t": "ref",
              "v": "Stealing",
              "kind": "unresolved"
            },
            {
              "t": "text",
              "v": " from "
            },
            {
              "t": "ref",
              "v": "Shop",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": " while placed (until it explodes)."
            }
          ]
        }
      ],
      "notes": [
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "synref",
              "v": "Deadlier Distraction"
            },
            {
              "t": "text",
              "v": " - If the player also has "
            },
            {
              "t": "ref",
              "v": "Monster Blood",
              "kind": "item"
            },
            {
              "t": "text",
              "v": ", the Explosive Decoy explodes and creates a large poison pool when attacked."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "synref",
              "v": "Decoy Octorok"
            },
            {
              "t": "text",
              "v": " - If the player also has "
            },
            {
              "t": "ref",
              "v": "Abyssal Tentacle",
              "kind": "gun"
            },
            {
              "t": "text",
              "v": ", the decoy will become a charmed enemy."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "synref",
              "v": "Frostier Distraction"
            },
            {
              "t": "text",
              "v": " - If the player also has "
            },
            {
              "t": "ref",
              "v": "Heart of Ice",
              "kind": "item"
            },
            {
              "t": "text",
              "v": ", the Explosive Decoy becomes partially made of ice and causes enemies that shoot it to be frozen."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "synref",
              "v": "Hardwood"
            },
            {
              "t": "text",
              "v": " - If the player also has "
            },
            {
              "t": "ref",
              "v": "Mahoguny",
              "kind": "gun"
            },
            {
              "t": "text",
              "v": ", it will fire three explosive shots at a time."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Items cannot be purchased from a shop with an explosive decoy in it; stealing is the only option. It shares this effect with the regular "
            },
            {
              "t": "ref",
              "v": "Decoy",
              "kind": "item"
            },
            {
              "t": "text",
              "v": ", but because it explodes after a short period, it's less problematic if the player intends to buy something from a shop after stealing."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "If the player has "
            },
            {
              "t": "ref",
              "v": "Ring of Triggers",
              "kind": "item"
            },
            {
              "t": "text",
              "v": ", the Explosive Decoy will immediately explode and damage the player."
            }
          ]
        }
      ]
    }
  },
  {
    "name": "Melted Rock",
    "icon": "https://static.wikia.nocookie.net/enterthegungeon_gamepedia/images/a/a6/Melted_Rock.png",
    "type": "Active",
    "quote": "Corpses Explode",
    "quality": "C",
    "effect": "Causes enemy corpses to explode on use.",
    "curse": 0.0,
    "coolness": 0.0,
    "wiki": {
      "effects": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "Causes enemy corpses to explode on use, dealing 15 damage to nearby enemies."
            }
          ]
        }
      ],
      "notes": [
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "synref",
              "v": "Alternative Rock"
            },
            {
              "t": "text",
              "v": " - If the player has "
            },
            {
              "t": "ref",
              "v": "Face Melter",
              "kind": "gun"
            },
            {
              "t": "text",
              "v": ", instead of firing four streams, Face Melter fires two parallel columns of notes. Reloading fires a guitar pick with a chance to stun."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "synref",
              "v": "Dead Place"
            },
            {
              "t": "text",
              "v": " - If the player also has "
            },
            {
              "t": "ref",
              "v": "Mine Cutter",
              "kind": "gun"
            },
            {
              "t": "text",
              "v": ", its damage is increased by 25%."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "synref",
              "v": "Extreme Operation"
            },
            {
              "t": "text",
              "v": " - If the player has "
            },
            {
              "t": "ref",
              "v": "Ammo Synthesizer",
              "kind": "item"
            },
            {
              "t": "text",
              "v": ", Melted Rock causes each corpse to fire a bullet at a nearby enemy in addition to exploding."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "synref",
              "v": "Human Shield"
            },
            {
              "t": "text",
              "v": " - If the player has "
            },
            {
              "t": "ref",
              "v": "Crisis Stone",
              "kind": "item"
            },
            {
              "t": "text",
              "v": ", Melted Rock causes each corpse to spawn a shield after exploding, similar to the "
            },
            {
              "t": "ref",
              "v": "Betrayer's Shield",
              "kind": "gun"
            },
            {
              "t": "text",
              "v": "."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Prior to "
            },
            {
              "t": "ref",
              "v": "Version History",
              "kind": "unresolved"
            },
            {
              "t": "text",
              "v": ", the explosions could hurt the player."
            }
          ]
        }
      ],
      "trivia": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "This item and its description are references to the character Melting from "
            },
            {
              "t": "ext",
              "v": "Nuclear Throne",
              "url": "https://en.wikipedia.org/wiki/Nuclear_Throne"
            },
            {
              "t": "text",
              "v": ", who is able to cause corpses to explode."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "If the Melted Rock is used after defeating "
            },
            {
              "t": "ref",
              "v": "Gatling Gull",
              "kind": "unresolved"
            },
            {
              "t": "text",
              "v": ", when the birds appear to pick up the body, they will all stay in place until the player uses the elevator to the next floor."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The synergy  "
            },
            {
              "t": "synref",
              "v": "Dead Place"
            },
            {
              "t": "text",
              "v": " is a reference to the game "
            },
            {
              "t": "ext",
              "v": "Dead Space",
              "url": "https://en.wikipedia.org/wiki/Dead_Space"
            },
            {
              "t": "text",
              "v": ", where the first weapon is a repurposed laser used for cutting rock."
            }
          ]
        }
      ]
    }
  },
  {
    "name": "Trusty Lockpicks",
    "icon": "https://static.wikia.nocookie.net/enterthegungeon_gamepedia/images/6/6c/Trusty_Lockpicks.png",
    "type": "Active",
    "quote": "Who Needs Keys?",
    "quality": "D",
    "effect": "Has a 50% chance to unlock a lock or locked chest. If it fails, the lock will no longer function.",
    "curse": 0.0,
    "coolness": 0.0,
    "wiki": {
      "effects": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "Has a 50% chance to unlock a lock or locked "
            },
            {
              "t": "ref",
              "v": "Chest",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": ".\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "If it fails, the lock will no longer function. The chest can still be destroyed."
                }
              ]
            },
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "Can be used to unlock locks on trapdoors such as the entrance to the "
                },
                {
                  "t": "ref",
                  "v": "Oubliette",
                  "kind": "lore"
                },
                {
                  "t": "text",
                  "v": "."
                }
              ]
            },
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "The lockpicks are unique among key-replacing items in that they can be used to open "
