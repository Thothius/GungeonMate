                },
                {
                  "t": "text",
                  "v": " stats with innately higher dodge roll damage, Blast Helmet instead increases damage dealt per roll from 4 to 12."
                }
              ]
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Grants contact damage immunity.\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "This does "
                },
                {
                  "t": "text",
                  "v": "not",
                  "style": "i"
                },
                {
                  "t": "text",
                  "v": " prevent  "
                },
                {
                  "t": "ref",
                  "v": "Muzzle Wisp",
