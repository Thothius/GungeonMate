  {
    "name": "Fortune's Favor",
    "icon": "https://static.wikia.nocookie.net/enterthegungeon_gamepedia/images/9/9a/Fortune%27s_Favor.png",
    "type": "Active",
    "quote": "Use For Luck",
    "quality": "B",
    "effect": "While active, bullets will curve around the player.",
    "curse": 0.0,
    "coolness": 0.0,
    "wiki": {
      "effects": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "While active, enemy bullets are repulsed from the player- curving around them."
            }
          ]
        }
      ],
      "notes": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "The curving effect is not powerful enough to redirect bullets with significant velocity (e.g. "
            },
            {
              "t": "ref",
              "v": "Sniper Shell",
              "kind": "unresolved"
            },
            {
              "t": "text",
              "v": " projectiles) or bigger bullets (e.g. "
            },
            {
              "t": "ref",
              "v": "Cannonbalrog",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": "'s disappearing attack)."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The synergy \"Pretty Good\" is a reference to the popular quote from Metal Gear Solid, \"You're pretty good\"."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The synergy \"What a Thrill\" is a reference to the song \"Snake Eater\" from Metal Gear Solid 3, sung by Cynthia Harrel."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "This item is a reference to the character Fortune from "
            },
            {
              "t": "ext",
              "v": "Metal Gear Solid 2",
              "url": "https://en.wikipedia.org/wiki/Metal_Gear_Solid_2:_Sons_of_Liberty"
            },
            {
              "t": "text",
              "v": ", who supposedly possesses unnatural luck but in reality possesses a device capable of deflecting bullets and turning live grenades into duds around her.\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "The synergy with the Railgun is also a reference to her, as she uses a massive handheld railgun as well. The synergy's name refers to Fortune's squad, the Dead Cell Unit."
                }
              ]
            }
          ]
        }
      ]
    }
  },
  {
    "name": "Jar of Bees",
    "icon": "https://static.wikia.nocookie.net/enterthegungeon_gamepedia/images/e/e1/Jar_of_Bees.png",
    "type": "Active",
