            },
            {
              "t": "text",
              "v": " and "
            },
            {
              "t": "ref",
              "v": "Barrels",
              "kind": "unresolved"
            },
            {
              "t": "text",
              "v": "."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Inactive enemies, such as the frozen corpse of a  "
            },
            {
              "t": "ref",
              "v": "Blizzbulon",
              "kind": "unresolved"
            },
            {
              "t": "text",
              "v": " will still block and destroy knives."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": " Bug If the player uses a teleporter with knives active, it is possible to damage and kill enemies in rooms between the two teleporting points, as the knives do not teleport; they travel very quickly between the two points."
            }
          ]
        }
      ]
    }
  },
  {
    "name": "Grappling Hook",
    "icon": "https://static.wikia.nocookie.net/enterthegungeon_gamepedia/images/3/3d/Grappling_Hook.png",
    "type": "Active",
    "quote": "Rapid Transit",
    "quality": "D",
    "effect": "Allows players to hook onto and then pull themselves towards walls at a fast speed. Hitting enemies with the hook will deal minor damage and stun them for a short duration. Allows players to steal items from the shop. The hook has an unlimited range.",
    "curse": 0.0,
    "coolness": 0.0,
    "wiki": {
      "effects": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "Allows players to hook onto and then pull themselves towards walls at a fast speed.\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "The hook has unlimited range."
