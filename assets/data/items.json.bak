  {
    "name": "Disarming Personality",
    "icon": "https://static.wikia.nocookie.net/enterthegungeon_gamepedia/images/3/3a/Disarming_Personality.png",
    "type": "Passive",
    "quote": "For You?",
    "quality": "C",
    "effect": "Decreases shop prices by 15%.",
    "curse": 0.0,
    "coolness": 0.0,
    "wiki": {
      "effects": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "Grants a 15% discount at shops."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Grants a 20% discount at shops."
            }
          ]
        }
      ],
      "notes": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "Cannot be sold, even as gungeoneers other than The Pilot."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Does not provide a discount for the "
            },
            {
              "t": "ref",
              "v": "Gnawed Key",
              "kind": "unresolved"
            },
            {
              "t": "text",
              "v": " or the "
            },
            {
              "t": "ref",
              "v": "Prime Primer",
              "kind": "item"
            },
            {
              "t": "text",
              "v": "."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "If Disarming Personality is bought from a shop, the discount will apply to itself."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "In co-op, the discount applies to The Cultist as well."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "About 30 Disarming Personalities will make everything in the "
            },
            {
              "t": "ref",
              "v": "Shop",
