        {
          "tokens": [
            {
              "t": "text",
              "v": "Lament Configurum is sold for the price of an  item in shops even though it is a  item.\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "ref",
                  "v": "Flynt",
                  "kind": "unresolved"
                },
                {
                  "t": "text",
                  "v": " does not sell it for an increased price."
                }
