          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "synref",
              "v": "Devil's Plaything"
            },
            {
              "t": "text",
              "v": " - If the player also has "
            },
            {
              "t": "ref",
              "v": "Armor of Thorns",
              "kind": "item"
            },
            {
              "t": "text",
              "v": ", Bullet Idol orbits the player, blocking enemy shots. Any enemy shots blocked by Bullet Idol cause 10 damage to every enemy in the room."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "synref",
              "v": "Just Like The Real Thing"
