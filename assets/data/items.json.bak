  {
    "name": "Wingman",
    "icon": "https://static.wikia.nocookie.net/enterthegungeon_gamepedia/images/0/09/Wingman.png",
    "type": "Passive",
    "quote": "Got Your Back",
    "quality": "A",
    "effect": "Orbits the player, firing rockets at enemies.",
    "curse": 0.0,
    "coolness": 0.0,
    "wiki": {
      "effects": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "Orbits the player, firing homing 20-damage rockets at enemies every 5 seconds."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Blocks bullets."
            }
          ]
        }
      ],
      "notes": [
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "synref",
              "v": "Pilot Wingsman"
            },
            {
              "t": "text",
              "v": " - If the player also has "
            },
            {
              "t": "ref",
              "v": "Alien Engine",
              "kind": "gun"
            },
            {
              "t": "text",
              "v": ", Wingman's sprite will become blue and will fire 4 missiles at a time.\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "When dropping "
                },
                {
                  "t": "ref",
                  "v": "Alien Engine",
                  "kind": "gun"
                },
                {
                  "t": "text",
                  "v": ", the wingman may still look blue, but it will only fire one rocket."
                }
              ]
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Wingman's missiles can be controlled by the player if they have "
            },
            {
              "t": "ref",
              "v": "Remote Bullets",
              "kind": "item"
            },
            {
              "t": "text",
              "v": "."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The Wingman's homing missiles target a single enemy and if that enemy dies before the missile has reached it, it will not home onto another one."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Wingman's missiles are affected by "
            },
            {
              "t": "ref",
              "v": "Battle Standard",
              "kind": "item"
            },
            {
              "t": "text",
              "v": "."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Wingman's missiles ignite any flammable "
            },
            {
              "t": "ref",
              "v": "Goop",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": " they fly over."
            }
          ]
        }
      ],
      "trivia": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "The Wingman is likely a miniature version of Z's ship from "
            },
            {
              "t": "ref",
              "v": "The Pilot",
              "kind": "character"
            },
            {
              "t": "text",
              "v": "'s past, reinforced by its entry in the Ammonomicon, its unlock method, and its resemblance to Z's ship."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The  "
            },
            {
              "t": "synref",
              "v": "Pilot Wingsman"
            },
            {
              "t": "text",
              "v": " synergy is a reference to the Nintendo game "
            },
            {
              "t": "ext",
              "v": "Pilotwings",
              "url": "https://en.wikipedia.org/wiki/Pilotwings"
            },
            {
              "t": "text",
              "v": "."
            }
          ]
        }
      ]
    }
  },
  {
    "name": "Wolf",
    "icon": "https://static.wikia.nocookie.net/enterthegungeon_gamepedia/images/c/c8/Wolf.png",
    "type": "Passive",
    "quote": "Junior",
    "quality": "B",
    "effect": "Chases and bites enemies.",
    "curse": 0.0,
    "coolness": 0.0,
    "wiki": {
      "effects": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "Summons a wolf companion who chases and bites enemies, dealing 5 damage per bite."
            }
          ]
        }
      ],
      "notes": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "Wolf can damage "
            },
            {
              "t": "ref",
              "v": "High Priest",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": " and "
            },
            {
              "t": "ref",
              "v": "Cannonbalrog",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": " during their invulnerable attacks."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Wolf will not cross pits to attack."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Wolf cannot damage phase 2 of the "
            },
            {
              "t": "ref",
              "v": "Resourceful Rat",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": "; however, he can trigger  "
            },
            {
              "t": "synref",
              "v": "The Red Hood"
            },
            {
              "t": "text",
              "v": "'s effect."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Wolf cannot damage the "
            },
            {
              "t": "ref",
              "v": "Wallmonger",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": "."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Wolf cannot damage "
            },
            {
              "t": "ref",
              "v": "High Dragun",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": "."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Riding a mine cart counts as standing still for the  "
            },
            {
              "t": "synref",
              "v": "Sniper Woof"
            },
            {
              "t": "text",
              "v": " synergy."
            }
          ]
        }
      ],
      "trivia": [
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "ref",
              "v": "Unused and Cut Content/Synergies",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": " - ("
            },
            {
              "t": "text",
              "v": "CustomSynergyType.DOG_AND_WOLF",
              "style": "code"
            },
            {
              "t": "text",
              "v": ") If the player has "
            },
            {
              "t": "ref",
              "v": "Dog",
              "kind": "item"
            },
            {
              "t": "text",
              "v": ", it spawns smaller puppy versions of the two companions that follow the player.These puppies have no effect."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "This is a reference to "
            },
            {
              "t": "ext",
              "v": "Hachikō",
              "url": "https://en.wikipedia.org/wiki/Hachik%C5%8D"
            },
            {
              "t": "text",
              "v": ", an "
            },
            {
              "t": "ext",
              "v": "Akita",
              "url": "https://en.wikipedia.org/wiki/Akita_(dog)"
            },
            {
              "t": "text",
              "v": " dog remembered for his remarkable loyalty to his owner which continued for ten years after his owner's death."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "This also mirrors the Futurama episode Jurassic Bark in a number of ways. The episode in question "
            },
            {
              "t": "text",
              "v": "also",
              "style": "i"
            },
            {
              "t": "text",
              "v": " features a loyal dog whose owner was trapped in a cryogenic freezing pod for a thousand years."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The handkerchief item icon is a reference to the "
            },
            {
              "t": "ext",
              "v": "Metal Gear Solid",
              "url": "https://en.wikipedia.org/wiki/Metal_Gear_Solid"
            },
            {
              "t": "text",
              "v": " series. It is the same handkerchief given to Solid Snake by Otacon during his prison escape. It originally belonged to the female sniper character Sniper Wolf.\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "The synergy with the various rifles alludes to Sniper Wolf's position as a sniper."
                }
              ]
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "In "
            },
            {
              "t": "ref",
              "v": "Exit the Gungeon",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": " Wolf can pick up money and powerups, but will not pathfind to them. Instead, he will pathfind to enemies."
            }
          ]
        }
      ]
    }
  },
  {
    "name": "Dog",
    "icon": "https://static.wikia.nocookie.net/enterthegungeon_gamepedia/images/3/35/Dog.png",
    "type": "Passive",
    "quote": "Junior II",
    "quality": "D",
    "effect": "Follows the player around, occasionally digs up a pickup upon completing a room, and barks at mimic chests.",
    "curse": 0.0,
    "coolness": 0.0,
    "wiki": {
      "effects": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "Summons a dog companion who follows the player around.\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "Has a 5% chance to dig up a "
                },
                {
                  "t": "ref",
                  "v": "Pickups",
                  "kind": "unresolved"
                },
                {
                  "t": "text",
                  "v": " upon completing a room."
                }
              ]
            },
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "Identifies chest "
                },
                {
                  "t": "ref",
                  "v": "Mimic",
                  "kind": "lore"
                },
                {
                  "t": "text",
                  "v": " by barking.\n"
                }
              ],
              "sub": [
                {
                  "tokens": [
                    {
                      "t": "text",
                      "v": "Dog will not bark at Pedestal Mimics or Wall Mimics."
                    }
                  ]
                }
              ]
            },
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "The player can pet the dog by interacting with him."
                }
              ]
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Summons a dog companion that will fly around the screen in a jetpack.\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "The dog will go after any pickups on screen and collects them for the player. This includes casings, blanks, armor, hearts, Hegemony credits, and "
                },
                {
                  "t": "ref",
                  "v": "Powerups",
                  "kind": "unresolved"
                },
                {
                  "t": "text",
                  "v": "."
                }
              ]
            },
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "The player can pet the dog by interacting with him while he is not chasing down items."
                }
              ]
            }
          ]
        }
      ],
      "notes": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "Cannot be dropped when playing as The Hunter."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The dog cannot be interacted with if the player is currently in combat."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "If the player has flight, they can still interact with the dog but there will be no petting animation."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "If the player is playing as "
            },
            {
              "t": "ref",
              "v": "The Marine",
              "kind": "character"
            },
            {
              "t": "text",
              "v": " and they lose his helmet, he will have no more petting animation, but he'll still be able to interact with the Dog."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Most Gungeoneers smile when petting the Dog, with the exception of "
            },
            {
              "t": "ref",
              "v": "The Robot",
              "kind": "character"
            },
            {
              "t": "text",
              "v": ", whose monitor displays a heart, and "
            },
            {
              "t": "ref",
              "v": "The Pilot",
              "kind": "character"
            },
            {
              "t": "text",
              "v": " and "
            },
            {
              "t": "ref",
              "v": "The Bullet",
              "kind": "character"
            },
            {
              "t": "text",
              "v": ", with both remaining serious during the animation. The reason is unknown."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "ref",
              "v": "The Convict",
              "kind": "character"
            },
            {
              "t": "text",
              "v": "'s petting animation is slower than the other characters.  This doesn't happen when using her alternate costume."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "ref",
              "v": "The Gunslinger",
              "kind": "character"
            },
            {
              "t": "text",
              "v": " will not smile while petting the dog as he is expressionless."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The dog can dodge-roll across pits."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "If the player has "
            },
            {
              "t": "ref",
              "v": "Baby Good Mimic",
              "kind": "item"
            },
            {
              "t": "text",
              "v": " and it transforms into the dog, each individual Dog will have a chance to find an item, both will play the digging animation if one finds an item, and both can be pet if interacted with."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The ability to pet the dog was added in the "
            },
            {
              "t": "ref",
              "v": "Farewell to Arms",
              "kind": "unresolved"
            },
            {
              "t": "text",
              "v": " Update, in direct response to a post from twitter account "
            },
            {
              "t": "ext",
              "v": "@CanYouPetTheDog",
              "url": "https://x.com/CanYouPetTheDog"
            },
            {
              "t": "text",
              "v": ", calling out "
            },
            {
              "t": "text",
              "v": "Enter the Gungeon",
              "style": "i"
            },
            {
              "t": "text",
              "v": " for containing a non-pettable dog. According to "
            },
            {
              "t": "ref",
              "v": "Dodge Roll",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": " designer "
            },
            {
              "t": "ref",
              "v": "Dave Crooks",
              "kind": "unresolved"
            },
            {
              "t": "text",
              "v": ", while the idea of making the dog pettable had come up before in development, it was the intervention of @CanYouPetTheDog that spurred the change."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The Dog's name implies that the Hunter got him as a replacement for her Wolf, Junior."
            }
          ]
        }
      ]
    }
  },
  {
    "name": "Owl",
    "icon": "https://static.wikia.nocookie.net/enterthegungeon_gamepedia/images/5/5c/Owl.png",
    "type": "Passive",
    "quote": "Hoots And More",
    "quality": "1S",
    "effect": "Follows the player, firing bullets at enemies and occasionally using short-ranged blanks.",
    "curse": 0.0,
    "coolness": 0.0,
    "wiki": {
      "effects": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "Follows the player, occasionally activating a short-ranged blank while bullets are near the player or shooting a random enemy."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Blocks enemy bullets."
            }
          ]
        }
      ],
      "notes": [
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "synref",
              "v": "Don't Hoot the Messenger"
            },
            {
              "t": "text",
              "v": " - If the player also has "
            },
            {
              "t": "ref",
              "v": "Dungeon Eagle",
              "kind": "gun"
            },
            {
              "t": "text",
              "v": ", halves time required to fire a charged shot with the Dungeon Eagle."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "synref",
              "v": "Special Delivery"
            },
            {
              "t": "text",
              "v": " - If the player has "
            },
            {
              "t": "ref",
              "v": "Bundle of Wands",
              "kind": "gun"
            },
            {
              "t": "text",
              "v": ", "
            },
            {
              "t": "ref",
              "v": "Witch Pistol",
              "kind": "gun"
            },
            {
              "t": "text",
              "v": ", "
            },
            {
              "t": "ref",
              "v": "Hexagun",
              "kind": "gun"
            },
            {
              "t": "text",
              "v": ", or "
            },
            {
              "t": "ref",
              "v": "Staff of Firepower",
              "kind": "gun"
            },
            {
              "t": "text",
              "v": ", the gun's and Owl's shots bounce, and Owl turns skeletal and fires letters at enemies.\n"
            }
          ],
          "sub": [
            {
              "tokens": []
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "synref",
              "v": "The Elephant in the Room"
            },
            {
              "t": "text",
              "v": " - If the player has "
            },
            {
              "t": "ref",
              "v": "Elephant Gun",
              "kind": "gun"
            },
            {
              "t": "text",
              "v": ", it becomes an elephant head and shoots elephants instead of bullets."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The Owl's blanks will trigger the effects of the Ammolets ("
            },
            {
              "t": "ref",
              "v": "Chaos Ammolet",
              "kind": "item"
            },
            {
              "t": "text",
              "v": ", "
            },
            {
              "t": "ref",
              "v": "Uranium Ammolet",
              "kind": "item"
            },
            {
              "t": "text",
              "v": ", "
            },
            {
              "t": "ref",
              "v": "Copper Ammolet",
              "kind": "item"
            },
            {
              "t": "text",
              "v": ", "
            },
            {
              "t": "ref",
              "v": "Lodestone Ammolet",
              "kind": "item"
            },
            {
              "t": "text",
              "v": ", "
            },
            {
              "t": "ref",
              "v": "Gold Ammolet",
              "kind": "item"
            },
            {
              "t": "text",
              "v": " and "
            },
            {
              "t": "ref",
              "v": "Frost Ammolet",
              "kind": "item"
            },
            {
              "t": "text",
              "v": "), affecting enemies in the entire room just like a normal blank would."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The Owl's blanks will not open up pathways to "
            },
            {
              "t": "ref",
              "v": "Secret Rooms",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": "."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Owl's bullets are affected by all bullet modifiers."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "If duplicates of this item are somehow obtained, further summons more owl allies.\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "Owls will create a single file line behind each other and follow owls that are in front of them (while trying to position themselves in a line)."
                }
              ]
            },
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "This will cause a problem to the player, as the line of owls can extend into walls and aren't near the player to provide any assistance with their effect. This can be prevented by having the player continuously walk in circles to manipulate the owls orbiting closer to the player."
                }
              ]
            }
          ]
        }
      ],
      "trivia": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "The Owl's \"Special Delivery\" synergy is a reference to Hedwig, the snowy owl that accompanies Harry in the Harry Potter book series."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The Owl is also a reference to the OWL Drone in Killzone: Shadow Fall in which the drone attacks enemies and protects the player on his command."
            }
          ]
        }
      ]
    }
  },
  {
    "name": "Super Space Turtle",
    "icon": "https://static.wikia.nocookie.net/enterthegungeon_gamepedia/images/8/8f/Super_Space_Turtle.png",
    "type": "Passive",
    "quote": "Hero From Space",
    "quality": "B",
    "effect": "Follows the player, firing bullets at enemies.",
    "curse": 0.0,
    "coolness": 0.0,
    "wiki": {
      "effects": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "Summons Super Space Turtle to the players side to aid them in combat.\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": " Super Space Turtle will run towards enemies, firing bullets that deal 5 damage each."
                }
              ]
            },
            {
              "tokens": [
                {
                  "t": "text",
                  "v": " Super Space Turtle will fly towards enemies with the aid of a jetpack, firing at them."
                }
              ]
            }
          ]
        }
      ],
      "notes": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "The turtle's bullets are affected by bullet modifiers such as "
            },
            {
              "t": "ref",
              "v": "Cursed Bullets",
              "kind": "item"
            },
            {
              "t": "text",
              "v": " and "
            },
            {
              "t": "ref",
              "v": "Helix Bullets",
              "kind": "item"
            },
            {
              "t": "text",
              "v": ".\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "ref",
                  "v": "Shock Rounds",
                  "kind": "item"
                },
                {
                  "t": "text",
                  "v": " will create a link of electricity between the turtle's bullets and the player's bullets."
                }
              ]
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The turtle will not attack a "
            },
            {
              "t": "ref",
              "v": "Mimic",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": " without the player first interacting with the Mimic."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The turtle will not attack any of the multiple bells the "
            },
            {
              "t": "ref",
              "v": "Mine Flayer",
              "kind": "unresolved"
            },
            {
              "t": "text",
              "v": " boss spawns."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "If the player has a bullet modifier such as "
            },
            {
              "t": "ref",
              "v": "Irradiated Lead",
              "kind": "item"
            },
            {
              "t": "text",
              "v": ", Super Space Turtle's chances of firing an affected shot depend on the gun the player is holding.\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "For example, with "
                },
                {
                  "t": "ref",
                  "v": "RPG",
                  "kind": "gun"
                },
                {
                  "t": "text",
                  "v": ", the shot is guaranteed to poison, while with a shotgun it has less chance to."
                }
              ]
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The turtle can attack "
            },
            {
              "t": "ref",
              "v": "Gunjurer",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": " while they charge up their circle without the bullets being absorbed, making them able to kill the Gunjurer at any time."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "If the player is in stealth mode, Super Space Turtle will wear a detective outfit."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The turtle's bullets count as the player's as far as the "
            },
            {
              "t": "ref",
              "v": "Turkey",
              "kind": "item"
            },
            {
              "t": "text",
              "v": " is concerned, allowing you to get free ammo by simply sitting back and letting the turtle attack enemies."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The turtle's bullets can be multiplied by the Y.V. shrine's pop effect."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Defeating the "
            },
            {
              "t": "ref",
              "v": "High Dragun",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": " with Super Space Turtle will unlock "
            },
            {
              "t": "ref",
              "v": "Turtle Problem",
              "kind": "item"
            },
            {
              "t": "text",
              "v": "."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The  "
            },
            {
              "t": "synref",
              "v": "Super Space Turtle DX"
            },
            {
              "t": "text",
              "v": " synergy makes the Super Space Turtle's gun into the unused "
            },
            {
              "t": "ref",
              "v": "Turtine Gun",
              "kind": "unresolved"
            },
            {
              "t": "text",
              "v": "."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The turtle will attack Red-caped Bullet Kin, so watch out, as they are very rare. The most effective way to prevent this is to drop the item in the room that the Bullet Kin is in to prevent the turtle from attacking it."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": " Bug The  "
            },
            {
              "t": "synref",
              "v": "Super Space Turtle DX"
            },
            {
              "t": "text",
              "v": " synergy has the unintentional side-effect of reducing Super Space Turtle's maximum health "
            },
            {
              "t": "text",
              "v": "significantly",
              "style": "i"
            },
            {
              "t": "text",
              "v": ". This makes it possible to accidentally kill him via explosions or other indirect means like the  "
            },
            {
              "t": "ref",
              "v": "Black Hole Gun",
              "kind": "gun"
            },
            {
              "t": "text",
              "v": ". If Super Space Turtle dies in this manner, he can be re-summoned by dropping the item and picking it back up."
            }
          ]
        }
      ],
      "trivia": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "The Ammonomicon entry refers to the unused gun also called "
            },
            {
              "t": "ref",
              "v": "Super Space Turtle (Gun)",
              "kind": "unresolved"
            },
            {
              "t": "text",
              "v": "."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The Elephant in the Room synergy may be a reference to Discworld's setting, in which four elephants carry the world atop a colossal space turtle."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The limitation of 4 Super Space Turtles with the  "
            },
            {
              "t": "synref",
              "v": "Turtle Solutions"
            },
            {
              "t": "text",
              "v": " synergy may be a reference to the Teenage Mutant Ninja Turtles, who are a group of four."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The Super Space Turtle's \"Detective Outfit\" disguise when the player is stealthed is, likewise, a reference to the Teenage Mutant Ninja Turtles, who typically wear fedoras and long trenchcoats when wandering in public, to avoid being identified as non-humans."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "\"Space Turtle\" itself is likely reference to the Gamera movie franchise. A Japanese Kaiju series about a huge turtle monster defending Earth from evil invading creatures. Very similar to the Godzilla franchise."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The  "
            },
            {
              "t": "synref",
              "v": "Super Space Turtle DX"
            },
            {
              "t": "text",
              "v": " synergy is likely a reference to Super Mario Bros. Deluxe, released for the Nintendo GameBoy Color system."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "If the player opens a door to a new room without triggering enemies to start attacking, the turtle is able to fire at, and kill, enemies without them being able to attack the player."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The Super Space Turtle is nearly identical to the very first playable character in the Enter The Gungeon demo."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The Super Space Turtle wields the "
            },
            {
              "t": "ref",
              "v": "Heck Blaster",
              "kind": "gun"
            },
            {
              "t": "text",
              "v": " weapon, though this is only visual."
            }
          ]
        },
        {
          "tokens": []
        }
      ]
    }
  },
  {
    "name": "Junk",
    "icon": "https://static.wikia.nocookie.net/enterthegungeon_gamepedia/images/f/fd/Junk.png",
    "type": "Passive",
    "quote": "Next Time Use A Key",
    "quality": "N",
    "effect": "Has no effect on its own. Often spawned by destroying chests.",
    "curse": 0.0,
    "coolness": 0.0,
    "wiki": {
      "effects": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "Junk has no inherent effect, however it does interact with some other systems and items.\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "When playing as "
                },
                {
                  "t": "ref",
                  "v": "The Robot",
                  "kind": "character"
                },
                {
                  "t": "text",
                  "v": ", each piece of Junk increases damage by a permanent additive 5%. The damage increase persists no matter what happens to the Junk."
                }
              ]
            },
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "If the player has  "
                },
                {
                  "t": "ref",
                  "v": "Ser Junkan",
                  "kind": "lore"
                },
                {
                  "t": "text",
                  "v": ", collecting Junk levels him up, making him more powerful."
                }
              ]
            }
          ]
        }
      ],
      "notes": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "Junk has a "
            },
            {
              "t": "ref",
              "v": "Chests",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": " of 0.45.\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "If the player is in possession of "
                },
                {
                  "t": "ref",
                  "v": "Ser Junkan",
                  "kind": "lore"
                },
                {
                  "t": "text",
                  "v": ", the chest destruction loot weight of junk is multiplied by 1.5."
                }
              ]
            },
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "If the player is in possession of at least one key, the chest destruction loot weight of junk is multiplied by 3."
                }
              ]
            },
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "The loot weight increases given by keys and Ser Junkan stack with one another."
                }
              ]
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "4 Junk is used to unlock the "
            },
            {
              "t": "ref",
              "v": "Hollow",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": "'s "
            },
            {
              "t": "ref",
              "v": "Shortcuts",
              "kind": "unresolved"
            },
            {
              "t": "text",
              "v": ".\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "ref",
                  "v": "Ser Junkan",
                  "kind": "lore"
                },
                {
                  "t": "text",
                  "v": " won't be accepted by the "
                },
                {
                  "t": "ref",
                  "v": "Tinker",
                  "kind": "unresolved"
                },
                {
                  "t": "text",
                  "v": "."
                }
              ]
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "If "
            },
            {
              "t": "ref",
              "v": "Ser Junkan",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": " has not been unlocked, he has a 20% chance to replace normal Junk.\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "If he has been unlocked, the chance to replace normal junk decreases to 1%."
                }
              ]
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "If the player has "
            },
            {
              "t": "ref",
              "v": "Ser Junkan",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": " the flavor text when picking Junk up changes to 'Knight in shining armor'. Each additional piece of junk changes the text."
            }
          ]
        }
      ]
    }
  },
