  {
    "name": "Sunglasses",
    "icon": "https://static.wikia.nocookie.net/enterthegungeon_gamepedia/images/9/92/Sunglasses.png",
    "type": "Passive",
    "quote": "Bright Future",
    "quality": "C",
    "effect": "Slows down time and increases dodge power during explosions. Increases coolness by 2.",
    "curse": 0.0,
    "coolness": 2.0,
    "wiki": {
      "effects": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "Slows down time by 55% and increases "
            },
            {
              "t": "ref",
              "v": "Dodge Roll (Move)",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": " distance and speed by 25% for 2 seconds after an explosion.\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "This effect has a 10 second cooldown, meaning it cannot be permanently activated by chained explosives."
                }
              ]
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Increases "
            },
            {
              "t": "ref",
              "v": "Coolness",
              "kind": "stat"
            },
            {
              "t": "text",
              "v": " by 2."
            }
          ]
        }
      ],
      "notes": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "This item is a reference to the "
            },
            {
              "t": "ext",
              "v": "unflinching walk",
              "url": "https://tvtropes.org/pmwiki/pmwiki.php/Main/UnflinchingWalk"
            },
            {
              "t": "text",
              "v": ", a movie cliché popularized by action flicks where a \"cool\" character (sometimes wearing sunglasses) walks in slow motion as explosions go off behind them. Online, this is a more commonly known as the "
            },
            {
              "t": "ext",
              "v": "\"cool guys don't look at explosions\"",
              "url": "https://www.youtube.com/watch?v=Sqz5dbs5zmo"
            },
            {
              "t": "text",
              "v": " meme, popularized by a song by comedy music group "
            },
            {
              "t": "text",
              "v": "The Lonely Island",
              "style": "i"
            },
            {
              "t": "text",
              "v": "."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "In terms of design, the sunglasses closely resemble those of "
            },
            {
              "t": "ext",
              "v": "Horatio Caine",
              "url": "https://en.wikipedia.org/wiki/Horatio_Caine"
            },
            {
              "t": "text",
              "v": ", the protagonist of "
            },
            {
              "t": "text",
              "v": "CSI: Miami",
              "style": "i"
            },
            {
              "t": "text",
              "v": " who is well known for slowly putting on similar shades when announcing a one-liner based on the episode's plot."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The "
            },
            {
              "t": "ref",
              "v": "Ammonomicon",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": " quote "
            },
            {
              "t": "text",
              "v": "\"Bright Future\"",
              "style": "i"
            },
            {
              "t": "text",
              "v": " is a reference to the song "
            },
            {
              "t": "ext",
              "v": "The Future's So Bright, I Gotta Wear Shades",
              "url": "https://youtu.be/8qrriKcwvlY"
            },
            {
              "t": "text",
              "v": " by "
            },
            {
              "t": "text",
              "v": "Timbuk 3",
              "style": "i"
            },
            {
              "t": "text",
              "v": "."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "ref",
              "v": "Dodge Roll",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": " programmer "
            },
            {
              "t": "ref",
              "v": "Brent Sodman",
              "kind": "unresolved"
            },
            {
              "t": "text",
              "v": " has semi-seriously expressed regret at not calling Sunglasses "
            },
            {
              "t": "text",
              "v": "\"Gunglasses\"",
              "style": "i"
            },
            {
              "t": "text",
              "v": "."
            }
          ]
        }
      ]
    }
  },
  {
    "name": "Mimic Tooth Necklace",
    "icon": "https://static.wikia.nocookie.net/enterthegungeon_gamepedia/images/5/5f/Mimic_Tooth_Necklace.png",
    "type": "Passive",
    "quote": "Chomp",
    "quality": "A",
    "effect": "Every chest is guaranteed to be a Mimic .",
    "curse": 0.0,
    "coolness": 0.0,
    "wiki": {
      "effects": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "All "
            },
            {
              "t": "ref",
              "v": "Chests",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": " (with the exception of "
            },
            {
              "t": "ref",
              "v": "Rat chest",
              "kind": "unresolved"
            },
            {
              "t": "text",
              "v": ", and chests that have no corresponding mimic type) are unlocked, and become "
            },
            {
              "t": "ref",
              "v": "Mimic",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": ".\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "This includes chests spawned before the necklace was picked up."
                }
              ]
            },
            {
              "tokens": [
                {
                  "t": "text",
                  "v": " Possible Bug Has an inverse effect on "
                },
                {
                  "t": "ref",
                  "v": "Rat chest",
                  "kind": "unresolved"
                },
                {
                  "t": "text",
                  "v": ", forcing them "
                },
                {
                  "t": "text",
                  "v": "not",
                  "style": "i"
                },
                {
                  "t": "text",
                  "v": " to be "
                },
                {
                  "t": "ref",
                  "v": "Mimic",
                  "kind": "lore"
                },
                {
                  "t": "text",
                  "v": "."
                }
              ]
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "All random item pedestals (except for those spawned after the "
            },
            {
              "t": "ref",
              "v": "Wallmonger",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": " is defeated) become "
            },
            {
              "t": "ref",
              "v": "Pedestal Mimic",
              "kind": "unresolved"
            },
            {
              "t": "text",
              "v": ", effectively doubling the boss reward.\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "Only pedestals containing random loot are affected. Pedestals containing "
                },
                {
                  "t": "ref",
                  "v": "Master Round I",
                  "kind": "item"
                },
                {
                  "t": "text",
                  "v": " or the "
                },
                {
                  "t": "ref",
                  "v": "Old Crest",
                  "kind": "item"
                },
                {
                  "t": "text",
                  "v": " cannot be affected."
                }
              ]
            },
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "The golden pedestals in the room after the "
                },
                {
                  "t": "ref",
                  "v": "Resourceful Rat (Boss)",
                  "kind": "unresolved"
                },
                {
                  "t": "text",
                  "v": " bossfight are unaffected."
                }
              ]
            },
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "Item pedestals spawned after the defeat of the "
                },
                {
                  "t": "ref",
                  "v": "Glitched Beholsters",
                  "kind": "unresolved"
                },
                {
                  "t": "text",
                  "v": " have a 50% chance of being Pedestal Mimics. This chance is "
                },
                {
                  "t": "text",
                  "v": "not affected",
                  "style": "i"
                },
                {
                  "t": "text",
                  "v": " in any way by Mimic Tooth Necklace."
                }
              ]
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Causes a "
            },
            {
              "t": "ref",
              "v": "Union Mimic",
              "kind": "unresolved"
            },
            {
              "t": "text",
              "v": " to appear in the room after the "
            },
            {
              "t": "ref",
              "v": "Resourceful Rat (Boss)",
              "kind": "unresolved"
            },
            {
              "t": "text",
              "v": " bossfight to apologise for the aforementioned inability of the Mimic Tooth Necklace to turn "
            },
            {
              "t": "ref",
              "v": "Rat Chest",
              "kind": "unresolved"
            },
            {
              "t": "text",
              "v": " into mimics."
            }
          ]
        }
      ],
      "item_interactions": [
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "ref",
              "v": "Ring of Mimic Friendship",
              "kind": "item"
            },
            {
              "t": "text",
              "v": " - All "
            },
            {
              "t": "ref",
              "v": "Chests",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": " (except for Rat Chests) will be unlocked, but will "
            },
            {
              "t": "text",
              "v": "not",
              "style": "i"
            },
            {
              "t": "text",
              "v": " be "
            },
            {
              "t": "ref",
              "v": "Mimics",
              "kind": "unresolved"
            },
            {
              "t": "text",
              "v": "."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "ref",
              "v": "Trusty Lockpicks",
              "kind": "item"
            },
            {
              "t": "text",
              "v": " - Picking up Mimic Tooth Necklace will unlock any chests rendered unopenable by Trusty Lockpicks, and convert them into mimics. These broken-locked mimics cannot be interacted with, but can still be shot to awaken them. They will drop their item on death like normal."
            }
          ]
        }
      ],
      "notes": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "Has no interaction with "
            },
            {
              "t": "ref",
              "v": "Wall Mimic",
              "kind": "unresolved"
            },
            {
              "t": "text",
              "v": ", "
            },
            {
              "t": "ref",
              "v": "Door Lord",
              "kind": "unresolved"
            },
            {
              "t": "text",
              "v": ", or the  "
            },
            {
              "t": "ref",
              "v": "Mimic Gun",
              "kind": "unresolved"
            },
            {
              "t": "text",
              "v": ", despite them being mimics."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "This item makes  "
            },
            {
              "t": "ref",
              "v": "Junk",
              "kind": "item"
            },
            {
              "t": "text",
              "v": " significantly more difficult to acquire, as it is acquired from breaking non-mimic chests."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Does not affect the chest spawned by "
            },
            {
              "t": "ref",
              "v": "Winchester (NPC)",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": "'s minigame, rainbow chests, synergy chests, or glitch chests."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Chests in "
            },
            {
              "t": "ref",
              "v": "Mirror",
              "kind": "unresolved"
            },
            {
              "t": "text",
              "v": " will also become mimics."
            }
          ]
        }
      ]
    }
  },
  {
    "name": "Escape Rope",
    "icon": "https://static.wikia.nocookie.net/enterthegungeon_gamepedia/images/e/e2/Escape_Rope.png",
    "type": "Active",
    "quote": "Works Anywhere!",
    "quality": "D",
    "effect": "Teleport out of the current room into the shop of the current floor.",
    "curse": 0.0,
    "coolness": 0.0,
    "wiki": {
      "effects": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "Upon use, teleports the player into the "
            },
            {
              "t": "ref",
              "v": "Shop",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": ", resetting the current room if they are in an uncleared combat room.\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "In the "
                },
                {
                  "t": "ref",
                  "v": "R&G Dept",
                  "kind": "unresolved"
                },
                {
                  "t": "text",
                  "v": " and "
                },
                {
                  "t": "ref",
                  "v": "Bullet Hell",
                  "kind": "lore"
                },
                {
                  "t": "text",
                  "v": ", which do not have shops, the player is teleported to the first room of the chamber."
                }
              ]
            },
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "Cannot be used in the "
                },
                {
                  "t": "ref",
                  "v": "Resourceful Rat's Lair",
                  "kind": "lore"
                },
                {
                  "t": "text",
                  "v": "."
                }
              ]
            },
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "Can teleport the player to other "
                },
                {
                  "t": "ref",
                  "v": "Merchants",
                  "kind": "unresolved"
                },
                {
                  "t": "text",
                  "v": ", if they are present on the floor."
                }
              ]
            }
          ]
        }
      ],
      "notes": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "Teleporting out of a "
            },
            {
              "t": "ref",
              "v": "Boss",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": " room will return the boss to full health when the player re-enters.\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "If the player takes damage to a boss and uses the Escape Rope to teleport out, they "
                },
                {
                  "t": "text",
                  "v": "cannot",
                  "style": "i"
                },
                {
                  "t": "text",
                  "v": " earn a "
                },
                {
                  "t": "ref",
                  "v": "Master Round I",
                  "kind": "item"
                },
                {
                  "t": "text",
                  "v": " even if they take no damage on subsequent attempts at the boss."
                }
              ]
            },
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "Resetting a boss with the Escape Rope results in the re-encounter with the boss having an independent chance of being "
                },
                {
                  "t": "ref",
                  "v": "Jammed",
                  "kind": "lore"
                },
                {
                  "t": "text",
                  "v": ". For example, a non-jammed boss may be jammed on a subsequent visit, and a jammed boss may be non-jammed on a subsequent visit."
                }
              ]
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "When used to escape a room in "
            },
            {
              "t": "ref",
              "v": "Challenge Mode",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": ", the room will have different modifiers when re-entered.\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "The number of modifiers, however, will still stay the same. For example, if you leave a 2-modifier room with the Escape Rope and come back to it, there will be 2 new modifiers in place of the old ones."
                }
              ]
            },
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "The \"Hammer Time\" modifier is unaffected by this, leading to the "
                },
                {
                  "t": "ref",
                  "v": "Dead Blow",
                  "kind": "unresolved"
                },
                {
                  "t": "text",
                  "v": " from the previous set of modifiers still being present despite it not being listed. It is therefore not advised to use Escape Rope in a room with it present, as coming back to the room will essentially add an additional modifier. This is also the case with the "
                },
                {
                  "t": "ref",
                  "v": "Teleporter Prototype",
                  "kind": "item"
                },
                {
                  "t": "text",
                  "v": "."
                }
              ]
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Prior to the "
            },
            {
              "t": "ref",
              "v": "A Farewell to Arms Update",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": ", Escape Rope was a  tier item."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "This item is a reference to the "
            },
            {
              "t": "ext",
              "v": "item of the same name",
              "url": "https://bulbapedia.bulbagarden.net/wiki/Escape_Rope"
            },
            {
              "t": "text",
              "v": " and similar effect in the "
            },
            {
              "t": "text",
              "v": "Pokémon",
              "style": "i"
            },
            {
              "t": "text",
              "v": " franchise.\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "The  "
                },
                {
                  "t": "synref",
                  "v": "Hydro Pump"
                },
                {
                  "t": "text",
                  "v": " synergy is a reference to the water-type move "
                },
                {
                  "t": "ext",
                  "v": "Hydro Pump",
                  "url": "https://bulbapedia.bulbagarden.net/wiki/Hydro_Pump_(move)"
                },
                {
                  "t": "text",
                  "v": " seen in the "
                },
                {
                  "t": "text",
                  "v": "Pokémon",
                  "style": "i"
                },
                {
                  "t": "text",
                  "v": " franchise."
                }
              ]
            }
          ]
        }
      ]
    }
  },
  {
    "name": "Jetpack",
    "icon": "https://static.wikia.nocookie.net/enterthegungeon_gamepedia/images/0/07/Jetpack.png",
    "type": "Active",
    "quote": "To Fly",
    "quality": "C",
    "effect": "Can be toggled. While active, the player has increased movement speed and flight, but cannot dodge roll. Passing over puddles of oil will set them on fire.",
    "curse": 0.0,
    "coolness": 0.0,
    "wiki": {
      "effects": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "Use to toggle the jetpack on and off. While active, the players "
            },
            {
              "t": "ref",
              "v": "Movement Speed",
              "kind": "unresolved"
            },
            {
              "t": "text",
              "v": " is increased by 2.5 and the player gains flight, but cannot "
            },
            {
              "t": "ref",
              "v": "Dodge Roll (Move)",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": ".\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "Passing over pools of flammable "
                },
                {
                  "t": "ref",
                  "v": "Goop",
                  "kind": "lore"
                },
                {
                  "t": "text",
                  "v": " such as oil or "
                },
                {
                  "t": "ref",
                  "v": "Phaser Spider",
                  "kind": "unresolved"
                },
                {
                  "t": "text",
                  "v": " webs while the jetpack is active will set them on fire."
