                    {
                      "t": "ref",
                      "v": "Gnawed Key",
                      "kind": "unresolved"
                    }
                  ]
                }
              ]
            },
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "Increases "
                },
                {
                  "t": "ref",
                  "v": "Coolness",
                  "kind": "stat"
                },
                {
                  "t": "text",
                  "v": " by 2.\n"
                }
              ],
              "sub": [
                {
                  "tokens": [
                    {
                      "t": "text",
                      "v": "Dropping the Iron Coin loses this buff, but using it makes the +2 Coolness permanent."
                    }
                  ]
                }
              ]
            }
          ]
        }
      ],
      "notes": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "The player can get money from enemies killed in this way, but pickup drops will likely be stolen by the "
