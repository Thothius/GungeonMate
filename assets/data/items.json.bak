  {
    "name": "Lament Configurum",
    "icon": "https://static.wikia.nocookie.net/enterthegungeon_gamepedia/images/e/e8/Lament_Configurum.png",
    "type": "Active",
    "quote": "Shellraiser",
    "quality": "B",
    "effect": "Upon use, spawns several enemies and has a chance to spawn a gun or item (which has a chance to damage the character). Increases curse by 1 while held.",
    "curse": 1.0,
    "coolness": 0.0,
    "wiki": {
      "effects": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "Upon use, spawns 3 to 5 enemies. If opened, it will spawn a "
            },
            {
              "t": "ref",
              "v": "Guns",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": " or "
            },
            {
              "t": "ref",
              "v": "Items",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": ". The Lament Configurum must be used a certain number of times before it is successfully opened, and each time it spawns a gun or item, the number of uses it takes to open increases by 1. It always spawns rewards on the 2nd, 5th, 9th, 14th, 20th, etc. uses.\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "There is a 25% chance that it will damage the player upon spawning a gun or item.\n"
                }
              ],
              "sub": [
                {
                  "tokens": [
                    {
                      "t": "text",
                      "v": "Damage starts at one heart and increases by half a heart each time the player is damaged by the item."
                    }
                  ]
                }
              ]
            },
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "Items and guns spawned will increase  "
                },
                {
                  "t": "ref",
                  "v": "Curse",
                  "kind": "stat"
                },
                {
                  "t": "text",
                  "v": " by 1 when picked up."
                }
              ]
            },
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "Items and guns spawned will be , , or  quality."
                }
              ]
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Increases  "
            },
            {
              "t": "ref",
              "v": "Curse",
              "kind": "stat"
            },
            {
              "t": "text",
              "v": " by 1 while held."
