        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The "
            },
            {
              "t": "ref",
              "v": "Ammonomicon",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": " quote and entry of this item are a reference to the character \"The Pain\" from "
            },
            {
              "t": "ext",
              "v": "Metal Gear Solid 3",
              "url": "https://en.wikipedia.org/wiki/Metal_Gear_Solid_3"
            },
            {
              "t": "text",
              "v": " who uses bees to attack."
            }
          ]
        }
      ]
    }
  },
  {
    "name": "Potion of Lead Skin",
    "icon": "https://static.wikia.nocookie.net/enterthegungeon_gamepedia/images/b/bb/Potion_of_Lead_Skin.png",
    "type": "Active",
    "quote": "I'm Invincible!",
    "quality": "D",
    "effect": "While active, the player reflects enemy bullets.",
    "curse": 0.0,
    "coolness": 0.0,
    "wiki": {
      "effects": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "While active, the player turns gray, becoming invincible and reflecting bullets back at enemies.\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "Reflected bullets deal 10 damage."
                }
              ]
            },
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "Does not prevent damage from falling into pits."
                }
              ]
            }
          ]
        }
      ],
      "notes": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "This item is a reference to the classic Potion of Stoneskin from Dungeons and Dragons."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Both the tagline and the item's effect could be references to Metal Gear Rising's Sundowner, a boss who employs a shield to deflect the player's attacks while boasting of his invincibility."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The tagline could also be a reference to the James Bond movie Goldeneye, in which computer technician Boris Grishenko repeatedly yells, "
            },
            {
              "t": "ext",
              "v": "\"Yes! I am invincible!\"",
              "url": "https://www.youtube.com/watch?v=fXW02XmBGQw"
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The synergy  "
            },
            {
              "t": "synref",
              "v": "Terminated, Too"
            },
            {
              "t": "text",
              "v": " is a reference to the film "
            },
            {
              "t": "ext",
              "v": "Terminator 2: Judgment Day",
              "url": "https://en.wikipedia.org/wiki/Terminator_2:_Judgment_Day"
            },
            {
              "t": "text",
              "v": ", where the titular Terminator uses an M79 Grenade Launcher."
            }
          ]
        }
      ]
    }
  },
