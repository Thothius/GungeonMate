            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Chaff Grenade can be found multiple times in a single run, and will grant 3 uses each time it is picked up."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "It can still be sold for its full sell price at 2 or 1 uses left."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "This item is a reference to a weapon of the same name often found in the "
            },
            {
              "t": "ext",
              "v": "Metal Gear Solid",
              "url": "https://en.wikipedia.org/wiki/Metal_Gear_Solid"
