  {
    "name": "Amulet of the Pit Lord",
    "icon": "https://static.wikia.nocookie.net/enterthegungeon_gamepedia/images/3/3a/Amulet_of_the_Pit_Lord.png",
    "type": "Passive",
    "quote": "No Fall Damage",
    "quality": "D",
    "effect": "Falling into pits no longer deals damage.",
    "curse": 0.0,
    "coolness": 0.0,
    "wiki": {
      "effects": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "Falling into "
            },
            {
              "t": "ref",
              "v": "Pit",
              "kind": "unresolved"
            },
            {
              "t": "text",
              "v": " no longer deals damage."
            }
          ]
        }
      ],
      "trivia": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "The item is a reference to a famous Magic the Gathering card \"Lord of the Pit.\"  The \"bargain\" referred to in this text refers to the card mechanic whereby you must sacrifice your other creatures to it or it will harm you.  It is also connected to the unlock method, the implication being that knocking enemies into the pits is sending them to the Pit Lord to be consumed."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The code for Amulet of the Pit Lord is stored in a class called 'RingOfPitFriendship', which may have been an in-development name/theme for the item."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Since the player will still go through the falling animation the item can be used to avoid other sources of damage for a brief time."
            }
          ]
        }
      ]
    }
  },
  {
