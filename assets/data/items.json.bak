  {
    "name": "Cloranthy Ring",
    "icon": "https://static.wikia.nocookie.net/enterthegungeon_gamepedia/images/7/75/Cloranthy_Ring.png",
    "type": "Passive",
    "quote": "Dodge Power Up",
    "quality": "C",
    "effect": "Greatly shortens the time at the end of a dodge roll where the player is vulnerable.",
    "curse": 0.0,
    "coolness": 0.0,
    "wiki": {
      "effects": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "Increases dodge roll speed by 15.8%."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Increases the amount of time during a dodge roll that the player is invulnerable."
            }
          ]
        }
      ],
      "item_interactions": [
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "synref",
              "v": "Hot Rolls"
            },
            {
              "t": "text",
              "v": " +  "
            },
            {
              "t": "ref",
              "v": "Bug Boots",
              "kind": "item"
            },
            {
              "t": "text",
              "v": " - The poison trail of Bug Boots takes priority, overriding the fire trails of the synergy."
            }
          ]
        }
      ],
      "notes": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "This item is a reference to a "
            },
            {
              "t": "ext",
              "v": "Dark Souls",
              "url": "https://en.wikipedia.org/wiki/Dark_Souls"
            },
            {
              "t": "text",
              "v": " item of the same name.\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "Like in Enter The Gungeon, dodge rolling in Dark Souls is a commonly used move to avoid enemy attacks.\n"
                }
              ],
              "sub": [
                {
                  "tokens": [
                    {
                      "t": "text",
                      "v": "In Dark Souls, this ring speeds up  stamina recovery. Stamina is used for rolling, as well as attacking and running."
                    }
                  ]
                },
                {
                  "tokens": [
                    {
                      "t": "text",
                      "v": "The effect of this ring actually bears closer resemblance to the Dark Wood Grain Ring in Dark Souls 1, which increases the i-frames of rolling and shortens the recovery frames."
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    }
  },
  {
    "name": "Ring of Chest Friendship",
    "icon": "https://static.wikia.nocookie.net/enterthegungeon_gamepedia/images/9/91/Ring_of_Chest_Friendship.png",
    "type": "Passive",
    "quote": "Chest Friends Forever",
    "quality": "B",
    "effect": "Increases the chance of finding chests.",
    "curse": 0.0,
    "coolness": 0.0,
    "wiki": {
      "effects": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "Increases the chance of finding rewards upon clearing rooms."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Increases the chance of finding a chest upon clearing a room by 50%."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Modifies the chances for chests spawned on room clear to be a specific quality;\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "Halves the likelihood of spawned chests being  tier."
                }
              ]
            },
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "Increases the likelihood of spawned chests being  or  tier respectively by a quarter of the original chance of getting a  tier chest, effectively reallocating the chances from brown chests to blue and green equally."
                }
              ]
            },
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "Has no effect on the likelihood of getting an  or  tier chest."
                }
              ]
            },
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "These changes are applied "
                },
                {
                  "t": "text",
                  "v": "before",
                  "style": "i"
                },
                {
                  "t": "text",
                  "v": " "
                },
                {
                  "t": "ref",
                  "v": "Magnificence",
                  "kind": "unresolved"
                },
                {
                  "t": "text",
                  "v": ", and as such the chest chances are still heavily subject to the magnificence stat."
                }
              ]
            }
          ]
        }
      ],
      "notes": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "If duplicates of this item are somehow obtained, they will "
            },
            {
              "t": "text",
              "v": "not",
              "style": "i"
            },
            {
              "t": "text",
              "v": " stack their effects."
            }
          ]
        }
      ]
    }
  },
  {
    "name": "Ring of Mimic Friendship",
    "icon": "https://static.wikia.nocookie.net/enterthegungeon_gamepedia/images/8/8b/Ring_of_Mimic_Friendship.png",
    "type": "Passive",
    "quote": "Unlikely Allies",
    "quality": "D",
    "effect": "Chests will not turn into Mimics .",
    "curse": 0.0,
    "coolness": 0.0,
    "wiki": {
      "effects": [
        {
          "tokens": [
            {
              "t": "ref",
              "v": "Mimic",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "ref",
              "v": "Chests",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": " will no longer attack the player, acting like regular chests."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Prevents "
            },
            {
              "t": "ref",
              "v": "Pedestal Mimic",
              "kind": "unresolved"
            },
            {
              "t": "text",
              "v": " from appearing."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Prevents "
            },
            {
              "t": "ref",
              "v": "Wall Mimic",
              "kind": "unresolved"
            },
            {
              "t": "text",
              "v": " from awakening."
            }
          ]
        }
      ],
      "item_interactions": [
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "ref",
              "v": "Mimic Tooth Necklace",
              "kind": "item"
            },
            {
              "t": "text",
              "v": " - All "
            },
            {
              "t": "ref",
              "v": "Chests",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": " (except for Rat Chests) will be unlocked, but will "
            },
            {
              "t": "text",
              "v": "not",
              "style": "i"
            },
            {
              "t": "text",
              "v": " be "
            },
            {
              "t": "ref",
              "v": "Mimics",
              "kind": "unresolved"
            },
            {
              "t": "text",
              "v": "."
            }
          ]
        }
      ],
      "notes": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "This item is most valuable to new and inexperienced players, to whom Mimics may pose a serious threat. For players experienced in fighting mimics, however, this item may even be considered negative as it prevents the player from obtaining free mimic loot."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Does "
            },
            {
              "t": "text",
              "v": "not",
              "style": "i"
            },
            {
              "t": "text",
              "v": " prevent "
            },
            {
              "t": "ref",
              "v": "Door Lord",
              "kind": "unresolved"
            },
            {
              "t": "text",
              "v": " from appearing, despite it technically being a "
            },
            {
              "t": "ref",
              "v": "Mimic",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": "."
            }
          ]
        }
      ]
    }
  },
  {
    "name": "Ring of Triggers",
    "icon": "https://static.wikia.nocookie.net/enterthegungeon_gamepedia/images/4/46/Ring_of_Triggers.png",
    "type": "Passive",
    "quote": "Items == Guns",
    "quality": "A",
    "effect": "Using an active item fires the currently held weapon in all directions.",
    "curse": 0.0,
    "coolness": 0.0,
    "wiki": {
      "effects": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "While using an active item, rapidly fires the currently held weapon in a counterclockwise ring. This does not consume ammo, nor does it require the held gun to have any ammo remaining.\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "The effect has a cooldown of about 10 seconds."
                }
              ]
            }
          ]
        }
      ],
      "notes": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "While not a synergy in the traditional sense, active items with no cooldown such as "
            },
            {
              "t": "ref",
              "v": "Sense of Direction",
              "kind": "item"
            },
            {
              "t": "text",
              "v": ", "
            },
            {
              "t": "ref",
              "v": "Jetpack",
              "kind": "item"
            },
            {
              "t": "text",
              "v": ", or "
            },
            {
              "t": "ref",
              "v": "iBomb Companion App",
              "kind": "item"
            },
            {
              "t": "text",
              "v": " are strongly recommended to maximize usage of this item's effect. However, because of the Ring of Triggers' independent cooldown, it can't be used all the time."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The player can also maximize the benefit of this item by using a gun or bullet modifier that allows the shots fired to bounce or be retargeted, such as "
            },
            {
              "t": "ref",
              "v": "Serious Cannon",
              "kind": "gun"
            },
            {
              "t": "text",
              "v": " or "
            },
            {
              "t": "ref",
              "v": "Remote Bullets",
              "kind": "item"
            },
            {
              "t": "text",
              "v": "."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The "
            },
            {
              "t": "ref",
              "v": "Shop",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": " does not count the ring's effect as firing in his shop, making it helpful for finding breakable walls in the shop."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "This item fires all the bullets a weapon can fire at once. For example, it fires all three of "
            },
            {
              "t": "ref",
              "v": "Polaris",
              "kind": "gun"
            },
            {
              "t": "text",
              "v": "'s levels at once and fires "
            },
            {
              "t": "ref",
              "v": "Blasphemy",
              "kind": "gun"
            },
            {
              "t": "text",
              "v": "'s sword beams even when not at full health."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "If two guns are "
            },
            {
              "t": "ref",
              "v": "Duct Tape",
              "kind": "item"
            },
            {
              "t": "text",
              "v": " together, Ring of Triggers will only fire bullets from the second gun."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "If the player dodge-rolls with the "
            },
            {
              "t": "ref",
              "v": "Macho Brace",
              "kind": "item"
            },
            {
              "t": "text",
              "v": " equipped, Ring of Triggers can fire several shots with its damage bonus."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Ring of Triggers' effect can shoot "
            },
            {
              "t": "ref",
              "v": "Makeshift Cannon",
              "kind": "gun"
            },
            {
              "t": "text",
              "v": "'s bullets in all directions, dealing high damage without consuming its ammo.\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "Active items could be recharged immediately due to the high damage."
                }
              ]
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "As shown in the image below, Ring of Triggers can be used to fire extra shots in "
            },
            {
              "t": "ref",
              "v": "Winchester (NPC)",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": "'s game, but the inaccuracy of its ability leaves its usefulness in question."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "If duplicates of this item are somehow obtained, it causes twice as many bullets to be fired for every use of the active item. However, the second set of bullets is stacked directly on top of the first, making it hard to see them in practice."
            }
          ]
        }
      ],
      "trivia": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "The mention of \"transgunstantiation\" in the Ammonomicon entry is a reference to the Roman Catholic belief in transubstantiation, the transformation of the Communion wafer and wine into the body and blood of Christ during the Eucharist ritual."
            }
          ]
        }
      ]
    }
  },
  {
    "name": "Ring of Ethereal Form",
    "icon": "https://static.wikia.nocookie.net/enterthegungeon_gamepedia/images/5/55/Ring_of_Ethereal_Form.png",
