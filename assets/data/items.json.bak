  {
    "name": "Battery Bullets",
    "icon": "https://static.wikia.nocookie.net/enterthegungeon_gamepedia/images/3/33/Battery_Bullets.png",
    "type": "Passive",
    "quote": "Zap!",
    "quality": "D",
    "effect": "Causes water that bullets pass over to become electrified, damaging enemies. Decreases shot spread by 50%.",
    "curse": 0.0,
    "coolness": 0.0,
    "wiki": {
      "effects": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "Causes water that bullets pass over to become electrified, damaging enemies."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Decreases shot spread by 50%, doubling accuracy."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Grants immunity to electrified water."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Gives a 1/100 chance to deal 1.25x more damage."
            }
          ]
        }
      ],
      "notes": [
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "ref",
              "v": "Unused and Cut Content",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": " - If the player has "
            },
            {
              "t": "ref",
              "v": "Shock Rifle",
              "kind": "gun"
            },
            {
              "t": "text",
              "v": ", shot speed is doubled. Likely removed because it includes a starting item."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Cannot be dropped when playing as The Robot."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Using items or guns that freeze water such as "
            },
            {
              "t": "ref",
              "v": "Frost Bullets",
              "kind": "item"
            },
            {
              "t": "text",
              "v": " and "
            },
            {
              "t": "ref",
              "v": "Ice Breaker",
              "kind": "gun"
            },
            {
              "t": "text",
              "v": " make this item much less useful, as ice cannot become electrified."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Prior to the "
            },
            {
              "t": "ref",
              "v": "Supply Drop Update",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": ", Battery Bullets did not increase accuracy."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Prior to the "
            },
            {
              "t": "ref",
              "v": "Advanced Gungeons & Draguns Update",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": ", the item did not grant immunity to electricity."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Weapons that shoot water will not be electrified unless shot with a normal weapon.\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "However, weapons that leave water puddles on impact, such as the "
                },
                {
                  "t": "ref",
                  "v": "Siren",
                  "kind": "gun"
                },
                {
                  "t": "text",
                  "v": ", can be used to electrify the water puddles by shooting over them."
                }
              ]
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Battery Bullets will not electrify the water in "
            },
            {
              "t": "ref",
              "v": "The Gorgun",
              "kind": "unresolved"
            },
            {
              "t": "text",
              "v": "'s arena."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Some enemies may be immune to electrified water like "
            },
            {
              "t": "ref",
              "v": "Beholster",
              "kind": "shrine"
            },
            {
              "t": "text",
              "v": "."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Grants immunity to the  "
            },
            {
              "t": "ref",
              "v": "Challenge Mode",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": " modifier's electricity links in "
            },
            {
              "t": "ref",
              "v": "Challenge Mode",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": ".\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "However the Bullets between the links will still damage the player."
                }
              ]
            }
          ]
        }
      ]
    }
  },
  {
    "name": "Frost Bullets",
    "icon": "https://static.wikia.nocookie.net/enterthegungeon_gamepedia/images/c/ce/Frost_Bullets.png",
    "type": "Passive",
    "quote": "Icy Fire",
    "quality": "A",
    "effect": "Adds a chance to fire bullets that freeze enemies.",
    "curse": 0.0,
    "coolness": 0.0,
    "wiki": {
      "effects": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "Adds a chance to fire light-blue bullets that freeze enemies.\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "The chance is higher for weapons with slower rates of fire."
                }
              ]
            }
          ]
        }
      ],
      "notes": [
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "synref",
              "v": "Added Effect - Ice"
            },
            {
              "t": "text",
              "v": " - If the player has "
            },
            {
              "t": "ref",
              "v": "Alpha Bullet",
              "kind": "item"
            },
            {
              "t": "text",
              "v": ", the first shot of each magazine is guaranteed to be an ice bullet."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "synref",
              "v": "Arctic Warfare"
            },
            {
              "t": "text",
              "v": " - If the player has "
            },
            {
              "t": "ref",
              "v": "A.W.P.",
              "kind": "gun"
            },
            {
              "t": "text",
              "v": ", it turns orange and white, deals 62.5% more damage, and its shots are guaranteed to freeze enemies."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "synref",
              "v": "Cold Ones"
            },
            {
              "t": "text",
              "v": " - If the player has "
            },
            {
              "t": "ref",
              "v": "Frost Ammolet",
              "kind": "item"
            },
            {
              "t": "text",
              "v": ", the chance to fire ice bullets is significantly increased."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "synref",
              "v": "Diamond Weapon"
            },
            {
              "t": "text",
              "v": " - If the player has "
            },
            {
              "t": "ref",
              "v": "Omega Bullets",
              "kind": "item"
            },
            {
              "t": "text",
              "v": ", the last shot of each magazine is guaranteed to be an ice shot."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "synref",
              "v": "Frosty the Bullet Tyrant"
            },
            {
              "t": "text",
              "v": " - If the player has "
            },
            {
              "t": "ref",
              "v": "Snowballer",
              "kind": "gun"
            },
            {
              "t": "text",
              "v": ", its shots increase in size and damage the further they travel."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "synref",
              "v": "Ice Beam"
            },
            {
              "t": "text",
              "v": " - If the player has "
            },
            {
              "t": "ref",
              "v": "Heroine",
              "kind": "gun"
            },
            {
              "t": "text",
              "v": ", enables Ice Beam mode, which fires a projectile that instantly freezes an enemy when fully charged. Modes can be switched by reloading the Heroine with a full magazine."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "synref",
              "v": "Ice To Meet You"
            },
            {
              "t": "text",
              "v": " - If the player has "
            },
            {
              "t": "ref",
              "v": "Heart of Ice",
              "kind": "item"
            },
            {
              "t": "text",
              "v": ", firing with any gun will periodically fire a Heart of Ice projectile that splits and bounces."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "synref",
              "v": "Willing To Sacrifice"
            },
            {
              "t": "text",
              "v": " - If the player has "
            },
            {
              "t": "ref",
              "v": "Freeze Ray",
              "kind": "gun"
            },
            {
              "t": "text",
              "v": ", it gains piercing and slowly regenerates ammo over time."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Frost Bullets will make explosive weapons create a patch of ice upon exploding."
            }
          ]
        }
      ],
      "trivia": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "'Willing to Sacrifice' likely refers to the song \"Cold as Ice\" by Foreigner"
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Cold Ones is most likely a reference to the YouTube series \"Hot Ones\""
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The color change from the \"Arctic Warfare\" synergy is a direct reference to the A.W.P. Asiimov skin from Counter Strike: Global Offensive"
            }
          ]
        }
      ]
    }
  },
  {
    "name": "Charming Rounds",
    "icon": "https://static.wikia.nocookie.net/enterthegungeon_gamepedia/images/a/a0/Charming_Rounds.png",
    "type": "Passive",
    "quote": "Made With Love",
    "quality": "B",
    "effect": "Adds a chance to fire bullets that charm enemies.",
    "curse": 0.0,
    "coolness": 0.0,
    "wiki": {
      "effects": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "Bullets have a 7.5% chance to "
            },
            {
              "t": "ref",
              "v": "Charm",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": " enemies, indicated by being tinted pink.\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "The chance for any given projectile to charm is multiplied by the "
                },
                {
                  "t": "ref",
                  "v": "Effect chance scalar",
                  "kind": "unresolved"
                },
                {
                  "t": "text",
                  "v": " of the player's current "
                },
                {
                  "t": "ref",
                  "v": "Gun",
                  "kind": "unresolved"
                },
                {
                  "t": "text",
                  "v": ". This means that faster firing guns trigger the effect less often, while slower firing guns are more likely to be effected."
                }
              ]
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Beams have a 10% chance per second to charm enemies while shooting them."
            }
          ]
        }
      ],
      "item_interactions": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "If duplicates of this item are somehow obtained, further increases the chance of bullets being able to charm enemies."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "ref",
              "v": "Book of Chest Anatomy",
              "kind": "item"
            },
            {
              "t": "text",
              "v": " +  "
            },
            {
              "t": "synref",
              "v": "Unbelievably Charming"
            },
            {
              "t": "text",
              "v": " - Because Book of Chest Anatomy raises the chance of broken chests dropping an item to 55%, all chests effectively have a 55% chance to drop the item they were predicted to contain when broken."
            }
          ]
        }
      ],
      "notes": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "A depiction of Charming Rounds can be seen in the opening scroll of the "
            },
            {
              "t": "ext",
              "v": "Supply Drop Trailer",
              "url": "https://www.youtube.com/watch?v=x3YN0qhy8R8"
            },
            {
              "t": "text",
              "v": "."
            }
          ]
        }
      ]
    }
  },
  {
    "name": "Magic Bullets",
    "icon": "https://static.wikia.nocookie.net/enterthegungeon_gamepedia/images/a/aa/Magic_Bullets.png",
    "type": "Passive",
    "quote": "Sufficiently Advanced",
    "quality": "B",
    "effect": "Grants all of the player's bullets a small chance to transmogrify enemies into chickens.",
    "curse": 0.0,
    "coolness": 0.0,
    "wiki": {
      "effects": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "Grants every bullet a small chance to transmogrify enemies into chickens."
            }
          ]
        }
      ],
      "notes": [
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "synref",
              "v": "Chicken Arise"
            },
            {
              "t": "text",
              "v": " - If the player also has "
            },
            {
              "t": "ref",
              "v": "Bundle of Wands",
              "kind": "gun"
            },
            {
              "t": "text",
              "v": ", "
            },
            {
              "t": "ref",
              "v": "Hexagun",
              "kind": "gun"
            },
            {
              "t": "text",
              "v": ", "
            },
            {
              "t": "ref",
              "v": "Staff of Firepower",
              "kind": "gun"
            },
            {
              "t": "text",
              "v": ", or "
            },
            {
              "t": "ref",
              "v": "Witch Pistol",
              "kind": "gun"
            },
            {
              "t": "text",
              "v": ", bullet size and transmogrification chances are increased."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "synref",
              "v": "Runic"
            },
            {
              "t": "text",
              "v": " - If the player has "
            },
            {
              "t": "ref",
              "v": "Lower Case r",
              "kind": "gun"
            },
            {
              "t": "text",
              "v": ", the words ABRA and KADABRA are spelled out when using the weapon."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Magic Bullets can turn normally invulnerable enemies like "
            },
            {
              "t": "ref",
              "v": "Gunreaper",
              "kind": "unresolved"
            },
            {
              "t": "text",
              "v": " into chickens, making them vulnerable and harmless."
            }
          ]
        }
      ],
      "trivia": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "The tagline is a reference to the third "
            },
            {
              "t": "ext",
              "v": "Clarke's Law",
              "url": "https://en.wikipedia.org/wiki/Clarke%27s_three_laws"
            },
            {
              "t": "text",
              "v": " (formulated by Arthur C. Clarke): \"Any sufficiently advanced technology is indistinguishable from magic.\""
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The synergy  "
            },
            {
              "t": "synref",
              "v": "Chicken Arise"
            },
            {
              "t": "text",
              "v": " is a reference to "
            },
            {
              "t": "ext",
              "v": "Aqua Teen Hunger Force",
              "url": "https://en.wikipedia.org/wiki/Aqua_Teen_Hunger_Force"
            },
            {
              "t": "text",
              "v": " season 3 episode 1, entitled \"Video Ouija\""
            }
          ]
        }
      ]
    }
  },
  {
    "name": "Fat Bullets",
    "icon": "https://static.wikia.nocookie.net/enterthegungeon_gamepedia/images/4/41/Fat_Bullets.png",
    "type": "Passive",
    "quote": "Fatter = Stronger",
    "quality": "A",
    "effect": "Doubles bullet size and knockback, increases damage by 30%, and decreases maximum ammo by 10%.",
    "curse": 0.0,
    "coolness": 0.0,
    "wiki": {
      "effects": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "Doubles "
            },
            {
              "t": "ref",
              "v": "Bullet Scale",
              "kind": "unresolved"
            },
            {
              "t": "text",
              "v": "."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Increases damage by 30%."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Decreases maximum ammo by 10%."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Doubles knockback."
            }
          ]
        }
      ],
      "item_interactions": [
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "ref",
              "v": "Table Tech Rocket",
              "kind": "item"
            },
            {
              "t": "text",
              "v": " - Rocket powered flipped tables double in size, allowing them to block more bullets and hit more enemies. This size increase can also be detrimental, as it can cause the table to catch on walls in tight spaces far more easily."
            }
          ]
        }
      ],
      "notes": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "The increased projectile size negatively affects guns with large projectiles such as the "
            },
            {
              "t": "ref",
              "v": "Crestfaller",
              "kind": "gun"
            },
            {
              "t": "text",
              "v": ". Often times, while close to a wall, the edge of a projectile will be in the wall resulting in the projectile hitting the wall the moment it is fired."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The decrease in maximum ammo can be bypassed if you temporarily drop the item before picking up ammo drops or new guns. This is because the game lets you hold more than your maximum ammo."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "May be a reference to The Binding of Isaac, where many items that increase damage also increase tear size."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "May also be a reference to the "
            },
            {
              "t": "ext",
              "v": "Metal Slug",
              "url": "https://en.wikipedia.org/wiki/Metal_Slug"
            },
            {
              "t": "text",
              "v": " series, where if a character eats too much food, they will get fat, and their shots will increase in size and damage."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": " Bug Throwing an empty "
            },
            {
              "t": "ref",
              "v": "Gun",
              "kind": "unresolved"
            },
            {
              "t": "text",
              "v": " will double the size of its sprite. This effect is mechanical only, and does not affect the function of the gun.\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "Resized guns "
                },
                {
                  "t": "text",
                  "v": "keep",
                  "style": "i"
                },
                {
                  "t": "text",
                  "v": " their size changes when picked back up, and while held in the players hands."
                }
              ]
            },
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "This bug has been known and acknowledged by "
                },
                {
                  "t": "ref",
                  "v": "Dodge Roll",
                  "kind": "lore"
                },
                {
                  "t": "text",
                  "v": " since at least October 2016, however it has not been fixed because it has no mechanical downside and is humorous."
                }
              ]
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": " Bug Entering a Gungeoneer's past with Fat Bullets in your inventory will cause the gun given in that Gungeoneer's past to have its current ammo set to 0.9x of the gun's usual maximum ammo capacity.\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "This affects "
                },
                {
                  "t": "ref",
                  "v": "The Marine",
                  "kind": "character"
                },
                {
                  "t": "text",
                  "v": " with the "
                },
                {
                  "t": "ref",
                  "v": "Hegemony Carbine",
                  "kind": "gun"
                },
                {
                  "t": "text",
                  "v": ", "
                },
                {
                  "t": "ref",
                  "v": "The Convict",
                  "kind": "character"
                },
                {
                  "t": "text",
                  "v": " with the "
                },
                {
                  "t": "ref",
                  "v": "Tommy gun",
                  "kind": "unresolved"
                },
                {
                  "t": "text",
                  "v": ", "
                },
                {
                  "t": "ref",
                  "v": "The Robot",
                  "kind": "character"
                },
                {
                  "t": "text",
                  "v": " with "
                },
                {
                  "t": "ref",
                  "v": "Robot's Left Hand",
                  "kind": "gun"
                },
                {
                  "t": "text",
                  "v": ", and "
                },
                {
                  "t": "ref",
                  "v": "The Hunter",
                  "kind": "character"
                },
                {
                  "t": "text",
                  "v": " with the "
                },
                {
                  "t": "ref",
                  "v": "Sticky Crossbow",
                  "kind": "gun"
                },
                {
                  "t": "text",
                  "v": "."
                }
              ]
            },
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "This bug does NOT affect "
                },
                {
                  "t": "ref",
                  "v": "The Pilot",
                  "kind": "character"
                },
                {
                  "t": "text",
                  "v": " or "
                },
                {
                  "t": "ref",
                  "v": "The Cultist",
                  "kind": "character"
                },
                {
                  "t": "text",
                  "v": ", as their pasts don't involve being given traditional weapons, and does not affect "
                },
                {
                  "t": "ref",
                  "v": "The Paradox",
                  "kind": "character"
                },
                {
                  "t": "text",
                  "v": " or "
                },
                {
                  "t": "ref",
                  "v": "The Gunslinger",
                  "kind": "character"
                },
                {
                  "t": "text",
                  "v": " as they don't have pasts."
                }
              ]
            }
          ]
        }
      ]
    }
  },
  {
    "name": "Angry Bullets",
    "icon": "https://static.wikia.nocookie.net/enterthegungeon_gamepedia/images/d/da/Angry_Bullets.png",
    "type": "Passive",
    "quote": "Hungry For More",
    "quality": "C",
    "effect": "Hitting an enemy refires the projectile at a nearby enemy.",
    "curse": 0.0,
    "coolness": 0.0,
    "wiki": {
      "effects": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "Bullets that hit enemies will bounce off them into a random direction.\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "Reflected bullets can trigger the same effect."
                }
              ]
            },
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "Reflected bullets deal half of the original bullet's damage."
                }
              ]
            },
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "Piercing weapons will always reflect at nearby enemies, or randomly if no enemies are nearby."
                }
              ]
            }
          ]
        }
      ],
      "item_interactions": [
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "ref",
              "v": "Hyper Light Blaster",
              "kind": "gun"
            },
            {
              "t": "text",
              "v": " - Shots from the Hyper Light Blaster will be immediately destroyed upon impacting an enemy, and will not rebound."
            }
          ]
        }
      ],
      "notes": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "Beam guns will be deflected at a random angle upon hitting an enemy."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Most explosive weapons will not explode upon contact with an enemy. Because of this, it is advisable to drop Angry Bullets during a fight if you intend on using explosive weapons during that fight.\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "An exception to this is "
                },
                {
                  "t": "ref",
                  "v": "Void Core Cannon",
                  "kind": "gun"
                },
                {
                  "t": "text",
                  "v": ", whose projectiles will still explode even with Angry Bullets."
                }
              ]
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Angry Bullets work well with the "
            },
            {
              "t": "ref",
              "v": "Railgun",
              "kind": "gun"
            },
            {
              "t": "text",
              "v": ", allowing it to easily clear rooms."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Angry Bullets also work well with "
            },
            {
              "t": "ref",
              "v": "Cat Claw",
              "kind": "gun"
            },
            {
              "t": "text",
              "v": ", allowing shots to strike multiple targets due to the homing nature of the rounds; even striking the same target multiple times in some instances."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "ref",
              "v": "Magic Lamp",
              "kind": "gun"
            },
            {
              "t": "text",
              "v": " can hit large bosses multiple times, allowing for the genie effect to trigger much more often."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "ref",
              "v": "Quad Laser",
              "kind": "gun"
            },
            {
              "t": "text",
              "v": "'s projectile moves extremely slowly, allowing it to strike enemies multiple times, and creating a near stationary barrier that enemies can be lured into."
            }
          ]
        }
      ]
    }
  },
  {
    "name": "Blank Bullets",
    "icon": "https://static.wikia.nocookie.net/enterthegungeon_gamepedia/images/8/81/Blank_Bullets.png",
    "type": "Passive",
