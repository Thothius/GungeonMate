  {
    "name": "Knife Shield",
    "icon": "https://static.wikia.nocookie.net/enterthegungeon_gamepedia/images/8/8a/Knife_Shield.png",
    "type": "Active",
    "quote": "Use Again To Launch!",
    "quality": "D",
    "effect": "Creates a ring of knives around the player that damage enemies and block enemy bullets. Knives vanish after taking enough damage. If used again while the shield is active, the knives are launched forward. Increases curse by 1 while held.",
    "curse": 1.0,
    "coolness": 0.0,
    "wiki": {
      "effects": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "Creates a ring of 8 knives around the player that damage enemies and block enemy bullets. Knives vanish after taking enough damage."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "If used again before Knife Shield is recharged, the knives are launched forward."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Each knife deals 30 damage."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Increases  "
            },
            {
              "t": "ref",
              "v": "Curse",
              "kind": "stat"
            },
            {
              "t": "text",
              "v": " by 1 while held."
            }
          ]
        }
      ],
      "notes": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "The knives do not carry on between floors, and disappear once the player enters a new floor."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Knife Shield can be activated while the player already has knives, adding another 8 knives to the ring."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Knives will destroy some objects, such as "
            },
            {
              "t": "ref",
              "v": "Breakables",
