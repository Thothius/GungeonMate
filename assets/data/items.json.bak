                },
                {
                  "t": "text",
                  "v": ", "
                },
                {
                  "t": "ref",
                  "v": "Lead Cube",
                  "kind": "unresolved"
                },
                {
                  "t": "text",
                  "v": " and "
                },
                {
                  "t": "ref",
                  "v": "Flesh Cube",
                  "kind": "unresolved"
                },
                {
                  "t": "text",
                  "v": ". The only non-boss enemies unaffected are the "
                },
                {
                  "t": "ref",
                  "v": "Gripmaster",
                  "kind": "unresolved"
                },
                {
                  "t": "text",
                  "v": ", "
                },
                {
                  "t": "ref",
                  "v": "Dead Blow",
                  "kind": "unresolved"
                },
                {
                  "t": "text",
                  "v": " and the "
                },
                {
                  "t": "ref",
                  "v": "Lord of the Jammed",
                  "kind": "unresolved"
                },
                {
                  "t": "text",
                  "v": "."
                }
              ]
            },
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "Bosses take 30 damage instead of dying instantly, and the player will bounce off them."
                }
              ]
            },
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "Teleporting while the item is active will deactivate the transformation."
                }
              ]
            }
          ]
        }
      ],
      "notes": [
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "synref",
              "v": "Resourceful Indeed"
            },
            {
              "t": "text",
              "v": " - If the player also has "
            },
            {
              "t": "ref",
              "v": "Rat Boots",
              "kind": "item"
            },
            {
              "t": "text",
              "v": ", "
            },
            {
              "t": "ref",
              "v": "Elimentaler",
              "kind": "gun"
            },
            {
              "t": "text",
              "v": ", and "
            },
            {
              "t": "ref",
              "v": "Resourceful Sack",
              "kind": "item"
            },
            {
              "t": "text",
              "v": ", the player becomes the Resourceful Rat, preventing items from being stolen when they're left behind in rooms."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Eating a "
            },
            {
              "t": "ref",
              "v": "Mimic",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": " used to cause it to not drop an item, but this has since been patched."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Eating "
            },
            {
              "t": "ref",
              "v": "Keybullet Kin",
              "kind": "unresolved"
            },
            {
              "t": "text",
              "v": " or "
            },
            {
              "t": "ref",
              "v": "Chance Kin",
              "kind": "unresolved"
            },
            {
              "t": "text",
              "v": " causes them to drop two keys or pickups.\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "Eating a "
                },
                {
                  "t": "ref",
                  "v": "Curse",
                  "kind": "stat"
                },
                {
                  "t": "text",
                  "v": " Keybullet Kin or Chance Kin will not have them drop four pickups, however."
                }
              ]
            }
          ]
        }
      ]
    }
