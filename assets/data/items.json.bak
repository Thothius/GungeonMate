            {
              "t": "text",
              "v": " or "
            },
            {
              "t": "ref",
              "v": "Baby Good Mimic",
              "kind": "item"
            },
            {
              "t": "text",
              "v": " can trigger Zombie Bullets and refill ammo for the player's currently held gun.\n"
