        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The "
            },
            {
              "t": "ref",
              "v": "Ammonomicon",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": " quote "
            },
            {
              "t": "text",
              "v": "\"Locks Are Dead To You\"",
              "style": "i"
            },
            {
              "t": "text",
              "v": " may be a reference to the fact that locks in the Gungeon are sentient, meaning that opening them literally kills them."
            }
          ]
        }
      ]
    }
