              "t": "text",
              "v": " "
            },
            {
              "t": "synref",
              "v": "Peripheral Vision"
            },
            {
              "t": "text",
              "v": " - If the player has "
            },
            {
              "t": "ref",
              "v": "Light Gun",
              "kind": "gun"
            },
            {
              "t": "text",
              "v": ", a dog occasionally appears and attacks enemies."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "synref",
              "v": "Pistol Machine"
            },
            {
              "t": "text",
              "v": " - If the player has "
            },
            {
              "t": "ref",
              "v": "Machine Pistol",
              "kind": "gun"
            },
            {
              "t": "text",
              "v": ", its shots pierce enemies and are connected with electricity."
            }
          ]
        }
      ],
      "trivia": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "The description title is a reference to "
            },
            {
              "t": "ext",
              "v": "King of The Dot",
              "url": "https://en.wikipedia.org/wiki/King_of_the_Dot"
            },
            {
              "t": "text",
              "v": ", the Canadian rap battle league of the same name."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The  "
            },
            {
              "t": "synref",
              "v": "Future Gangster"
            },
            {
              "t": "text",
              "v": " synergy may be a reference to Fallout: New Vegas's "
            },
            {
              "t": "ext",
              "v": "Laser RCW",
              "url": "http://fallout.wikia.com/wiki/Laser_RCW"
            },
            {
              "t": "text",
              "v": "."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The  "
            },
            {
              "t": "synref",
              "v": "Peripheral Vision"
            },
            {
              "t": "text",
              "v": " synergy refers to the NES Zapper, which was sold as a peripheral for the NES and served as the model for the "
            },
            {
              "t": "ref",
              "v": "Light Gun",
              "kind": "gun"
            }
          ]
        }
      ]
    }
  },
  {
    "name": "Ammo Belt",
    "icon": "https://static.wikia.nocookie.net/enterthegungeon_gamepedia/images/f/fc/Ammo_Belt.png",
