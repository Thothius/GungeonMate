            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Like other starting items, the Trusty Lockpicks will carry over to the "
            },
            {
              "t": "ref",
              "v": "Past",
              "kind": "unresolved"
            },
            {
              "t": "text",
              "v": "."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Cannot be fed to the "
            },
            {
              "t": "ref",
              "v": "Serpent",
              "kind": "unresolved"
            },
            {
              "t": "text",
              "v": "."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Cannot open the trap door leading to the "
            },
            {
              "t": "ref",
              "v": "Resourceful Rat's Lair",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": "."
            }
          ]
        }
      ]
    }
  },
