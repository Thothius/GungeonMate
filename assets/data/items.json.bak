  {
    "name": "Heart Holster",
    "icon": "https://static.wikia.nocookie.net/enterthegungeon_gamepedia/images/d/db/Heart_Holster.png",
    "type": "Passive",
    "quote": "On Your Sleeve",
    "quality": "C",
    "effect": "Grants a heart container.",
    "curse": 0.0,
    "coolness": 0.0,
    "wiki": {
      "effects": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "Grants a heart container."
            }
          ]
        }
      ],
      "notes": [
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "synref",
              "v": "All Out Of Law"
            },
            {
              "t": "text",
              "v": " - If the player has "
            },
            {
              "t": "ref",
              "v": "Colt 1851",
              "kind": "gun"
            },
            {
              "t": "text",
              "v": ", it fires three tight spreads of three bullets upon reloading. These projectiles can ignore tables when fired from behind them, and they can reveal secret rooms without angering the shopkeeper Bello."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "synref",
              "v": "Finger on the Pulse"
            },
            {
              "t": "text",
              "v": " - If the player has "
            },
            {
              "t": "ref",
              "v": "Pulse Cannon",
              "kind": "gun"
            },
            {
              "t": "text",
              "v": ", upon taking damage, three miniature Pulse cannons briefly spawn around the player and fire at enemies."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "synref",
              "v": "Quick and the Gundead"
            },
            {
              "t": "text",
              "v": " - If the player has "
            },
            {
              "t": "ref",
              "v": "Hip Holster",
              "kind": "item"
            },
            {
              "t": "text",
              "v": ", shots fired by Hip Holster home in on enemies."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Despite being able to be found in  and  rank chests, it will always have to be bought from a "
            },
            {
              "t": "ref",
              "v": "Shop",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": " at  rank price."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Like all heart container items, "
            },
            {
              "t": "ref",
              "v": "The Robot",
              "kind": "character"
            },
            {
              "t": "text",
              "v": " will receive 5 to 10  instead."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Like the other heart container items, the Heart Holster will drop alongside a key if it is found from opening an  rank chest."
            }
          ]
        }
      ],
      "trivia": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "The pickup quote is a reference to the phrase \"wear your heart on your sleeve\"."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The \"Quick and the Gundead\" synergy is a reference to 1995 western film \""
            },
            {
              "t": "ext",
              "v": "The Quick and the Dead",
              "url": "https://en.wikipedia.org/wiki/The_Quick_and_the_Dead_(1995_film)"
            },
            {
              "t": "text",
              "v": "\"."
            }
          ]
        }
      ]
    }
  },
