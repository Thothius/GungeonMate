                {
                  "t": "text",
                  "v": "only",
                  "style": "i"
                },
                {
                  "t": "text",
                  "v": " applies to helix projectiles from Helix Bullets. Bullets from the  "
                },
                {
                  "t": "ref",
                  "v": "Helix",
                  "kind": "gun"
                },
                {
                  "t": "text",
                  "v": " will orbit in perfect circles like most other guns."
