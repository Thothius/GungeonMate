  {
    "name": "Riddle of Lead",
    "icon": "https://static.wikia.nocookie.net/enterthegungeon_gamepedia/images/c/cb/Riddle_of_Lead.png",
    "type": "Passive",
    "quote": "This You Can Trust",
    "quality": "1S",
    "effect": "Grants a heart container, fully heals the player, increases damage by 30%, increases dodge roll speed by 15%, increases movement speed by 10%, and adds a chance to negate damage.",
    "curse": 0.0,
    "coolness": 0.0,
    "wiki": {
      "effects": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "Grants a heart container."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Fully heals the player."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Increases damage by 30%."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Increases player speed by 10%."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Increases dodge roll/table sliding speed by approximately 15%."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "When at 1 heart or less, adds a 50% chance to negate damage."
            }
          ]
        }
      ],
      "notes": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "Dropping and picking up the item will not heal the player again."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Due to having no hearts, "
            },
            {
              "t": "ref",
              "v": "The Robot",
              "kind": "character"
            },
            {
              "t": "text",
              "v": " will always have the 50% chance to negate damage active."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The chance to negate damage applies to falling damage from walking into pits."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Negated damage will not prevent the player from earning a "
            },
            {
              "t": "ref",
              "v": "Master Round I",
              "kind": "item"
            },
            {
              "t": "text",
              "v": "."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "This item and its quote are references to the \"Riddle of Steel\" from the 1982 film "
            },
            {
              "t": "ext",
              "v": "Conan the Barbarian",
              "url": "https://en.wikipedia.org/wiki/Conan_the_Barbarian_(1982_film)"
            },
            {
              "t": "text",
              "v": ".\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "The name may also be a reference to the use of the word \"riddle\" to mean \"to make many holes in (someone or something), especially with gunshot.\""
                }
              ]
            }
          ]
        }
      ]
    }
  },
  {
    "name": "Bracket Key",
    "icon": "https://static.wikia.nocookie.net/enterthegungeon_gamepedia/images/7/7a/Bracket_Key.png",
    "type": "Active",
    "quote": "`debugkill",
    "quality": "1S",
    "effect": "Deals a large amount of damage to all enemies in a room. Increases curse by 1 while held.",
    "curse": 1.0,
    "coolness": 0.0,
    "wiki": {
      "effects": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "Deals 150 damage to all enemies in the room."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Prevents additional enemy waves from spawning when used."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Increases "
            },
            {
              "t": "ref",
              "v": "Curse",
              "kind": "stat"
            },
            {
              "t": "text",
              "v": " by 1 while held."
            }
          ]
        }
      ],
      "notes": [
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "synref",
              "v": "Hacker"
            },
            {
              "t": "text",
              "v": " - If the player also has "
            },
            {
              "t": "ref",
              "v": "Lower Case r",
              "kind": "gun"
            },
            {
              "t": "text",
              "v": ", its damage is increased by 25%."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "synref",
              "v": "Square Brace"
            },
            {
              "t": "text",
              "v": " - If the player also has "
            },
            {
              "t": "ref",
              "v": "Polaris",
              "kind": "gun"
            },
            {
              "t": "text",
              "v": ", it gains 20% increased damage, higher ammo capacity and magazine size, faster fire rate, and a new appearance."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The Bracket Key can hit bosses such as "
            },
            {
              "t": "ref",
              "v": "Cannonbalrog",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": " and "
            },
            {
              "t": "ref",
              "v": "High Priest",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": " during attacks where they are normally invincible."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The explosion cannot travel to other rooms (e.g. using the item in a room adjacent to a chest room containing a "
            },
            {
              "t": "ref",
              "v": "Mimic",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": " will not damage it)."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Unlike "
            },
            {
              "t": "ref",
              "v": "Big Boy",
              "kind": "item"
            },
            {
              "t": "text",
              "v": ", the damage done by Bracket Key will not contribute to its own recharge."
            }
          ]
        }
      ],
      "trivia": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "The Bracket Key's description and functionality seem to suggest/pay homage to the fact that the right bracket key on the keyboard was used during development of Enter the Gungeon to automatically clear rooms for debugging purposes."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The synergy  "
            },
            {
              "t": "synref",
              "v": "Square Brace"
            },
            {
              "t": "text",
              "v": " is a reference to the character Curly Brace from the game Cave Story, where the gun "
            },
            {
              "t": "ref",
              "v": "Polaris",
              "kind": "gun"
            },
            {
              "t": "text",
              "v": " is also from."
            }
          ]
        }
      ]
    }
  },
