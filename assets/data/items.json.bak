  {
    "name": "Ice Cube",
    "icon": "https://static.wikia.nocookie.net/enterthegungeon_gamepedia/images/f/f9/Ice_Cube.png",
    "type": "Passive",
    "quote": "Items Recharge While Active",
    "quality": "B",
    "effect": "Reduces the cooldown timer of active items. Increases coolness by 3.",
    "curse": 0.0,
    "coolness": 3.0,
    "wiki": {
      "effects": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "Allows active items to recharge while they are active."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Increases "
            },
            {
              "t": "ref",
              "v": "Coolness",
              "kind": "stat"
            },
            {
              "t": "text",
              "v": " by 3."
            }
          ]
        }
      ],
      "notes": [
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "synref",
              "v": "Ice To Meet You"
            },
            {
              "t": "text",
              "v": " - If the player also has "
            },
            {
              "t": "ref",
              "v": "Heart of Ice",
              "kind": "item"
            },
            {
              "t": "text",
              "v": ", firing with any gun will periodically fire a Heart of Ice projectile that splits and bounces. Like regular Heart of Ice projectiles, these projectiles can freeze water.\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "The probability of firing the ice projectile appears to be inversely proportional to the gun's fire rate.  Curiously, it will always fire if the player swings "
                },
                {
                  "t": "ref",
                  "v": "Blasphemy",
                  "kind": "gun"
                },
                {
                  "t": "text",
                  "v": " with full hearts."
                }
              ]
            },
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "Rapidly clicking with a charge weapon will fire an ice projectile without consuming ammo."
                }
              ]
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "synref",
              "v": "Willing To Sacrifice"
            },
            {
              "t": "text",
              "v": " - If the player also has "
            },
            {
              "t": "ref",
              "v": "Freeze Ray",
              "kind": "gun"
            },
            {
              "t": "text",
              "v": ", it gains piercing and slowly regenerates ammo over time."
            }
          ]
        }
      ],
      "trivia": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "The synergy  "
            },
            {
              "t": "synref",
              "v": "Willing to Sacrifice"
            },
            {
              "t": "text",
              "v": " - is a reference to the song \"Cold As Ice\" by Foreigner."
            }
          ]
        }
      ]
    }
  },
