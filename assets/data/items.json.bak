    "curse": 0.0,
    "coolness": 0.0,
    "wiki": {
      "effects": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "Increases damage and fire rate with every bullet that hits an enemy.\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "Weapon fire rate doubles every 250 normalized seconds of firing (2500 shots with a ten-shots-per-second weapon), to a maximum of triple firing speed after 375 seconds of shooting."
                }
              ]
            },
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "Weapon damage dealt doubles every 500 normalized seconds of firing (5000 shots with a ten-shots-per-second weapon), to a maximum of triple damage after 750 seconds of shooting."
                }
              ]
            },
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "Platinum Bullets start partially powered; there's a large immediate bump in fire speed and damage if the item is acquired on a later floor."
                }
              ]
            },
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "If Platinum Bullets are dropped, the effect of the Platinum Bullets resets until the next combat. After the next combat starts, the effect returns to as before."
                }
              ]
            }
          ]
        }
      ],
      "notes": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "The damage and fire rate bonuses do not update until the player switches weapons or picks up/drops an item or gun, making it possible for the bonuses to never apply."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Beam weapons stay mostly unchanged, but the increased fire rate makes their ammo drain much faster."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "With this item, most weapons turn silver in appearance."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "If this item is dropped, the fire rate and damage bonus are lost, and do not return when picked back up."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The "
            },
            {
              "t": "ref",
              "v": "Ammonomicon",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": " quote "
            },
            {
              "t": "text",
              "v": "\"Over One Million Served\"",
              "style": "i"
            },
            {
              "t": "text",
              "v": " is a reference to the McDonald's Restaurant's common sign slogan of "
            },
            {
              "t": "text",
              "v": "\"Over 99 Billion Served\"",
              "style": "i"
            },
            {
              "t": "text",
              "v": "."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The item and drop line both reference the phrase/concept of \""
            },
            {
              "t": "text",
              "v": "going platinum\",",
              "style": "i"
            },
            {
              "t": "text",
              "v": " meaning to reach 1 million (or more) in total sales.\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "Enter the Gungeon officially 'went platinum' in July of 2017,, with "
                },
                {
                  "t": "ref",
                  "v": "Brent Sodman",
                  "kind": "unresolved"
                },
                {
                  "t": "text",
                  "v": " stating on Reddit that they would put an extra item into "
                },
                {
                  "t": "ref",
                  "v": "AG&D",
                  "kind": "unresolved"
                },
                {
                  "t": "text",
                  "v": " to celebrate this milestone. This item was likely Platinum Bullets."
                }
              ]
            }
          ]
        }
      ]
    }
  },
  {
    "name": "Chaos Bullets",
    "icon": "https://static.wikia.nocookie.net/enterthegungeon_gamepedia/images/4/4f/Chaos_Bullets.png",
    "type": "Passive",
    "quote": "Taste The Painbow",
    "quality": "A",
    "effect": "Adds random bullet effects to the player's bullets.",
    "curse": 0.0,
    "coolness": 0.0,
    "wiki": {
      "effects": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "Slightly randomises the speed of the players bullets."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Each shot fired has a chance to be affected by a number of random modifiers from the following list. These effects are not mutually exclusive, and multiple can be applied to the same shot.\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "10% chance to add 1 additional ricochet."
                }
              ]
            },
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "10% chance to add 2 piercing.\n"
                }
              ],
              "sub": [
                {
                  "tokens": [
                    {
                      "t": "text",
                      "v": "Chaos Bullets will continue attempting to stack bounces and pierces onto a bullet until it fails, or reaches 10 bouncing/piercing. This means that a projectile that already gained a bounce has another 10% chance to gain an additional bounce, and then another 10% chance to gain a third, etc."
                    }
                  ]
                },
                {
                  "tokens": [
                    {
                      "t": "text",
                      "v": "For each additional application of piercing, Chaos Bullets will pierce two more enemies, while for each additional application of bouncing Chaos Bullets will only bounce one extra time."
                    }
                  ]
                }
              ]
            },
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "10% chance to increase the size of the projectile by 25%-75%."
                }
              ]
            },
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "10% chance for the bullet to inflict a random "
                },
                {
                  "t": "ref",
                  "v": "Status effect",
                  "kind": "unresolved"
                },
                {
                  "t": "text",
                  "v": " from the status effect table (see below). Projectiles are tinted colours corresponding to the status effect that has been applied to them.\n"
                }
              ],
              "sub": [
                {
                  "tokens": [
                    {
                      "t": "text",
                      "v": "The 10% chance for a random status effect is multiplied by the "
                    },
                    {
                      "t": "ref",
                      "v": "Effect chance scalar",
                      "kind": "unresolved"
                    },
                    {
                      "t": "text",
                      "v": " of the players current "
                    },
                    {
                      "t": "ref",
                      "v": "Gun",
                      "kind": "unresolved"
                    },
                    {
                      "t": "text",
                      "v": ". This means that faster firing guns are applied with status effects less often, while slower firing guns are more likely to be effected."
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "25% chance-per-second while shooting an enemy with a beam-type weapon for that enemy to be afflicted with a random "
            },
            {
              "t": "ref",
              "v": "Status effect",
              "kind": "unresolved"
            },
            {
              "t": "text",
              "v": " from the status effect table (see below). Other Chaos Bullets effects such as size, velocity, bouncing, and piercing do "
            },
            {
              "t": "text",
              "v": "not",
              "style": "i"
            },
            {
              "t": "text",
              "v": " affect beams. Beams are not tinted different colours, regardless of what effects they apply."
            }
          ]
        }
      ],
      "item_interactions": [
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "ref",
              "v": "Prize Pistol",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": " - The velocity randomisation applied by Chaos Bullets can make the Prize Pistol unpredictable, and render it difficult to properly play "
            },
            {
              "t": "ref",
              "v": "Winchester (NPC)",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": " game."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "ref",
              "v": "Dark Marker",
              "kind": "gun"
            },
            {
              "t": "text",
              "v": " - The random velocity modification of Chaos Bullets is extremely detrimental to the Dark Marker, as it means the juxtaposed charged shots will almost always miss one another."
            }
          ]
        }
      ],
      "notes": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "The "
            },
            {
              "t": "ref",
              "v": "Ammonomicon",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": " quote "
            },
            {
              "t": "text",
              "v": "\"Taste the Painbow\"",
              "style": "i"
            },
            {
              "t": "text",
              "v": " is a reference to the slogan of the "
            },
            {
              "t": "ext",
              "v": "Skittles",
              "url": "https://en.wikipedia.org/wiki/Skittles_(confectionery)"
            },
            {
              "t": "text",
              "v": " brand of confectionery, "
            },
            {
              "t": "text",
              "v": "\"Taste the Rainbow\"",
              "style": "i"
            },
            {
              "t": "text",
              "v": "."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "This item bearing butterfly wings is a reference to the concept of the "
            },
            {
              "t": "ext",
              "v": "butterfly effect",
              "url": "https://en.wikipedia.org/wiki/Butterfly_effect"
            },
            {
              "t": "text",
              "v": " in chaos theory.\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "It may also be a reference to the song "
                },
                {
                  "t": "ext",
                  "v": "Bullet With Butterfly Wings",
                  "url": "https://www.youtube.com/watch?v=8-r-V0uK4u0"
                },
                {
                  "t": "text",
                  "v": " by the band "
                },
                {
                  "t": "text",
                  "v": "Smashing Pumpkins",
                  "style": "i"
                },
                {
                  "t": "text",
                  "v": "."
                }
              ]
            }
          ]
        }
      ]
    }
  },
  {
