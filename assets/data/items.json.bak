  {
    "name": "Teleporter Prototype",
    "icon": "https://static.wikia.nocookie.net/enterthegungeon_gamepedia/images/a/ac/Teleporter_Prototype.png",
    "type": "Active",
    "quote": "Teleport?!",
    "quality": "B",
    "effect": "Teleports the player to a random room.",
    "curse": 0.0,
    "coolness": 0.0,
    "wiki": {
      "effects": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "If the player is in the "
            },
            {
              "t": "ref",
              "v": "Forge",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": " or "
            },
            {
              "t": "ref",
              "v": "Bullet Hell",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": ", this outcome will instead do nothing if chosen."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "If the player is in combat when using the Teleporter Prototype, this outcome will never trigger. If it would have triggered, the teleport will instead take the player to a random special room as detailed below."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "If an "
