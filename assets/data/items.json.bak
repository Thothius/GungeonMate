  {
    "name": "Ring of the Resourceful Rat",
    "icon": "https://static.wikia.nocookie.net/enterthegungeon_gamepedia/images/5/53/Ring_of_the_Resourceful_Rat.png",
    "type": "Passive",
    "quote": "Fufufufufufu",
    "quality": "B",
    "effect": "Once per floor, if the Resourceful Rat takes an item or gun, he will give another item or gun of equal quality in return. Unused trades carry over to subsequent floors.",
    "curse": 0.0,
    "coolness": 0.0,
    "wiki": {
      "effects": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "If the "
            },
            {
              "t": "ref",
              "v": "Resourceful Rat",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": " steals an "
            },
            {
              "t": "ref",
              "v": "Item",
              "kind": "unresolved"
            },
            {
              "t": "text",
              "v": " or "
            },
            {
              "t": "ref",
              "v": "Gun",
              "kind": "unresolved"
            },
            {
              "t": "text",
              "v": ", he will drop another item or gun of the same type and "
            },
            {
              "t": "ref",
              "v": "Quality",
              "kind": "unresolved"
            },
            {
              "t": "text",
              "v": ".\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "The Rat can be traded with once per chamber after acquiring the ring. Unused trades will carry over to subsequent floors, allowing multiple trades on a single chamber."
                }
              ]
            },
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "Active items are always exchanged for other active items. Passive items are always exchanged for other passive items."
                }
              ]
            },
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "If there are no possible items or guns of the appropriate quality tier (for example, if all of them have somehow been acquired) the Rat will instead drop items or guns one tier lower than the traded quality."
                }
              ]
            },
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "Common or Special quality items, such as  "
                },
                {
                  "t": "ref",
                  "v": "Friendship Cookie",
                  "kind": "item"
                },
                {
                  "t": "text",
                  "v": ",  "
                },
                {
                  "t": "ref",
                  "v": "Glass Guon Stone",
                  "kind": "item"
                },
                {
                  "t": "text",
                  "v": ", or  "
                },
                {
                  "t": "ref",
                  "v": "Junk",
                  "kind": "item"
                },
                {
                  "t": "text",
                  "v": " will be stolen without anything being given in return, and will not spend a trade."
                }
              ]
            }
          ]
        }
      ],
      "item_interactions": [
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "ref",
              "v": "Bullet That Can Kill The Past",
              "kind": "unresolved"
            },
            {
              "t": "text",
              "v": " - The Rat will trade the bullet in exchange for an  tier passive item."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "ref",
              "v": "Clone",
              "kind": "item"
            },
            {
              "t": "text",
              "v": " - Unused trades do not carry over after reviving with Clone."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "synref",
              "v": "Resourceful Indeed"
            },
            {
              "t": "text",
              "v": " - Prevents the Rat from appearing to steal items, and in doing so functionally prevents all trading."
            }
          ]
        }
      ],
      "notes": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "The Ring of the Resourceful Rat will not be stolen by the Resourceful Rat."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The Resourceful Rat will not trade with the player while in the "
            },
            {
              "t": "ref",
              "v": "Resourceful Rat's Lair",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": "."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Even if the player has killed the Resourceful Rat by beating him in "
            },
            {
              "t": "ref",
              "v": "Punch Out",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": ", he will still appear to steal items if the Ring of the Resourceful Rat is held and has remaining trades."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "While playing a "
            },
            {
              "t": "ref",
              "v": "Rainbow Run",
              "kind": "unresolved"
            },
            {
              "t": "text",
              "v": ", if the Resourceful Rat steals an item from a  "
            },
            {
              "t": "ref",
              "v": "Rainbow Chest",
              "kind": "unresolved"
            },
            {
              "t": "text",
              "v": ", the other seven items will disappear; thus, only one item per chest can be traded."
            }
          ]
        }
      ]
    }
  },
