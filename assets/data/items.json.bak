                },
                {
                  "t": "text",
                  "v": "."
                }
              ]
            }
          ]
        }
      ],
      "item_interactions": [
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "ref",
              "v": "Mimic Tooth Necklace",
              "kind": "item"
            },
            {
              "t": "text",
              "v": " - Picking up Mimic Tooth Necklace will unlock any chests rendered unopenable by Trusty Lockpicks, and convert them into mimics. These broken-locked mimics cannot be interacted with, but can still be shot to awaken them. They will drop their item on death like normal."
            }
          ]
