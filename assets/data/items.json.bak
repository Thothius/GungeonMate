        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "While held:\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "Grants a 20% discount at "
                },
                {
                  "t": "ref",
                  "v": "Shop",
