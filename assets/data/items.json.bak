    "wiki": {
      "effects": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "Throws a jar that shatters upon hitting the floor, releasing a swarm of angry bees that seek out and attack nearby enemies."
            }
          ]
        }
      ],
      "notes": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "The thrown jar must impact the ground in order to shatter and release the bees inside. If the jar is tossed into a pit, the jar will not shatter and no bees will be released."
