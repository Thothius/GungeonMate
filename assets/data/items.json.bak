              "kind": "character"
            },
            {
              "t": "text",
              "v": "."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "You can only hold a maximum of 2 charges at once, meaning that if you already have your flask at 2 charges and you go to another floor it won’t stack."
