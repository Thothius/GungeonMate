  {
    "name": "Lodestone Ammolet",
    "icon": "https://static.wikia.nocookie.net/enterthegungeon_gamepedia/images/1/18/Lodestone_Ammolet.png",
    "type": "Passive",
    "quote": "Blank Knockback Up",
    "quality": "D",
    "effect": "Increases the knockback of blanks. Grants an extra blank per floor.",
    "curse": 0.0,
    "coolness": 0.0,
    "wiki": {
      "effects": [
        {
          "tokens": [
