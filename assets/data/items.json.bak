  {
    "name": "Napalm Strike",
    "icon": "https://static.wikia.nocookie.net/enterthegungeon_gamepedia/images/1/19/Napalm_Strike.png",
    "type": "Active",
    "quote": "Smells Great!",
    "quality": "C",
    "effect": "Sets a large rectangular area on fire.",
    "curse": 0.0,
    "coolness": 0.0,
    "wiki": {
      "effects": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "Sets a large rectangular area on "
            },
            {
              "t": "ref",
              "v": "Goop",
              "kind": "lore"
            },
