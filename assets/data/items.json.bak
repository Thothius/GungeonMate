  {
    "name": "Old Knight's Flask",
    "icon": "https://static.wikia.nocookie.net/enterthegungeon_gamepedia/images/3/3c/Old_Knight%27s_Flask.png",
    "type": "Active",
    "quote": "Heals Per Floor",
    "quality": "A",
    "effect": "Heals the player for one heart upon use. Gains 2 charges each floor.",
    "curse": 0.0,
    "coolness": 0.0,
    "wiki": {
      "effects": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "Heals the player for one heart upon use."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Starts with 2 charges, and refills to 2 charges at the start of each floor."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "It does not charge through damage."
            }
          ]
        }
      ],
      "notes": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "The player is immobile while the item is being used, and the player is not healed until the item is finished being used.\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "The player is still vulnerable to damage while healing, so it is not recommended for in-combat recovery."
                }
              ]
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "This item does not heal "
