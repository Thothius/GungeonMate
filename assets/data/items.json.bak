    "effect": "Places a stationary turret that shoots at enemies. The turret will be destroyed if it takes enough damage.",
    "curse": 0.0,
    "coolness": 0.0,
    "wiki": {
      "effects": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "Places a stationary turret that shoots at enemies and blocks enemy projectiles.\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "The turret will be destroyed if it takes enough damage."
                }
              ]
            },
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "The turret will disappear after the room has been cleared or enough time has passed."
                }
              ]
            }
          ]
        }
      ],
      "notes": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "If the player has the "
            },
            {
              "t": "ref",
