              "t": "text",
              "v": "  "
            },
            {
              "t": "synref",
              "v": "Particle Flow"
            },
            {
              "t": "text",
              "v": " - If the player also has "
            },
            {
              "t": "ref",
              "v": "RPG",
              "kind": "gun"
            },
            {
              "t": "text",
              "v": ", "
            },
            {
              "t": "ref",
              "v": "Stinger",
              "kind": "gun"
            },
            {
              "t": "text",
              "v": ", "
            },
            {
              "t": "ref",
              "v": "Zorgun",
              "kind": "gun"
            },
            {
              "t": "text",
              "v": ", or "
            },
            {
              "t": "ref",
              "v": "Laser Lotus",
              "kind": "gun"
            },
