            },
            {
              "t": "text",
              "v": " fire projectiles from the duct taped gun."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "ref",
              "v": "Boxing Glove",
              "kind": "gun"
            },
            {
              "t": "text",
              "v": " - If the Boxing Glove is duct taped onto another gun, "
            },
            {
              "t": "text",
