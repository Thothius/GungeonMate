          ]
        }
      ]
    }
  },
  {
    "name": "Bloodied Scarf",
    "icon": "https://static.wikia.nocookie.net/enterthegungeon_gamepedia/images/9/94/Bloodied_Scarf.png",
    "type": "Passive",
    "quote": "Blink Away",
    "quality": "B",
    "effect": "Replaces the dodge roll with a teleport. Increases reload speed.",
    "curse": 0.0,
    "coolness": 0.0,
    "wiki": {
      "effects": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "Replaces the "
            },
            {
              "t": "ref",
              "v": "Dodge Roll (Move)",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": " with a teleport.\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "Pressing the dodge button teleports the player a short distance in the direction they are moving."
                }
              ]
            },
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "Holding down the dodge button allows the player to teleport to the location of the cursor, shown by a shadow of the player's character. With a controller, the shadow gets created at the player's current position, and is controlled by the right analog stick (so any aiming will displace the teleport target)."
                }
              ]
            },
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "If the player attempts to blink into a solid object or off a ledge, the shadow will turn red, and the player will be teleported as far as safely possible in that direction.\n"
                }
              ],
              "sub": [
                {
                  "tokens": [
                    {
                      "t": "text",
                      "v": "This safety also exists for flying players. This also means that if the flying player is already over a pit, then dodging will be entirely disabled unless there is solid ground in range."
                    }
                  ]
                },
                {
                  "tokens": [
                    {
                      "t": "text",
                      "v": "This also prevents the player from blinking onto rails that run over pits in "
                    },
                    {
                      "t": "ref",
                      "v": "Black Powder Mine",
                      "kind": "lore"
                    },
                    {
                      "t": "text",
                      "v": ", and blinking onto the spine bridge that appears after defeating the "
                    },
                    {
                      "t": "ref",
                      "v": "Dragun",
                      "kind": "lore"
                    },
                    {
                      "t": "text",
                      "v": "."
                    }
                  ]
                }
              ]
            },
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "Blinking onto bullets will cause them to dissipate, and they won't cause damage."
                }
              ]
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Decreases reload times by 30%."
            }
          ]
        }
      ],
      "item_interactions": [
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "ref",
              "v": "Rolling Eye",
              "kind": "item"
            },
            {
              "t": "text",
              "v": " /  "
            },
            {
              "t": "ref",
              "v": "Resourceful Sack",
              "kind": "item"
            },
            {
              "t": "text",
              "v": " /  "
            },
            {
              "t": "ref",
              "v": "Daruma",
              "kind": "item"
            },
            {
              "t": "text",
              "v": " - Items that require the player to roll through bullets become useless, as rolls no longer pass over bullets."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "ref",
              "v": "Roll Bomb",
              "kind": "item"
            },
            {
              "t": "text",
              "v": " - Teleporting via the Bloodied Scarf drops a bomb at the position the player blinked away from."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "ref",
              "v": "Busted Television",
              "kind": "item"
            },
            {
              "t": "text",
              "v": " - Blinking with the Bloodied Scarf will still drop the Busted Television."
            }
          ]
        }
      ],
      "notes": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "Can be used to blink through locked doors which otherwise require the player to use a key or stand on a pressure plate to open.\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "Does not work if the door is facing downward."
                }
              ]
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Can be used to find secret rooms. The teleport icon will appear grey when over the part of the wall that becomes the path. Technically, you can enter the room, but you won't be able to see anything without using a blank outside of the secret room. Blanking inside the secret room will not reveal it."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Can be used to rescue "
            },
            {
              "t": "ref",
              "v": "NPCs",
              "kind": "unresolved"
            },
            {
              "t": "text",
              "v": " before acquiring the "
            },
            {
              "t": "ref",
              "v": "Pickups",
              "kind": "unresolved"
            },
            {
              "t": "text",
              "v": " by teleporting into their cell."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The player can teleport through the two walls that access the entrance to the "
            },
            {
              "t": "ref",
              "v": "Resourceful Rat",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": "'s lair,not being able to see anything but still able to use the "
            },
            {
              "t": "ref",
              "v": "Gnawed Key",
              "kind": "unresolved"
            },
            {
              "t": "text",
              "v": " to open the entrance."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Can be used to teleport behind "
            },
            {
              "t": "ref",
              "v": "Wallmonger",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": ", out of reach of the boss's attacks. However, the camera will remained locked on to the Wallmonger."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Repeatedly teleporting in place can effectively grant immunity to bullets."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "When using the Bloodied Scarf in "
            },
            {
              "t": "ref",
              "v": "The Aimless Void",
              "kind": "unresolved"
            },
            {
              "t": "text",
              "v": ", the player will dodge roll normally instead of teleporting."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "If the player is on fire, teleporting will instantly cause the fire to go away."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The teleport is still considered a dodge roll despite having replaced the action, so teleporting can still fail challenges  issued by the "
            },
            {
              "t": "ref",
              "v": "Gunsling King and Manservantes",
              "kind": "unresolved"
            },
            {
              "t": "text",
              "v": " to clear rooms without dodge rolling."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The teleport can be used to reach normally inaccessible areas present in certain layouts of "
            },
            {
              "t": "ref",
              "v": "Winchester (NPC)",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": "'s games and improve the vantage point, and the player will not be penalised for doing so."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "In the patch notes for "
            },
            {
              "t": "ref",
              "v": "V1.0.2",
              "kind": "unresolved"
            },
            {
              "t": "text",
              "v": ", the Bloodied Scarf is referred to as the "
            },
            {
              "t": "text",
              "v": "Red Bandana",
              "style": "i"
            },
            {
              "t": "text",
              "v": "."
            }
          ]
        }
      ],
      "trivia": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "This item's description, appearance, and effect are references to the PS2 game "
            },
            {
              "t": "ext",
              "v": "Shinobi",
              "url": "https://en.wikipedia.org/wiki/Shinobi_(2002_video_game)"
            },
            {
              "t": "text",
              "v": ", in which the main character Hotsuma wears an unusually long red scarf."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The item's description, appearance, and effect may also reference the character Hidden Phantom from the Megaman Zero series."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The  "
            },
            {
              "t": "synref",
              "v": "Raizo's Stuff"
            },
            {
              "t": "text",
              "v": " - synergy may reference the movie Ninja Assassin in which the character Raizo is on the run from his former ninja clan."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "This item's appearance may reference Hyper Light Drifter in which the main character wears a long red scarf."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The ‘skilled assassin’ in the description most likely refers to "
            },
            {
              "t": "ref",
              "v": "Unused and Cut Content",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": ", as the sprite name for the Bloodied Scarf is ‘Ninja Headband’."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The Bloodied Scarf shares its sprite shape with "
            },
            {
              "t": "ref",
              "v": "Number 2",
              "kind": "item"
            },
            {
              "t": "text",
              "v": " and "
            },
            {
              "t": "ref",
              "v": "Ancient Hero's Bandana",
              "kind": "item"
            },
            {
              "t": "text",
              "v": "."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The Bloodied Scarf might be the scarf mentioned in the "
            },
            {
              "t": "ref",
              "v": "Snowballets",
              "kind": "item"
            },
            {
              "t": "text",
              "v": " description; \"Arguments frequently break out over the sole scarf in the Gungeon\". Similarly, \"Arguments\" might refer to how polarized opinion the about the Bloodied Scarf is among the player base."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "You can get the shadow to fall down a pit due to a bug, where it shows a red version of your character falling."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "  Possible Bug The special UI icon for Bloodied Scarf in the "
            },
            {
              "t": "ref",
              "v": "Chinese Mobile Version",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": " of "
            },
            {
              "t": "text",
              "v": "Enter the Gungeon",
              "style": "i"
            },
            {
              "t": "text",
              "v": " appears blue. This is likely due to incorrect colour encoding issues when saving the file, as the same thing can be seen in other UI textures."
            }
          ]
        }
      ]
    }
  },
  {
    "name": "Muscle Relaxant",
    "icon": "https://static.wikia.nocookie.net/enterthegungeon_gamepedia/images/1/15/Muscle_Relaxant.png",
    "type": "Passive",
    "quote": "Loosen Up",
    "quality": "B",
    "effect": "Decreases bullet spread by 66%.",
    "curse": 0.0,
    "coolness": 0.0,
    "wiki": {
      "effects": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "Reduces weapon's spread by 66%, increasing accuracy."
            }
          ]
        }
      ],
      "notes": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "This item is a reference to similar muscle relaxant drugs in the "
            },
            {
              "t": "text",
              "v": "Metal Gear Solid",
              "style": "i"
            },
            {
              "t": "text",
              "v": " series, such as Diazepam or Pentazemin."
            }
          ]
        }
      ]
    }
  },
  {
    "name": "Hip Holster",
    "icon": "https://static.wikia.nocookie.net/enterthegungeon_gamepedia/images/b/b0/Hip_Holster.png",
    "type": "Passive",
    "quote": "Quickdraw",
    "quality": "B",
    "effect": "Reloading a weapon fires it once for free.",
    "curse": 0.0,
    "coolness": 0.0,
    "wiki": {
      "effects": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "Reloading a weapon fires a single bullet from it for free. The bullet fired is always perfectly accurate, even if the gun is not."
            }
          ]
        }
      ],
      "notes": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "This item works well with single shot weapons, effectively doubling their firepower."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "This item appears to fire the \"Default\" version of a projectile - for example, on Charged weapons that have an \"uncharged\" state like the "
            },
            {
              "t": "ref",
              "v": "Megahand",
              "kind": "gun"
            },
            {
              "t": "text",
              "v": " and "
            },
            {
              "t": "ref",
              "v": "Heroine",
              "kind": "gun"
            },
            {
              "t": "text",
              "v": ", the Hip Holster will fire the uncharged projectile."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Weapons that fire multiple bullets every shot will instead fire only a single bullet, often rendering the projectile near-ineffective.\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "ref",
                  "v": "Mass Shotgun",
                  "kind": "gun"
                },
                {
                  "t": "text",
                  "v": " is a notable exception, as the single projectile it initially fires "
                },
                {
                  "t": "text",
                  "v": "is",
                  "style": "i"
                },
                {
                  "t": "text",
                  "v": " duplicated by Hip Holster."
                }
              ]
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Reloading while in "
            },
            {
              "t": "ref",
              "v": "Shop",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": "'s shop will not aggravate him.\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "This can be especially useful when trying to find "
                },
                {
                  "t": "ref",
                  "v": "Secret Rooms",
                  "kind": "lore"
                },
                {
                  "t": "text",
                  "v": " inside of it."
                }
              ]
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "This item affects the "
            },
            {
              "t": "ref",
              "v": "Prize Pistol",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": " received during "
            },
            {
              "t": "ref",
              "v": "Winchester (NPC)",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": "'s minigame, which can help improve the chances of winning."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Damage bonuses do not affect the bonus projectile."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Bonus projectile spawns from the player's center instead of the held gun, so peeking might not be a good way to utilize this bonus projectile."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Despite the bonus projectile being shot at the start of a reload, cancelling a reload by swapping to another weapon and back will not trigger Hip Holster's effect when initiating reload with the same weapon."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Owning duplicates of this item will not affect it in any sort of way."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The projectile fired from Hip Holster is not affected by the speed reduction from "
            },
            {
              "t": "ref",
              "v": "Heavy Bullets",
              "kind": "item"
            },
            {
              "t": "text",
              "v": " or "
            },
            {
              "t": "ref",
              "v": "Stout Bullets",
              "kind": "item"
            },
            {
              "t": "text",
              "v": ", but is affected by their size (& presumably damage) increase."
            }
          ]
        }
      ],
      "tips": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "For guns that have no reload (e.g. "
            },
            {
              "t": "ref",
              "v": "Pitchfork",
              "kind": "gun"
            },
            {
              "t": "text",
              "v": "), it is possible to fire the extra bullet by clicking the reload button, essentially firing an extra bullet with no consequence (as there is no reload time). However, this is only possible if a bullet has been fired from that gun after the last reload.\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "Therefore, spamming reload while shooting one of these guns to get nearly double the firepower at no extra cost."
                }
              ]
            }
          ]
        }
      ],
      "trivia": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "The synergy \"Pretty Good\" is a reference to Revolver Ocelot's quote, \"You're pretty good\" in Metal Gear Solid."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The \"Quick and the Gundead\" synergy is a reference to 1995 western film \""
            },
            {
              "t": "ext",
              "v": "The Quick and the Dead",
              "url": "https://en.wikipedia.org/wiki/The_Quick_and_the_Dead_(1995_film)"
            },
            {
              "t": "text",
              "v": "\"."
            }
          ]
        }
      ]
    }
  },
  {
    "name": "Clone",
    "icon": "https://static.wikia.nocookie.net/enterthegungeon_gamepedia/images/3/34/Clone.png",
    "type": "Passive",
    "quote": "The Real Me",
    "quality": "1S",
    "effect": "Upon death, the player is revived in the starting room of the first floor, retaining all items and guns.",
    "curse": 0.0,
    "coolness": 0.0,
    "wiki": {
      "effects": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "Upon death, the player respawns at the very beginning of their run with full health, as well as all of their accumulated "
            },
            {
              "t": "ref",
              "v": "Guns",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": ", "
            },
            {
              "t": "ref",
              "v": "Items",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": ", and "
            },
            {
              "t": "ref",
              "v": "Pickups",
              "kind": "unresolved"
            },
            {
              "t": "text",
              "v": "- with the exception of Clone itself. This essentially allows the player to immediately start a new run with all of the loot of the last run.\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "The "
                },
                {
                  "t": "ref",
                  "v": "The Robot",
                  "kind": "character"
                },
                {
                  "t": "text",
                  "v": " will always respawn with 6  "
                },
                {
                  "t": "ref",
                  "v": "Armor",
                  "kind": "lore"
                },
                {
                  "t": "text",
                  "v": "."
                }
              ]
            },
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "The player always respawns on the chamber they started the original run in. Usually this is the "
                },
                {
                  "t": "ref",
                  "v": "Keep of the Lead Lord",
                  "kind": "lore"
                },
                {
                  "t": "text",
                  "v": ", however if a "
                },
                {
                  "t": "ref",
                  "v": "Shortcut",
                  "kind": "unresolved"
                },
                {
                  "t": "text",
                  "v": " was used to start the run in a different chamber, that chamber will be where the player revives."
                }
              ]
            },
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "Stat changes not tied to items, such as  "
                },
                {
                  "t": "ref",
                  "v": "Curse",
                  "kind": "stat"
                },
                {
                  "t": "text",
                  "v": ", are "
                },
                {
                  "t": "text",
                  "v": "not lost",
                  "style": "i"
                },
                {
                  "t": "text",
                  "v": " upon reviving with Clone."
                }
              ]
            }
          ]
        }
      ],
      "item_interactions": [
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "ref",
              "v": "Pig",
              "kind": "item"
            },
            {
              "t": "text",
              "v": " /  "
            },
            {
              "t": "ref",
              "v": "Gun Soul",
              "kind": "item"
            },
            {
              "t": "text",
              "v": " - The resurrection effect of these items always triggers first, before clone."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "ref",
              "v": "Gun Soul",
              "kind": "item"
            },
            {
              "t": "text",
              "v": " - If the player dies while in the Gun Soul's spirit form, they will respawn in the first chamber with clone like normal. This will remove the players spirit form, but will "
            },
            {
              "t": "text",
              "v": "not",
              "style": "i"
            },
            {
              "t": "text",
              "v": " restore their lost heart containers.\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "Saving and loading the game with the "
                },
                {
                  "t": "ref",
                  "v": "Save Button",
                  "kind": "unresolved"
                },
                {
                  "t": "text",
                  "v": " will restore the players lost health, as will finding and using another Gun Soul."
                }
              ]
            },
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "This effect is not necessarily a bug, as "
                },
                {
                  "t": "ref",
                  "v": "Dodge Roll",
                  "kind": "lore"
                },
                {
                  "t": "text",
                  "v": " is aware of this interaction, and has not fixed it- leaving the souls of unfortunate clones lost to the shifting Gungeon below."
                }
              ]
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "ref",
              "v": "Ser Junkan",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": " - If Ser Junkan is in Holy Knight form, he will save the player from death upon them perishing- much like the pig. Unlike the pig, this effect triggers "
            },
            {
              "t": "text",
              "v": "before",
              "style": "i"
            },
            {
              "t": "text",
              "v": " clone."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "ref",
              "v": "Spice",
              "kind": "item"
            },
            {
              "t": "text",
              "v": " - The stat changes of spice, and the pervasiveness of Spice in the loot pool are not reset upon reviving with Clone."
            }
          ]
        }
      ],
      "notes": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "If the "
            },
            {
              "t": "ref",
              "v": "Shop",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": " has been angered (ex. shooting in shop, stealing), he will not return after revival."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Allows the collection of duplicate "
            },
            {
              "t": "ref",
              "v": "Master Round I",
              "kind": "item"
            },
            {
              "t": "text",
              "v": " on a single run, all of which count towards unlocking the "
            },
            {
              "t": "ref",
              "v": "Super Hot Watch",
              "kind": "item"
            },
            {
              "t": "text",
              "v": "."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "If the player perfects the "
            },
            {
              "t": "ref",
              "v": "Resourceful Rat",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": " fights, he will still not steal from the player after revival."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Players can fight the "
            },
            {
              "t": "ref",
              "v": "Resourceful Rat",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": " again after respawning, however, upon entering the Resourceful Rat's lair, any extra "
            },
            {
              "t": "ref",
              "v": "Pickups",
              "kind": "unresolved"
            },
            {
              "t": "text",
              "v": " will disappear from the player's inventory."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "If the player is holding more than one Clone when they die, the extra Clones will also be removed from the player's inventory when they revive. However, extra Clones can still be obtained after the player dies."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "If the player obtains the "
            },
            {
              "t": "ref",
              "v": "High Dragun",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": " before they die, it's not lost after revival."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "If the player is one hit away from death and takes damage while having "
            },
            {
              "t": "ref",
              "v": "Glass Guon Stone",
              "kind": "item"
            },
            {
              "t": "text",
              "v": ", they will not break and will remain with the player when they revive."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "If the player respawns from a Clone, they can get another Clone in a chest afterwards. However, it's extremely rare and usually happens in Rainbow Mode."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "In "
            },
            {
              "t": "ref",
              "v": "Co-op",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": ", if "
            },
            {
              "t": "ref",
              "v": "The Paradox",
              "kind": "character"
            },
            {
              "t": "text",
              "v": " starts with Clone, it can be traded with "
            },
            {
              "t": "ref",
              "v": "The Cultist",
              "kind": "character"
            },
            {
              "t": "text",
              "v": " and allows The Paradox to continuously carry clones whenever they die and when clone is activated from The Cultist, allowing excessive clone runs unless the game crashes or the players save and quit the game."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "In "
            },
            {
              "t": "ref",
              "v": "Co-op",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": ", if the player with Clone dies first, the Clone is consumed but the effect doesn't trigger."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "IF the player has multiple clones at once, all Clones will be consumed upon death."
            }
          ]
        }
      ],
      "trivia": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "The item’s Ammonomicon Entry may be a reference to the 1993 song \""
            },
            {
              "t": "ext",
              "v": "Sweating Bullets",
              "url": "https://en.m.wikipedia.org/wiki/Sweating_Bullets_(song)"
            },
            {
              "t": "text",
              "v": "\" by the American thrash metal band Megadeth."
            }
          ]
        }
      ]
    }
  },
  {
