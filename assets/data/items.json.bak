    "quality": "D",
    "effect": "Flipping a table briefly slows down time and triple the player's shots.",
    "curse": 0.0,
    "coolness": 0.0,
    "wiki": {
      "effects": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "Flipping a "
            },
            {
              "t": "ref",
              "v": "Table",
              "kind": "unresolved"
            },
            {
              "t": "text",
              "v": " briefly slows down time and triples number of bullets fired by the player for three seconds."
            }
          ]
        }
      ],
      "notes": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "If duplicates of this item are somehow obtained, each copy of Table Tech Sight held will multiply the players shots by 3 an additional time.\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "Sometimes flipping tables with duplicates may not activate time slowing down but shots still remain multiplied as usual."
