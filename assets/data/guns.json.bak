                  "v": "Robot's Left Hand",
                  "kind": "gun"
                },
                {
                  "t": "text",
                  "v": ", "
                },
                {
                  "t": "ref",
                  "v": "Heroine",
                  "kind": "gun"
                },
                {
                  "t": "text",
                  "v": ", "
                },
                {
                  "t": "ref",
                  "v": "Flame Hand",
                  "kind": "gun"
                },
                {
                  "t": "text",
                  "v": " and "
