            }
          ]
        }
      ],
      "item_interactions": [
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "ref",
              "v": "Drum Clip",
              "kind": "item"
            },
            {
              "t": "text",
              "v": " - Increasing the magazine size of this weapon will only add additional ice shots. Only the final shot in the clip is the slug."
            }
          ]
        }
      ],
      "notes": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "Because the ice shots of the Ice Breaker use the "
            },
            {
              "t": "text",
              "v": "Ice",
              "style": "i"
            },
            {
              "t": "text",
              "v": " damage type, they deal 1.5x damage to "
