              "t": "text",
              "v": ", the guns are dual wielded. Removed because it contains a starting weapon."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "ref",
              "v": "Unused and Cut Content/Synergies",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": " - ("
            },
            {
              "t": "text",
              "v": "CustomSynergyType.THE_TERMINATOR",
              "style": "code"
            },
            {
              "t": "text",
              "v": ") If the player has "
            },
            {
              "t": "ref",
              "v": "Winchester",
              "kind": "gun"
            },
            {
              "t": "text",
              "v": ", it causes an unknown effect."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "See You Later",
              "style": "i"
            },
            {
              "t": "text",
              "v": " is a reference to the famous quote \"Hasta la vista\" from "
            },
            {
              "t": "ext",
              "v": "The Terminator",
              "url": "https://en.wikipedia.org/wiki/The_Terminator"
            },
            {
              "t": "text",
              "v": "."
            }
          ]
        }
      ]
    }
  },
  {
