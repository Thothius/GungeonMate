  {
    "name": "Cobalt Hammer",
    "icon": "https://static.wikia.nocookie.net/enterthegungeon_gamepedia/images/1/1f/Cobalt_Hammer.png",
    "notes": "Fires blue thunderbolts. Charging the weapon makes it fire thunderbolts in four directions.",
    "quote": "Break Stuff",
    "quality": "A",
    "type": "Charged",
    "dps": "57.8",
    "magazine_size": "6",
    "ammo_capacity": "60",
    "damage": "Uncharged: 26 Charged: 36",
    "fire_rate": "0.30",
    "reload_time": "1.2",
    "shot_speed": "100",
    "range": "1,000",
    "force": "80",
    "spread": "0",
    "class": "CHARGE",
    "curse": 0.0,
    "coolness": 0.0,
    "wiki": {
      "effects": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "Fires instantaneous piercing blue lasers."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "When fully charged, the "
            },
            {
              "t": "ref",
              "v": "Gungeoneers",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": " will strike the gun against the ground, damaging all enemies in a short radius and firing lasers in four to five directions which can electrify water."
            }
          ]
        }
      ],
      "item_interactions": [
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "ref",
              "v": "Scattershot",
              "kind": "item"
            },
            {
              "t": "text",
              "v": " - Items that increase the number of bullets fired will increase the ammo usage of charged shots."
            }
          ]
        }
      ],
      "notes": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "This gun is a reference to the streamers Cobalt Streak and Richard_Hammer, who before the release of "
            },
            {
              "t": "text",
              "v": "Enter the Gungeon",
              "style": "i"
            },
            {
              "t": "text",
              "v": " were known for playing "
            },
            {
              "t": "text",
              "v": "The Binding of Isaac",
              "style": "i"
            },
            {
              "t": "text",
              "v": ", another shooter rogue-like. They were also known to \"break\" games or exploit game mechanics to a ridiculous, often beneficial degree.\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "The item description refers to their several day long stream leading up to Enter the Gungeon's release, where the two would take turns streaming and sleeping."
                }
              ]
            },
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "This may also be a reference to the final level of "
                },
                {
                  "t": "text",
                  "v": "Cave Story,",
                  "style": "i"
                },
                {
                  "t": "text",
                  "v": " where the protagonist ties his passed out companion to his back."
                }
              ]
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The thunder effect and sound are a reference to "
            },
            {
              "t": "ext",
              "v": "Mjölnir",
              "url": "https://en.wikipedia.org/wiki/Mj%C3%B6lnir"
            },
            {
              "t": "text",
              "v": ", the hammer used by the Norse god of thunder, "
            },
            {
              "t": "ext",
              "v": "Thor",
              "url": "https://en.wikipedia.org/wiki/Thor"
            },
            {
              "t": "text",
              "v": "."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The initial release of "
            },
            {
              "t": "ref",
              "v": "Enter the Gungeon",
              "kind": "unresolved"
            },
            {
              "t": "text",
              "v": " came with several special Steam keys for the game which would automatically unlock the Cobalt Hammer when redeemed."
            }
          ]
        }
      ]
    }
  },
  {
    "name": "Frost Giant",
    "icon": "https://static.wikia.nocookie.net/enterthegungeon_gamepedia/images/9/99/Frost_Giant.png",
    "notes": "Fires big bullets that have a chance to freeze .",
    "quote": "Icy Grasp",
    "quality": "B",
    "type": "Semiautomatic",
    "dps": "80.0",
    "magazine_size": "12",
    "ammo_capacity": "130",
    "damage": "12",
    "fire_rate": "0.001",
    "reload_time": "1.6",
    "shot_speed": "20",
    "range": "30",
    "force": "10",
    "spread": "12",
    "class": "ICE",
    "curse": 0.0,
    "coolness": 0.0,
    "wiki": {
      "notes": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "The fire rate is only limited by how quickly the player can press the fire button, giving it high potential damage per second."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "If the player also has "
            },
            {
              "t": "ref",
              "v": "Helix Bullets",
              "kind": "item"
            },
            {
              "t": "text",
              "v": ", both bullets follow the same path, as opposed to the normal helix pattern."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "True to its name, the weapon is so physically large that the Gungeoneers must carry it with both hands, one on the handle and the other under the barrel, despite the gun being a revolver."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The synergy Jotun Time is a reference to Jotunheim, one of the nine realms in Norse mythology, and the realm that frost giants inhabit.\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "The fact that this synergy increases the damage of thrown guns may be a reference to the meme phrase \"yeet,\" meaning to throw something with great force, which is often written in the past tense as \"yote,\" pronounced similarly to Jotun."
                }
              ]
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The synergy \"Why's Bullet Crying?\" may be a reference to one of the Heavy's voice lines from the game "
            },
            {
              "t": "ext",
              "v": "Team Fortress 2",
              "url": "https://en.wikipedia.org/wiki/Team_Fortress_2"
            },
            {
              "t": "text",
              "v": "."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The yeti in the \"Why bullet's crying?\" synergy may be a reference to the yetis seen in "
            },
            {
              "t": "ext",
              "v": "Fork Parker's holiday profit hike",
              "url": "https://store.steampowered.com/app/339120/Fork_Parkers_Holiday_Profit_Hike/"
            },
            {
              "t": "text",
              "v": "."
            }
          ]
        }
      ]
    }
  },
  {
    "name": "Bullet Bore",
    "icon": "https://static.wikia.nocookie.net/enterthegungeon_gamepedia/images/3/32/Bullet_Bore.png",
    "notes": "Fires a drill that home in on enemies, stun them, and explode after a short delay.",
    "quote": "Mind Muncher",
    "quality": "A",
    "type": "Semiautomatic",
    "dps": "23.3",
    "magazine_size": "1",
    "ammo_capacity": "75",
    "damage": "10 (impact) + 25 (explosion)",
    "fire_rate": "1.00",
    "reload_time": "1.5",
    "shot_speed": "20",
    "range": "1,000",
    "force": "8",
    "spread": "5",
    "class": "EXPLOSIVE",
    "curse": 0.0,
    "coolness": 0.0,
    "wiki": {
      "notes": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "This gun can hit "
            },
            {
              "t": "ref",
              "v": "Cannonbalrog",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": " and "
            },
            {
              "t": "ref",
              "v": "High Priest",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": " during attacks where not normally possible."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "ref",
              "v": "Helix Bullets",
              "kind": "item"
            },
            {
              "t": "text",
              "v": " will cause the bullets to only shoot and have piercing abilities, without the explosion and stunning effect."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The drills fired are able to kill the mines spawned by the "
            },
            {
              "t": "ref",
              "v": "Mine Flayer",
              "kind": "unresolved"
            },
            {
              "t": "text",
              "v": "."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "This gun is a reference to the Cerebral Bore from "
            },
            {
              "t": "ext",
              "v": "Turok 2: Seeds of Evil",
              "url": "https://en.wikipedia.org/wiki/Turok_2:_Seeds_of_Evil"
            },
            {
              "t": "text",
              "v": ".\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "This is further shown by the synergy  "
                },
                {
                  "t": "synref",
                  "v": "Cerebral Bros"
                },
                {
                  "t": "text",
                  "v": " which is a slightly altered version of the Cerebral Bore's name."
                }
              ]
            },
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "The synergy  "
                },
                {
                  "t": "synref",
                  "v": "Cerebral Bros"
                },
                {
                  "t": "text",
                  "v": " may also be a reference to the Mario Brothers, as they are commonly referred to as the Mario Bros and the weapon's color before and after the synergy match the colors of the two brothers' outfits."
                }
              ]
            }
          ]
        }
      ]
    }
  },
  {
    "name": "Cat Claw",
    "icon": "https://static.wikia.nocookie.net/enterthegungeon_gamepedia/images/a/ab/Cat_Claw.png",
    "notes": "Fires darts that home in on enemies and explode after a short delay. The darts deal minimal damage on contact.",
    "quote": "Kneadle Your Foes!",
    "quality": "A",
    "type": "Automatic",
    "dps": "65.5",
    "magazine_size": "33",
    "ammo_capacity": "400",
    "damage": "2 (impact) + 10 (explosion)",
    "fire_rate": "0.15",
    "reload_time": "1.2",
    "shot_speed": "23",
    "range": "1,000",
    "force": "2",
    "spread": "5",
    "class": "FULLAUTO",
    "curse": 0.0,
    "coolness": 0.0,
    "wiki": {
      "effects": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "Fires small homing needles that stick into targets.\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "These needles have a high homing force but low homing radius, meaning that they can completely change their direction to hit a target but can only 'see' targets within 4 tiles."
                }
              ]
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "After an enemy has not been struck with a new needle for 0.5 seconds, all needles currently stuck into the enemy will simultaneously explode, damaging the target and everything else within a 2 tile radius of its epicenter."
            }
          ]
        }
      ],
      "notes": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "As needles only detonate once new needles stop being attached, it is easy to accidentally 'overkill' enemies. For example, it may take 6 darts to kill an enemy, but up to 33 darts can be attached, causing 27 shots to be excess damage and therefore wasted ammo.\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "For small targets, it is typically best to pause once a small number of needles are attached to allow them to detonate."
                }
              ]
            },
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "The DPS cap for bosses will limit the amount of damage the explosives do."
                }
              ]
            },
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "Firing single shots at a rate of 2-3 per second will cause each dart fired to have a separate countdown. This tactic prevents much overkill and also interferes with the target's shooting due to the constant explosions, but it greatly reduces DPS."
                }
              ]
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Prior to the "
            },
            {
              "t": "ref",
              "v": "Supply Drop Update",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": ", the darts did not deal any contact damage and the explosions only dealt 5 damage."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "This gun's projectiles, as well as the word \"Kneadle\" in the Pickup Quote, are references to the Needler weapon from the Halo franchise, supported/further referenced by the  "
            },
            {
              "t": "synref",
              "v": "Spartan Loadout"
            },
            {
              "t": "text",
              "v": " synergy.\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "The word \"Kneadle\", the name Cat Claw, and the flexing prongs on the muzzle are a reference to the way cats sometimes \"knead\" surfaces with their claws."
                }
              ]
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "This gun's name is likely a reference to the dirk named \"Cat Claw\" that was wielded by the Gray Mouser, a Fritz Leiber character. The quest to unlock this gun is given by Frifle and the Grey Mauser, with the latter NPC being a parody of the Gray Mouser."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "This gun resembles the Dragon Claw from "
            },
            {
              "t": "ext",
              "v": "Heretic",
              "url": "https://en.wikipedia.org/wiki/Heretic_(video_game)"
            },
            {
              "t": "text",
              "v": "."
            }
          ]
        }
      ]
    }
  },
  {
    "name": "Megahand",
    "icon": "https://static.wikia.nocookie.net/enterthegungeon_gamepedia/images/3/3e/Megahand.png",
    "notes": "Charges to fire a larger powerful bullet.",
    "quote": "-P-",
    "quality": "B",
    "type": "Charged",
    "dps": "62.4",
    "magazine_size": "18",
    "ammo_capacity": "200",
    "damage": "Uncharged: 6 Charged: 45",
    "fire_rate": "0.07",
    "reload_time": "0.54",
    "shot_speed": "20",
    "range": "1,000",
    "force": "8",
    "spread": "0",
    "class": "CHARGE",
    "curse": 0.0,
    "coolness": 0.0,
    "wiki": {
      "notes": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "If the player has certain items or guns, reloading with a full magazine switches the Megahand to a different mode. If the corresponding item or gun is dropped while in an alternative mode, the mode is still kept until the player next reloads a full magazine.\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": " "
                },
                {
                  "t": "synref",
                  "v": "Get Equipped With -A-"
                },
                {
                  "t": "text",
                  "v": " - "
                },
                {
                  "t": "ref",
                  "v": "Balloon Gun",
                  "kind": "gun"
                },
                {
                  "t": "text",
                  "v": ": Air Shooter, which fires "
                },
                {
                  "t": "ref",
                  "v": "Balloon Gun",
                  "kind": "gun"
                },
                {
                  "t": "text",
                  "v": " tornadoes when uncharged."
                }
              ]
            },
            {
              "tokens": [
                {
                  "t": "text",
                  "v": " "
                },
                {
                  "t": "synref",
                  "v": "Get Equipped With -B-"
                },
                {
                  "t": "text",
                  "v": " - "
                },
                {
                  "t": "ref",
                  "v": "Mega Douser",
                  "kind": "gun"
                },
                {
                  "t": "text",
                  "v": "/"
                },
                {
                  "t": "ref",
                  "v": "Bubble Blaster",
                  "kind": "gun"
                },
                {
                  "t": "text",
                  "v": ": Bubble Lead, which fires "
                },
                {
                  "t": "ref",
                  "v": "Bubble Blaster",
                  "kind": "gun"
                },
                {
                  "t": "text",
                  "v": " shots when uncharged."
                }
              ]
            },
            {
              "tokens": [
                {
                  "t": "text",
                  "v": " "
                },
                {
                  "t": "synref",
                  "v": "Get Equipped With -C-"
                },
                {
                  "t": "text",
                  "v": " - "
                },
                {
                  "t": "ref",
                  "v": "Bullet Bore",
                  "kind": "gun"
                },
                {
                  "t": "text",
                  "v": ": Crash Bomber, which fires "
                },
                {
                  "t": "ref",
                  "v": "Bullet Bore",
                  "kind": "gun"
                },
                {
                  "t": "text",
                  "v": " drills when fully charged."
                }
              ]
            },
            {
              "tokens": [
                {
                  "t": "text",
                  "v": " "
                },
                {
                  "t": "synref",
                  "v": "Get Equipped With -F-"
                },
                {
                  "t": "text",
                  "v": " - "
                },
                {
                  "t": "ref",
                  "v": "Camera",
                  "kind": "gun"
                },
                {
                  "t": "text",
                  "v": "/"
                },
                {
                  "t": "ref",
                  "v": "Aged Bell",
                  "kind": "item"
                },
                {
                  "t": "text",
                  "v": ": Time Stopper, which makes charged shots stop time for a few seconds and damages all enemies onscreen. Charged shots cost 5 ammo in this mode, while only using one shot in the magazine."
                }
              ]
            },
            {
              "tokens": [
                {
                  "t": "text",
                  "v": " "
                },
                {
                  "t": "synref",
                  "v": "Get Equipped With -H-"
                },
                {
                  "t": "text",
                  "v": " - "
                },
                {
                  "t": "ref",
                  "v": "Hot Lead",
                  "kind": "item"
                },
                {
                  "t": "text",
                  "v": ": Atomic Fire,  which fires piercing fireballs when uncharged that set everything in their path on fire."
                }
              ]
            },
            {
              "tokens": [
                {
                  "t": "text",
                  "v": " "
                },
                {
                  "t": "synref",
                  "v": "Get Equipped With -M-"
                },
                {
                  "t": "text",
                  "v": " - "
                },
                {
                  "t": "ref",
                  "v": "Buzzkill",
                  "kind": "gun"
                },
                {
                  "t": "text",
                  "v": ": Metal Blade, which fires blades when uncharged."
                }
              ]
            },
            {
              "tokens": [
                {
                  "t": "text",
                  "v": " "
                },
                {
                  "t": "synref",
                  "v": "Get Equipped With -Q-"
                },
                {
                  "t": "text",
                  "v": " - "
                },
                {
                  "t": "ref",
                  "v": "Boomerang",
                  "kind": "item"
                },
                {
                  "t": "text",
                  "v": ": Quick Boomerang,  which fires small boomerangs when uncharged that stun enemies."
                }
              ]
            },
            {
              "tokens": [
                {
                  "t": "text",
                  "v": " "
                },
                {
                  "t": "synref",
                  "v": "Get Equipped With -W-"
                },
                {
                  "t": "text",
                  "v": " - "
                },
                {
                  "t": "ref",
                  "v": "Mahoguny",
                  "kind": "gun"
                },
                {
                  "t": "text",
                  "v": ": Leaf Shield, which fires leaves when uncharged. Killing enemies causes leaves to orbit the player, blocking enemy shots, similar to "
                },
                {
                  "t": "ref",
                  "v": "Knife Shield",
                  "kind": "item"
                },
                {
                  "t": "text",
                  "v": ". These leaves vanish when switched to a different gun, and reappear when you switch back to Megahand"
                }
              ]
            }
          ]
        }
      ],
      "trivia": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "This gun is a reference to "
            },
            {
              "t": "ext",
              "v": "Mega Man",
              "url": "https://en.wikipedia.org/wiki/Mega_Man_(character)"
            },
            {
              "t": "text",
              "v": "'s arm cannon, called the "
            },
            {
              "t": "text",
              "v": "Mega Buster",
              "style": "i"
            },
            {
              "t": "text",
              "v": ".\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "The tooltip references how in "
                },
                {
                  "t": "text",
                  "v": "Mega Man",
                  "style": "i"
                },
                {
                  "t": "text",
                  "v": " through "
                },
                {
                  "t": "text",
                  "v": "Mega Man 3",
                  "style": "i"
                },
                {
                  "t": "text",
                  "v": ", the Mega Buster was represented in menus by the Symbol P."
                }
              ]
            },
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "The colors the Megahand flashes while charging most closely resemble those in "
                },
                {
                  "t": "text",
                  "v": "Mega Man 4,",
                  "style": "i"
                },
                {
                  "t": "text",
                  "v": " the game in which the ability to charge the Buster was first introduced.\n"
                }
              ],
              "sub": [
                {
                  "tokens": [
                    {
                      "t": "text",
                      "v": "Despite this, the charged shot itself more closely resembles those of later Mega Man games."
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The different modes gained from the gun's synergies are references to the weapons obtained from the eight Robot Masters in "
            },
            {
              "t": "text",
              "v": "Mega Man 2",
              "style": "i"
            },
            {
              "t": "text",
              "v": "."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Since the different modes are all "
            },
            {
              "t": "ref",
              "v": "Synergies",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": ", "
            },
            {
              "t": "ref",
              "v": "Lich's Eye Bullets",
              "kind": "item"
            },
            {
              "t": "text",
              "v": " make this gun incredibly powerful."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The internal name of the Megahand is 'Lemon Hand Cannon'."
            }
          ]
        }
      ]
    }
  },
  {
    "name": "Demon Head",
    "icon": "https://static.wikia.nocookie.net/enterthegungeon_gamepedia/images/3/34/Demon_Head.png",
    "notes": "Fires a continuous beam that has a chance to inflict Burn and slightly homes in on enemies.",
    "quote": "Wanged",
    "quality": "B",
    "type": "Beam",
    "dps": "31.0",
    "magazine_size": "500",
    "ammo_capacity": "500",
    "damage": "31/s",
    "fire_rate": "0.10",
    "reload_time": "N/A",
    "shot_speed": "100",
    "range": "40",
    "force": "30",
    "spread": "5",
    "class": "BEAM",
    "curse": 0.0,
    "coolness": 0.0,
    "wiki": {
      "notes": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "Prior to the "
            },
            {
              "t": "ref",
              "v": "Supply Drop Update",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": ", Demon Head did not curve towards enemies."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "This gun is a reference to the Guardian Head weapon from "
            },
            {
              "t": "ext",
              "v": "Shadow Warrior",
              "url": "https://en.wikipedia.org/wiki/Shadow_Warrior"
            },
            {
              "t": "text",
              "v": "."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The synergy  "
            },
            {
              "t": "synref",
              "v": "There is Only War"
            },
            {
              "t": "text",
              "v": " is a reference to the tagline for "
            },
            {
