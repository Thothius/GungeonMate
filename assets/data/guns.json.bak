    "reload_time": "1.2",
    "shot_speed": "16",
    "range": "50",
    "force": "20",
    "spread": "10",
    "class": "PISTOL",
    "curse": 0.0,
    "coolness": 0.0,
    "wiki": {
      "effects": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "First Stage: Fires piercing bullets at 6 damage."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
