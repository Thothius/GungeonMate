            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "synref",
              "v": "Flat Stanley"
            },
            {
              "t": "text",
              "v": " is a reference to the book series Flat Stanley."
