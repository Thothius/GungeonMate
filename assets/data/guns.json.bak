  {
    "name": "Casey",
    "icon": "https://static.wikia.nocookie.net/enterthegungeon_gamepedia/images/1/1e/Casey.png/revision/latest?cb=20161220033905",
    "notes": "Charged swings reflect nearby bullets. Does not crack secret walls . Increases curse by 2.",
    "quote": "Batting .50",
    "quality": "D",
    "type": "Charged",
    "dps": "50.0",
    "magazine_size": "1",
    "ammo_capacity": "",
    "damage": "100",
    "fire_rate": "0.20",
    "reload_time": "1.0",
    "shot_speed": "N/A",
    "range": "2.5",
    "force": "120",
    "spread": "N/A",
    "class": "SILLY",
    "curse": 2.0,
    "coolness": 0.0,
    "wiki": {
      "item_interactions": [
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "ref",
              "v": "Hip Holster",
              "kind": "item"
            },
            {
              "t": "text",
              "v": " - Reloading Casey will fire it's invisible projectile, resulting in a double-swing effect.\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "This secondary swing will not reflect projectiles."
                }
              ]
