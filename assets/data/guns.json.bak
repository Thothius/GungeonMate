  },
  {
    "name": "Charge Shot",
    "icon": "https://static.wikia.nocookie.net/enterthegungeon_gamepedia/images/8/81/Charge_Shot.png",
    "notes": "Fires a large laser that pierces enemies and bounces off of walls two times. Laser deals higher damage after bouncing.",
    "quote": "Hold To Fire",
    "quality": "B",
    "type": "Charged",
    "dps": "24.4",
    "magazine_size": "5",
    "ammo_capacity": "75",
    "damage": "30",
    "fire_rate": "0.01",
    "reload_time": "1.0",
    "shot_speed": "26",
    "range": "1,000",
    "force": "25",
    "spread": "5",
    "class": "CHARGE",
    "curse": 0.0,
    "coolness": 0.0,
    "wiki": {
      "notes": [
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "synref",
              "v": "Barrage Shot"
            },
            {
              "t": "text",
              "v": " - If the player also has "
            },
            {
              "t": "ref",
              "v": "Jetpack",
              "kind": "item"
            },
            {
              "t": "text",
              "v": ", charge time is reduced by 25%, reload time is increased by 50%, and shot size is increased."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Prior to the "
            },
            {
              "t": "ref",
              "v": "A Farewell to Arms",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": " update, Charge Shot's magazine size was 1 and its max ammo was 50."
            }
          ]
        }
      ],
      "trivia": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "This weapon is a reference to the game "
            },
            {
              "t": "ext",
              "v": "Charge Shot",
              "url": "http://store.steampowered.com/app/401840/"
            },
            {
              "t": "text",
              "v": "."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Charge Shot's glowing green light turns red and blinks when it is out of ammo.\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "If the Charge Shot's clip is refilled with an ammo pack while empty, it will continue to blink red as if it were still out of ammo until fired again."
                }
              ]
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "With "
            },
            {
              "t": "ref",
              "v": "Bumbullets",
              "kind": "item"
            },
            {
              "t": "text",
              "v": ", pressing fire without charging will always release a bee without using up ammo."
            }
          ]
        }
      ]
    }
  },
  {
    "name": "Dark Marker",
    "icon": "https://static.wikia.nocookie.net/enterthegungeon_gamepedia/images/6/62/Dark_Marker.png",
    "notes": "Charge shot consumes the entire clip to create a room-wide explosion and blank effect.",
    "quote": "Big Bang",
    "quality": "1S",
    "type": "Semiautomatic",
    "dps": "38.6",
    "magazine_size": "12",
    "ammo_capacity": "200",
    "damage": "Bullets: 8 Explosion: 80",
    "fire_rate": "0.20",
    "reload_time": "2.0",
    "shot_speed": "32",
    "range": "1,000",
    "force": "20",
    "spread": "0",
    "class": "EXPLOSIVE",
    "curse": 0.0,
    "coolness": 0.0,
    "wiki": {
      "effects": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "When uncharged, fires black and white projectiles with no special properties. This projectile is fired on button-down rather than button-up (unlike the uncharged shots of other "
            },
            {
              "t": "ref",
              "v": "Category:Charged",
              "kind": "unresolved"
            },
            {
              "t": "text",
              "v": " weapons), meaning that one will automatically be fired as the player begins charging a charged shot."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "When charged, fires two capsules (one matter, one antimatter) in a helical formation, arcing towards one another.\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "Firing a charged shot empties the entire magazine of the gun, and consumes 10 ammo rather than 1."
                }
              ]
            },
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "These capsules can pierce up to 5 enemies each."
                }
              ]
            },
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "If these capsules survive long enough to impact one another, both will be violently destroyed. This triggers a 50 damage explosion with very large 15 tile radius, as well as a "
                },
                {
                  "t": "ref",
                  "v": "Blank",
                  "kind": "shrine"
                },
                {
                  "t": "text",
                  "v": " effect, centered on the point of intersection. Like all blanks, this deals an additional 10 damage to enemies close enough to the center.\n"
                }
              ],
              "sub": [
                {
                  "tokens": [
                    {
                      "t": "text",
                      "v": "This blank effect does "
                    },
                    {
                      "t": "text",
                      "v": "not",
                      "style": "i"
                    },
                    {
                      "t": "text",
                      "v": " open "
                    },
                    {
                      "t": "ref",
                      "v": "Secret rooms",
                      "kind": "lore"
                    },
                    {
                      "t": "text",
                      "v": "."
                    }
                  ]
                }
              ]
            },
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "If these capsules are not detonated (for instance, if one is prematurely destroyed or item interactions cause them to miss) they will transform into swirling orbs. This has no mechanical effect."
                }
              ]
            }
          ]
        }
      ],
      "item_interactions": [
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "ref",
              "v": "Gold Ammolet",
              "kind": "item"
            },
            {
              "t": "text",
              "v": " /  "
            },
            {
              "t": "ref",
              "v": "Chaos Ammolet",
              "kind": "item"
            },
            {
              "t": "text",
              "v": " /  "
            },
            {
              "t": "ref",
              "v": "Lodestone Ammolet",
              "kind": "item"
            },
            {
              "t": "text",
              "v": " /  "
            },
            {
              "t": "ref",
              "v": "Uranium Ammolet",
              "kind": "item"
            },
            {
              "t": "text",
              "v": " /  "
            },
            {
              "t": "ref",
              "v": "Copper Ammolet",
              "kind": "item"
            },
            {
              "t": "text",
              "v": " /  "
            },
            {
              "t": "ref",
              "v": "Frost Ammolet",
              "kind": "item"
            },
            {
              "t": "text",
              "v": " - Blanks triggered by the Dark Marker activate the effects of ammolets."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "ref",
              "v": "Chaos Bullets",
              "kind": "item"
            },
            {
              "t": "text",
              "v": " - Chaos Bullets applies a random velocity modifier to fired bullets. This is extremely detrimental to the Dark Marker, as it means the juxtaposed charged shots will almost always miss one another."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "ref",
              "v": "Potion of Gun Friendship",
              "kind": "item"
            },
            {
              "t": "text",
              "v": " +  "
            },
            {
              "t": "synref",
              "v": "Friend to Gun and Bullet"
            },
            {
              "t": "text",
              "v": " - The temporary orbital version of the Dark Marker will rapidly fire both its charged and uncharged projectiles at once. Both charged shots will follow the "
            },
            {
              "t": "text",
              "v": "same",
              "style": "i"
            },
            {
              "t": "text",
              "v": " helical arc, rather than opposed arcs, causing them to collide almost immediately."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "A number of items interact strangely with the  "
            },
            {
              "t": "synref",
              "v": "Antichamber"
            },
            {
              "t": "text",
              "v": " synergy;\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": " "
                },
                {
                  "t": "ref",
                  "v": "Backup Gun",
                  "kind": "item"
                },
                {
                  "t": "text",
                  "v": " - The capsules fired forwards will always be the same colour, with the capsules fired backwards being their opposite. This can make it more difficult to intentionally shoot matter into antimatter, and vice versa."
                }
              ]
            },
            {
              "tokens": [
                {
                  "t": "text",
                  "v": " "
                },
                {
                  "t": "ref",
                  "v": "Helix Bullets",
                  "kind": "item"
                },
                {
                  "t": "text",
                  "v": " - While this synergy does cause every shot to be two opposite capsules traveling in a helical formation, they rarely actually collide, even when visibly overlapping. Additionally they will no longer decelerate."
                }
              ]
            },
            {
              "tokens": [
                {
                  "t": "text",
                  "v": " "
                },
                {
                  "t": "ref",
                  "v": "Remote Bullets",
                  "kind": "item"
                },
                {
                  "t": "text",
                  "v": " - It is very easy to remote-control matter and anti-matter canisters into one another, reliably triggering a blast."
                }
              ]
            }
          ]
        }
      ],
      "notes": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "This gun does not anger "
            },
            {
              "t": "ref",
              "v": "Bello",
              "kind": "unresolved"
            },
            {
              "t": "text",
              "v": " when fired in the shop unless it is charged."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Despite being listed as a semiautomatic weapon in the "
            },
            {
              "t": "ref",
              "v": "Ammonomicon",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": ", the Dark Marker is one of the few guns in "
            },
            {
              "t": "text",
              "v": "Enter the Gungeon",
              "style": "i"
            },
            {
              "t": "text",
              "v": " to have multiple different shooting styles at once. The uncharged shots of the weapon are internally semiautomatic, while its charged shots are charge type."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Like other area damage effects, the violent blast from the Dark Marker can damage bosses such as the "
            },
            {
              "t": "ref",
              "v": "Cannonbalrog",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": " or "
            },
            {
              "t": "ref",
              "v": "High Priest",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": " during attacks where they become intangible."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The mechanics of this gun are a reference to the concept of "
            },
            {
              "t": "ext",
              "v": "annihilation",
              "url": "https://en.wikipedia.org/wiki/Annihilation"
            },
            {
              "t": "text",
              "v": " in the field of particle physics, where a particle coming in contact with its corresponding antiparticle destroys both and results in a massive release of energy.\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "The "
                },
                {
                  "t": "ref",
                  "v": "Ammonomicon",
                  "kind": "lore"
                },
                {
                  "t": "text",
                  "v": " quote "
                },
                {
                  "t": "text",
                  "v": "\"Big Bang\"",
                  "style": "i"
                },
                {
                  "t": "text",
                  "v": " is a reference to a sequence of annihilation events theorised to have happened between 10 and 1 seconds after the birth of the universe, where newly formed baryons and electrons annihilated their respective antibaryons and positrons."
                }
              ]
            },
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "The 'strong' and 'weak' particles referenced in the Dark Marker's "
                },
                {
                  "t": "ref",
                  "v": "Ammonomicon",
                  "kind": "lore"
                },
                {
                  "t": "text",
                  "v": " entry do not correspond to real particles in physics, but may instead be references to the "
                },
                {
                  "t": "ext",
                  "v": "strong",
                  "url": "https://en.wikipedia.org/wiki/Strong_interaction"
                },
                {
                  "t": "text",
                  "v": " and "
                },
                {
                  "t": "ext",
                  "v": "weak",
                  "url": "https://en.wikipedia.org/wiki/Weak_interaction"
                },
                {
                  "t": "text",
                  "v": " nuclear interactions."
                }
              ]
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "In architecture, an "
            },
            {
              "t": "text",
              "v": "antechamber",
              "style": "i"
            },
            {
              "t": "text",
              "v": " is a smaller room serving as an entryway into a more important space. Despite this, and given how it is spelled, the  "
            },
            {
              "t": "synref",
              "v": "Antichamber"
            },
            {
              "t": "text",
              "v": " synergy is more likely a reference to the puzzle game "
            },
            {
              "t": "ext",
              "v": "Antichamber",
              "url": "https://en.wikipedia.org/wiki/"
            },
            {
              "t": "text",
              "v": "."
            }
          ]
        }
      ]
    }
  },
  {
    "name": "Particulator",
    "icon": "https://static.wikia.nocookie.net/enterthegungeon_gamepedia/images/0/08/Particulator.png",
    "notes": "Fires a large bullet, which will split into 10 homing bullets.",
    "quote": "Strange Matter",
    "quality": "1S",
    "type": "Semiautomatic",
    "dps": "41. 6",
    "magazine_size": "1",
    "ammo_capacity": "60",
    "damage": "Large: 30 Small: 7",
    "fire_rate": "0.70",
    "reload_time": "2.4",
    "shot_speed": "10",
    "range": "10",
    "force": "8",
    "spread": "0",
    "class": "SILLY",
    "curse": 0.0,
    "coolness": 0.0,
    "wiki": {
      "notes": [
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "synref",
              "v": "Particle Accelerator"
            },
            {
              "t": "text",
              "v": " - If the player also has "
            },
            {
              "t": "ref",
              "v": "Laser Sight",
              "kind": "item"
            },
            {
              "t": "text",
              "v": ", whenever a smaller bullet hits an enemy or object, a laser is automatically fired in its direction."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Upon splitting, the large bullet creates a visual blast effect that is similar to a blank but doesn't have any actual effect."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The homing projectiles are extremely useful for clearing large numbers of enemies, and for locating enemies off-screen."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "If there are no enemies in the room, after flying a short distance the homing projectiles will begin circling in place."
            }
          ]
        }
      ],
      "trivia": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "The gun is a reference to a "
            },
            {
              "t": "ext",
              "v": "particle accelerator",
              "url": "https://en.wikipedia.org/wiki/Particle_accelerator"
            },
            {
              "t": "text",
              "v": ", with the \"shower of exotic particles\" referring to a "
            },
            {
              "t": "ext",
              "v": "Particle shower",
              "url": "https://en.wikipedia.org/wiki/Particle_shower"
            },
            {
              "t": "text",
              "v": "."
            }
          ]
        },
        {
          "tokens": [
