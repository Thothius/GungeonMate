          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "Firing an energy ball consumes 10 ammo."
                }
              ]
            },
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "Disintegrating an enemy will prevent certain on-death effects from triggering. For instance, "
