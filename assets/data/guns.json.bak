        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "If the Mega Douser is fired at a pool of green fire with the  "
            },
            {
              "t": "synref",
              "v": "Napalm B"
            },
            {
              "t": "text",
              "v": " synergy, the fire spread will be of the normal variety."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "If both the  "
            },
            {
              "t": "synref",
              "v": "Napalm B"
            },
            {
              "t": "text",
              "v": " synergy and the  "
            },
            {
              "t": "synref",
              "v": "Ice Water"
            },
            {
              "t": "text",
              "v": " synergy are active at once, the ice spread by the Mega Douser will still spread fire.\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "This includes the fire effect caused when reloading "
