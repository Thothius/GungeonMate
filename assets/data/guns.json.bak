          "tokens": [
            {
              "t": "text",
              "v": "Flings a banana that bounces once, and explodes upon destruction dealing 30 damage to nearby enemies."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Each time this banana hits a wall, regardless of whether it bounces or explodes, it creates two more bananas. These sub-bananas look identical to the original, and also bounce once, but they cannot create more bananas, and their smaller explosions only deal 10 damage.\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "The banana will "
                },
                {
                  "t": "text",
                  "v": "also",
                  "style": "i"
                },
                {
                  "t": "text",
                  "v": " release two sub-bananas if it reaches the end of its range and detonates mid-air, or if it impacts an enemy."
                }
              ]
            }
          ]
        }
      ],
      "item_interactions": [
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
