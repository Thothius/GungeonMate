            },
            {
              "t": "text",
              "v": "DOOM",
              "style": "i"
            },
            {
              "t": "text",
              "v": "."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The "
            },
            {
              "t": "ref",
              "v": "Ammonomicon",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": " quote "
            },
            {
              "t": "text",
              "v": "\"Jealous Weapon\"",
              "style": "i"
            },
            {
              "t": "text",
              "v": " may be a reference to the character "
            },
            {
              "t": "ext",
              "v": "Gunther",
              "url": "https://friends.fandom.com/wiki/Gunther"
            },
            {
              "t": "text",
              "v": " in the television show "
            },
            {
              "t": "text",
              "v": "Friends",
              "style": "i"
            },
            {
              "t": "text",
              "v": ". In the show, Gunther is portrayed as a deeply jealous figure with a possessive— unrequited —love for the character Rachel, and is begrudging of the other men who get her attention."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": " Fixed Bug Prior to the "
            },
            {
              "t": "ref",
              "v": "Supply Drop Update",
