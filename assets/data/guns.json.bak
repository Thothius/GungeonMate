          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "The synergy form taken by the  "
                },
                {
                  "t": "synref",
                  "v": "Gunderlord"
                },
                {
                  "t": "text",
                  "v": " and  "
                },
                {
                  "t": "synref",
                  "v": "It's Your Destiny"
                },
                {
                  "t": "text",
                  "v": " synergies alter the gun to more closely match its "
                },
                {
                  "t": "text",
                  "v": "Destiny",
                  "style": "i"
                },
                {
                  "t": "text",
                  "v": " counterpart."
                }
              ]
            },
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "The  "
                },
                {
                  "t": "synref",
                  "v": "Gunderlord"
                },
                {
                  "t": "text",
                  "v": " synergy is also a reference to another "
                },
                {
                  "t": "text",
                  "v": "Destiny",
                  "style": "i"
                },
                {
                  "t": "text",
                  "v": " weapon, the "
                },
                {
                  "t": "ext",
                  "v": "Thunderlord",
                  "url": "https://www.destinypedia.com/Thunderlord"
                },
                {
                  "t": "text",
                  "v": "."
                }
              ]
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The "
            },
            {
              "t": "ref",
              "v": "Ammonomicon",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": " quote "
