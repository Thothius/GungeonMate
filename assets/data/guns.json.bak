                {
                  "t": "text",
                  "v": "."
                }
              ]
            },
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "The option of an exploding box is a reference to "
                },
                {
                  "t": "ext",
                  "v": "letter bombs",
                  "url": "https://en.wikipedia.org/wiki/Letter_bomb"
