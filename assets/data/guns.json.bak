    "coolness": 0.0,
    "wiki": {
      "notes": [
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "synref",
              "v": "Triple Sticky"
            },
            {
              "t": "text",
              "v": " - If the player also has "
            },
            {
              "t": "ref",
              "v": "Sticky Crossbow",
              "kind": "gun"
            },
            {
              "t": "text",
              "v": ", Sticky Crossbow will fire three bolts per shot, and its magazine size will increase from 5 to 6. Triple Crossbow's triple shot will explode (after hitting an enemy) upon reloading."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The Triple Crossbow is in the SHOTGUN "
            },
            {
              "t": "ref",
              "v": "Guns",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": " and as such benefits from the  "
