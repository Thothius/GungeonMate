  {
    "name": "The Scrambler",
    "icon": "https://static.wikia.nocookie.net/enterthegungeon_gamepedia/images/f/fc/The_Scrambler.png",
    "notes": "Fires bullets that hatch into many homing bullets upon hitting an enemy or obstacle.",
    "quote": "Bullet Or The Gun?",
    "quality": "C",
    "type": "Semiautomatic",
    "dps": "42.5",
    "magazine_size": "1",
    "ammo_capacity": "120",
    "damage": "6 (egg) + 9x5 (seekers)",
    "fire_rate": "0.10",
    "reload_time": "1.2",
    "shot_speed": "20",
    "range": "32",
    "force": "0",
    "spread": "6",
    "class": "SILLY",
    "curse": 0.0,
    "coolness": 0.0,
    "wiki": {
      "notes": [
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "synref",
              "v": "Bacon and Eggs"
            },
            {
              "t": "text",
              "v": " - If the player has "
            },
            {
              "t": "ref",
              "v": "Pig",
              "kind": "item"
            },
            {
              "t": "text",
              "v": ", shot speed is increased by 50%."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "synref",
              "v": "Bullet or the Egg"
            },
            {
              "t": "text",
              "v": " - If the player has "
            },
            {
              "t": "ref",
              "v": "Chicken Flute",
              "kind": "item"
            },
            {
              "t": "text",
              "v": ", Scrambler shots become larger and split into 10 seekers instead of 5."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "synref",
              "v": "EGG MURDERER"
            },
            {
              "t": "text",
              "v": " - If the player has "
            },
            {
              "t": "ref",
              "v": "Light Gun",
              "kind": "gun"
            },
            {
              "t": "text",
              "v": ", its ducks periodically send out two Scrambler shots perpendicular to itself as it travels."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "synref",
              "v": "Phoenix Up"
            },
            {
              "t": "text",
              "v": " - If the player has "
            },
            {
              "t": "ref",
              "v": "Phoenix",
              "kind": "gun"
            },
            {
              "t": "text",
              "v": ", summons a Phoenix companion that fires at enemies while Phoenix is held, even when not equipped."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "synref",
              "v": "Two Eggs Over Easy"
            },
            {
              "t": "text",
              "v": " - If the player has "
            },
            {
              "t": "ref",
              "v": "Weird Egg",
              "kind": "item"
            },
            {
              "t": "text",
              "v": ", the homing shots will cause "
            },
            {
              "t": "ref",
              "v": "Poison",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": "."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The homing pellets will always track the enemy closest to the player, not those closest to the point of impact."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "It's somewhat inconsistent how bullet modifiers apply to it.\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "For items such as "
                },
                {
                  "t": "ref",
                  "v": "Frost Bullets",
                  "kind": "item"
                },
                {
                  "t": "text",
                  "v": " or "
                },
                {
                  "t": "ref",
                  "v": "Hot Lead",
                  "kind": "item"
                },
                {
                  "t": "text",
                  "v": ", the status effect will only be applied to the egg bullet, not the seekers."
                }
              ]
            },
            {
              "tokens": [
                {
                  "t": "ref",
                  "v": "Shock Rounds",
                  "kind": "item"
                },
                {
                  "t": "text",
                  "v": " and "
                },
                {
                  "t": "ref",
                  "v": "Ghost Bullets",
                  "kind": "item"
                },
                {
                  "t": "text",
                  "v": " apply to both the egg bullet and seeker."
                }
              ]
            },
            {
              "tokens": [
                {
                  "t": "ref",
                  "v": "Flak Bullets",
                  "kind": "item"
                },
                {
                  "t": "text",
                  "v": "  only applies to the seekers."
                }
              ]
            },
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "Bizarrely, "
                },
                {
                  "t": "ref",
                  "v": "Homing Bullets",
                  "kind": "item"
                },
                {
                  "t": "text",
                  "v": " actually makes it take longer for the seekers to home in on an enemy."
                }
              ]
            },
            {
              "tokens": [
                {
                  "t": "ref",
                  "v": "Remote Bullets",
                  "kind": "item"
                },
                {
                  "t": "text",
                  "v": " apply to the egg bullet but not the seekers."
                }
              ]
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "If Red "
            },
            {
              "t": "ref",
              "v": "Gunjurer",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": " capture the bullets, they still retain their homing."
            }
          ]
        }
      ],
      "trivia": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "This item is a reference to the popular philosophical question - \"What came first, the chicken or the egg?\""
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "This weapon appears to be a modified version of the "
            },
            {
              "t": "ref",
              "v": "Flare Gun",
              "kind": "gun"
            },
            {
              "t": "text",
              "v": "."
            }
          ]
        }
      ]
    }
  },
