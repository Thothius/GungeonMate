    "coolness": 0.0,
    "wiki": {
      "notes": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "This gun is a reference to the alien pistols usable in "
            },
            {
              "t": "ext",
              "v": "Halo",
              "url": "https://en.wikipedia.org/wiki/Halo"
            },
            {
              "t": "text",
              "v": ".\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "Shield Breaker",
                  "style": "i"
                },
                {
                  "t": "text",
                  "v": " is a reference to Halo's famous shield mechanic."
                }
              ]
            },
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "The charging mechanic is also a function of Halo's plasma pistol. A fully charged shot from that gun could instantly break another player's shields in multiplayer."
                }
              ]
            },
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "Upon obtaining the Chief Master synergy, the weapon more closely resembles in design and function Halo's Plasma Rifle rather than the Plasma Pistol."
                }
              ]
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The entry for the Alien Sidearm in the "
            },
            {
              "t": "ref",
              "v": "Physical Ammonomicon",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": " has a small doodle of a creature resembling a "
            },
            {
              "t": "ref",
              "v": "Bullet Kin",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": " firing the weapon. The Bullet Kin-like creature may be styled after "
            },
            {
              "t": "ext",
              "v": "Grunts",
              "url": "https://www.halopedia.org/Unggoy"
            },
            {
              "t": "text",
              "v": " in the "
            },
            {
              "t": "text",
              "v": "Halo",
              "style": "i"
            },
            {
              "t": "text",
              "v": " franchise."
            }
          ]
        }
      ]
    }
  },
