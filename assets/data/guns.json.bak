              "v": " cannot absorb Gunther's bullets at stage 3."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The bullets of this gun ignore the  "
            },
            {
              "t": "ref",
              "v": "Challenge Mode",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "ref",
              "v": "Challenge Mode",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": " modifier."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "When shooting a north wall, Gunther's bullets will leave magical singe-marks shaped like the letters N, R, and Φ. These are the same symbols fired by "
