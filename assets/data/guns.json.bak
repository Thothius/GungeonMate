              "v": "Fires piercing, bouncing sawblades."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Increases "
            },
            {
              "t": "ref",
              "v": "Movement Speed",
              "kind": "unresolved"
            },
            {
