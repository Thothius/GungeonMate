  {
    "name": "Deck4rd",
    "icon": "https://static.wikia.nocookie.net/enterthegungeon_gamepedia/images/8/88/Deck4rd.png",
    "notes": "Fires a single powerful bullet that will explode upon impact.",
    "quote": "Unicorn Of Handguns",
    "quality": "A",
    "type": "Semiautomatic",
    "dps": "47.1",
    "magazine_size": "2",
    "ammo_capacity": "40",
    "damage": "5 (impact) + 35 (explosion)",
    "fire_rate": "0.20",
    "reload_time": "1.5",
    "shot_speed": "20",
    "range": "1,000",
    "force": "22",
    "spread": "10",
    "class": "EXPLOSIVE",
    "curse": 0.0,
    "coolness": 0.0,
    "wiki": {
      "notes": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "Although classified as semi-automatic, the Deck4rd is functionally automatic, as its rate of fire does not benefit from tapping the fire button instead of holding it down."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "synref",
              "v": "Blade Runner"
            },
            {
              "t": "text",
              "v": " - If the player has "
            },
            {
              "t": "ref",
              "v": "Origuni",
              "kind": "gun"
            },
            {
              "t": "text",
              "v": ", magazine size of both guns is increased by 50%."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "synref",
              "v": "Running Blades"
            },
            {
              "t": "text",
              "v": " - If the player has "
            },
            {
              "t": "ref",
              "v": "Knife Shield",
              "kind": "item"
            },
            {
              "t": "text",
              "v": ", killing enemies with Deck4rd has a high chance to spawn Knife Shield knives."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "synref",
              "v": "To Serve Android"
            },
            {
              "t": "text",
              "v": " - If the player has "
            },
            {
              "t": "ref",
              "v": "Badge",
              "kind": "item"
            },
            {
              "t": "text",
              "v": ", the police officer turns into a robot and becomes invincible."
            }
          ]
        }
      ],
      "trivia": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "This gun is a reference to Deckard's gun from "
            },
            {
              "t": "ext",
              "v": "Blade Runner",
              "url": "https://en.wikipedia.org/wiki/Blade_Runner"
            },
            {
              "t": "text",
              "v": ". In the film's various versions, Deckard has an acquaintance who is fond of making origami figures, and several scenes feature unicorn imagery.\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "\"Unicorn of Handguns\" is a reference to the unicorn in Deckard's dreams."
                }
              ]
            }
          ]
        }
      ]
    }
  },
  {
    "name": "The Judge",
    "icon": "https://static.wikia.nocookie.net/enterthegungeon_gamepedia/images/3/39/The_Judge.png",
    "notes": "The final shot of each clip has a chance to poison, freeze or ignite enemies. (likely more effects possible)",
