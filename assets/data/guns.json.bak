            {
              "t": "ext",
              "v": "Worms",
              "url": "https://en.wikipedia.org/wiki/Worms_(series)"
            },
            {
              "t": "text",
              "v": "."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The pickup quote is a reference to the "
            },
            {
              "t": "ext",
              "v": "plantain",
              "url": "https://en.wikipedia.org/wiki/True_plantains"
            },
