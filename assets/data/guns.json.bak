    "wiki": {
      "notes": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "The name "
            },
            {
              "t": "text",
              "v": "Dungeon Eagle",
              "style": "i"
            },
            {
              "t": "text",
              "v": " is a reference to the real-world 'Desert Eagle' gun.\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "The description of the weapon refers to the Desert Eagle's popularity in American culture and the weapon's iconic reputation despite its shortcomings."
                }
              ]
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "With  "
            },
            {
              "t": "synref",
              "v": "Don't Hoot the Messenger"
            },
            {
              "t": "text",
              "v": ", the reload animation of the gun shows its slide and barrel rotating 360 degrees in reference to the real-world ability of owls to rotate their heads 270 degrees."
            }
          ]
        }
      ]
    }
  },
