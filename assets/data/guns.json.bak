  },
  {
    "name": "The Emperor",
    "icon": "https://static.wikia.nocookie.net/enterthegungeon_gamepedia/images/9/96/The_Emperor.png",
    "notes": "Fires a burst of four green orbs connected by electricity.",
    "quote": "Electric Terror",
    "quality": "A",
    "type": "Burst",
    "dps": "37.5",
    "magazine_size": "30",
    "ammo_capacity": "300",
    "damage": "7",
    "fire_rate": "0.30",
    "reload_time": "1.2",
    "shot_speed": "20",
    "range": "50",
    "force": "10",
    "spread": "7",
    "class": "FULLAUTO",
    "curse": 0.0,
    "coolness": 0.0,
    "wiki": {
      "notes": [
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "synref",
              "v": "Starburst Fire"
            },
            {
              "t": "text",
              "v": " - If the player also has "
            },
            {
              "t": "ref",
              "v": "Laser Rifle",
              "kind": "gun"
            },
            {
              "t": "text",
              "v": ", firing either The Emperor or Laser Rifle once will cause it to rapidly fire its entire magazine. Increases damage by 20% and doubles fire rate.\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "You can cancel the effect by reloading or "
                },
                {
                  "t": "ref",
                  "v": "Dodge Roll (Move)",
                  "kind": "lore"
                },
                {
                  "t": "text",
                  "v": " while firing."
                }
              ]
            }
          ]
        }
      ],
      "trivia": [
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "ref",
              "v": "Unused and Cut Content/Synergies",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": " - ("
            },
            {
              "t": "text",
              "v": "CustomSynergyType.THE_STAR_WAR",
              "style": "code"
            },
            {
              "t": "text",
              "v": ") If the player has "
            },
            {
              "t": "ref",
              "v": "Void Marshal",
              "kind": "gun"
            },
            {
              "t": "text",
              "v": ", it causes an unknown effect."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "This gun may be a reference to Emperor Palpatine from "
            },
            {
              "t": "ext",
              "v": "Star Wars",
              "url": "https://en.wikipedia.org/wiki/Star_Wars"
            },
            {
              "t": "text",
              "v": ".\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "This is further reinforced by the name of the above unused synergy, and the fact that the Void Marshal is also a reference to Star Wars."
                }
              ]
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "This gun's bullets and firing mechanism are a reference to "
            },
            {
              "t": "ext",
              "v": "Emperor Zurg",
              "url": "https://pixar.fandom.com/wiki/Emperor_Zurg"
            },
            {
              "t": "text",
              "v": " from Toy Story."
            }
          ]
        }
      ]
    }
  },
  {
    "name": "RPG",
    "icon": "https://static.wikia.nocookie.net/enterthegungeon_gamepedia/images/6/6f/RPG.png",
    "notes": "Fires a rocket-penetrated grenade.",
    "quote": "Leveled Up",
    "quality": "B",
    "type": "Semiautomatic",
    "dps": "18.3",
    "magazine_size": "1",
    "ammo_capacity": "40",
    "damage": "20 (impact) + 35 (explosion)",
    "fire_rate": "1.00",
    "reload_time": "3.0",
    "shot_speed": "40",
    "range": "90",
    "force": "10",
    "spread": "5",
    "class": "EXPLOSIVE",
    "curse": 0.0,
    "coolness": 0.0,
    "wiki": {
      "effects": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "Fires a rocket-propelled explosive grenade. Capable of dealing considerable damage, but with a lengthy reload time.\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "The impact of the RPG projectile (not the explosion) deals 30% extra damage to "
                },
                {
                  "t": "ref",
                  "v": "Bosses",
                  "kind": "lore"
                },
                {
                  "t": "text",
                  "v": "."
                }
              ]
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "RPG grenades start off slightly slower, before quickly accelerating to maximum velocity."
            }
          ]
        }
      ],
      "item_interactions": [
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "ref",
              "v": "Duct Tape",
              "kind": "item"
            },
            {
              "t": "text",
              "v": " +  "
            },
            {
              "t": "synref",
              "v": "that &^#$# 'pizza'"
            },
            {
              "t": "text",
              "v": " -  If another gun is taped onto the RPG, "
            },
            {
              "t": "text",
              "v": "all",
              "style": "i"
            },
            {
              "t": "text",
              "v": " bullets fired from the taped-on gun will be replaced by rocket fists from the  "
            },
            {
              "t": "synref",
              "v": "that &^#$# 'pizza'"
            },
            {
              "t": "text",
              "v": " synergy."
            }
          ]
        }
      ],
      "notes": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "If the player feeds both this gun and "
            },
            {
              "t": "ref",
              "v": "Bee Hive",
              "kind": "gun"
            },
            {
              "t": "text",
              "v": " to a "
            },
            {
              "t": "ref",
              "v": "Muncher",
              "kind": "unresolved"
            },
            {
              "t": "text",
              "v": ", it will spit out a "
            },
            {
              "t": "ref",
              "v": "Stinger",
              "kind": "gun"
            },
            {
              "t": "text",
              "v": " as a result."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "'Gundropping' (dropping a weapon mid-reload and picking it back up to force-reload it, skipping it's reload time) is highly effective with this weapon due to it's lengthy reload."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "\"Leveled Up\" references a common game mechanic in role-playing games, which are also abbreviated as \"RPG\"."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The synergy  "
            },
            {
              "t": "synref",
              "v": "that &^#$# 'pizza'"
            },
            {
              "t": "text",
              "v": " is a reference to Final Fantasy VII. The hero Barett (who has a prosthetic, weaponized fist) mutters this in disparagement of the Midgar arcology (a city contained within a single bullding)."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": " Possible Bug The player can shoot through locked doors with the RPG by standing right next to them, and can use the explosion to knockback items back through the door."
            }
          ]
        }
      ]
    }
  },
  {
    "name": "Grenade Launcher",
    "icon": "https://static.wikia.nocookie.net/enterthegungeon_gamepedia/images/6/67/Grenade_Launcher.png",
    "notes": "Fires a grenade that bounces off of surfaces and explodes on impact with enemies.",
    "quote": "Fwomp!",
    "quality": "B",
    "type": "Semiautomatic",
    "dps": "29.2",
    "magazine_size": "1",
    "ammo_capacity": "60",
    "damage": "10 (impact) + 25 (explosion)",
    "fire_rate": "1.20",
    "reload_time": "0.78",
    "shot_speed": "20",
    "range": "20",
    "force": "20",
    "spread": "4",
    "class": "EXPLOSIVE",
    "curse": 0.0,
    "coolness": 0.0,
    "wiki": {
      "effects": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "Fires explosive grenades.\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": " Grenades skip across the ground, and are able to ricochet off of a wall or object once."
                }
              ]
            }
          ]
        }
      ],
      "item_interactions": [
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "ref",
              "v": "Angry Bullets",
              "kind": "item"
            },
            {
              "t": "text",
              "v": " /  "
            },
            {
              "t": "ref",
              "v": "Ghost Bullets",
              "kind": "item"
            },
            {
              "t": "text",
              "v": " - Grenades will not explode upon first contact with an enemy, making it much more difficult to reliably damage enemies, especially bosses."
            }
          ]
        }
      ],
      "notes": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "This gun is based on the real-world "
            },
            {
              "t": "ext",
              "v": "M79 Grenade Launcher",
              "url": "https://en.wikipedia.org/wiki/M79_grenade_launcher"
            },
            {
              "t": "text",
              "v": ", which was developed as a higher powered and more accurate substitute for the US Military's rifle-barrel grenades.\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "The item quote \"Fwomp!\" is a reference to the real-life weapon's distinctive report when fired."
                }
              ]
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Grenade Launcher's max ammo was increased from 25 to 60 in "
            },
            {
              "t": "ref",
              "v": "A Farewell to Arms",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": "."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The synergy  "
            },
            {
              "t": "synref",
              "v": "Terminated, Too"
            },
            {
              "t": "text",
              "v": " is a reference to the film "
            },
            {
              "t": "ext",
              "v": "Terminator 2: Judgment Day",
              "url": "https://en.wikipedia.org/wiki/Terminator_2:_Judgment_Day"
            },
            {
              "t": "text",
              "v": ", where the titular Terminator uses an M79 Grenade Launcher."
            }
          ]
        }
      ]
    }
  },
  {
    "name": "Stinger",
    "icon": "https://static.wikia.nocookie.net/enterthegungeon_gamepedia/images/b/b6/Stinger.png",
    "notes": "Fires a rocket along with bees, which explode into more bees.",
    "quote": "Drone Warfare",
    "quality": "B",
    "type": "Semiautomatic",
    "dps": "27.5",
    "magazine_size": "1",
    "ammo_capacity": "50",
    "damage": "10 (impact) + 15 (explosion)",
    "fire_rate": "1.00",
    "reload_time": "2.0",
    "shot_speed": "20",
    "range": "60",
    "force": "10",
    "spread": "1",
    "class": "EXPLOSIVE",
    "curse": 0.0,
    "coolness": 0.0,
    "wiki": {
      "effects": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "Fires an explosive rocket, and three homing bees. This rocket releases five more bees upon exploding."
            }
          ]
        }
      ],
      "item_interactions": [
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "ref",
              "v": "Bouncy Bullets",
              "kind": "item"
            },
            {
              "t": "text",
              "v": " - The rocket fired by the Stinger will create 5 bees every time it bounces."
            }
          ]
        }
      ],
      "notes": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "Giving the  "
            },
            {
              "t": "ref",
              "v": "Bee Hive",
              "kind": "gun"
            },
            {
              "t": "text",
              "v": " and  "
            },
            {
              "t": "ref",
              "v": "RPG",
              "kind": "gun"
            },
            {
              "t": "text",
              "v": " to the  "
            },
            {
              "t": "ref",
              "v": "Muncher",
              "kind": "unresolved"
            },
            {
              "t": "text",
              "v": " will always result in a Stinger."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The Stingers long reload time makes it especially affected by the 'gun-dropping' technique. Dropped guns are instantly reloaded, and with guns like the Stinger the process of dropping them and quickly picking them back up is faster than reloading normally."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "This gun is based on the real world "
            },
            {
              "t": "ext",
              "v": "FIM-92 Stinger",
              "url": "https://en.wikipedia.org/wiki/FIM-92_Stinger"
            },
            {
              "t": "text",
              "v": ", a United States military ground-to-air missile launcher. Its ability to fire bees is a double-meaning based on its name."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "This gun also contains several references to the "
            },
            {
              "t": "text",
              "v": "Metal Gear",
              "style": "i"
            },
            {
              "t": "text",
              "v": " franchise, where the FIM-92 Stinger makes "
            },
            {
              "t": "ext",
              "v": "numerous appearances",
              "url": "https://metalgear.fandom.com/wiki/FIM-92_Stinger"
            },
            {
              "t": "text",
              "v": ".\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "According to "
                },
                {
                  "t": "ref",
                  "v": "Dodge Roll",
                  "kind": "lore"
                },
                {
                  "t": "text",
                  "v": " lead designer "
                },
                {
                  "t": "ref",
                  "v": "Dave Crooks",
                  "kind": "unresolved"
                },
                {
                  "t": "text",
                  "v": ", the Stinger is primarily based on the weapons appearance in "
                },
                {
                  "t": "text",
                  "v": "Metal Gear Solid",
                  "style": "i"
                },
                {
                  "t": "text",
                  "v": ", where it is used to shoot down a "
                },
                {
                  "t": "ext",
                  "v": "Hind D",
                  "url": "https://metalgear.fandom.com/wiki/Mil_Mi-24"
                },
                {
                  "t": "text",
                  "v": ", and "
                },
                {
                  "t": "text",
                  "v": "Metal Gear Solid 2",
                  "style": "i"
                },
                {
                  "t": "text",
                  "v": ", where it is used to shoot down a "
                },
                {
                  "t": "ext",
                  "v": "Harrier Jet",
                  "url": "https://metalgear.fandom.com/wiki/AV-8B_Harrier_II"
                },
                {
                  "t": "text",
                  "v": "."
                }
              ]
            },
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "The line "
                },
                {
                  "t": "text",
                  "v": "\"Originally used to swat down bothersome aircraft\"",
                  "style": "i"
                },
                {
                  "t": "text",
                  "v": " is a reference to the line "
                },
                {
                  "t": "ext",
                  "v": "\"I'm going to go swat down a couple of bothersome flies.\"",
                  "url": "https://youtu.be/R4I0l4o65JQ?t=266"
                },
                {
                  "t": "text",
                  "v": ", said by Liquid Snake in the opening scenes of "
                },
                {
                  "t": "text",
                  "v": "Metal Gear Solid",
                  "style": "i"
                },
                {
                  "t": "text",
                  "v": "."
                }
              ]
            },
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "The use of weaponised bees is also a reference to "
                },
                {
                  "t": "ext",
                  "v": "The Pain",
                  "url": "https://metalgear.fandom.com/wiki/The_Pain"
                },
                {
                  "t": "text",
                  "v": ", a character in the "
                },
                {
                  "t": "text",
                  "v": "Metal Gear",
                  "style": "i"
                },
                {
                  "t": "text",
                  "v": " franchise who has the ability to manipulate bees."
                }
              ]
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The "
            },
            {
              "t": "ref",
              "v": "Ammonomicon",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": " quote "
            },
            {
              "t": "text",
              "v": "\"Drone Warfare\"",
              "style": "i"
            },
            {
              "t": "text",
              "v": " has a double meaning. In the real world, "
            },
            {
              "t": "ext",
              "v": "Drone Warfare",
              "url": "https://en.wikipedia.org/wiki/Drone_warfare"
            },
            {
              "t": "text",
              "v": " refers to war waged using robots. However, male worker bees are also called \"drones\"."
            }
          ]
        }
      ]
    }
  },
  {
    "name": "The Exotic",
    "icon": "https://static.wikia.nocookie.net/enterthegungeon_gamepedia/images/d/d2/The_Exotic.png",
    "notes": "Fires rockets which burst into homing rockets. While held, grants a ghost companion that follows the player and reveals the contents of nearby chests.",
    "quote": "Pack of Wolves",
    "quality": "A",
    "type": "Semiautomatic",
    "dps": "44.5",
    "magazine_size": "1",
    "ammo_capacity": "50",
    "damage": "25 (impact) + 15 (explosion) + 35 (7 * 5 mini rockets)",
    "fire_rate": "2.0",
    "reload_time": "1.5",
    "shot_speed": "10 (Rocket) 25 (Small rocket)",
    "range": "60 (Rocket) 10 (Small rocket)",
    "force": "?",
    "spread": "1",
    "class": "EXPLOSIVE",
    "curse": 0.0,
    "coolness": 0.0,
    "wiki": {
      "notes": [
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "synref",
              "v": "It's Your Destiny"
            },
            {
              "t": "text",
              "v": " - If the player also has "
            },
            {
              "t": "ref",
              "v": "Ice Breaker",
              "kind": "gun"
            },
            {
              "t": "text",
              "v": ", Ice Breaker fires single high-velocity shots and slowly regenerates ammo over time. The Exotic's rockets split into 14 smaller rockets instead of 7."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "After looking at the contents of a chest with the Exotic it has a small chance to drop the shown item or gun when destroyed. Carrying the "
            },
            {
              "t": "ref",
              "v": "Book of Chest Anatomy",
              "kind": "item"
            },
            {
              "t": "text",
              "v": " greatly increases this chance."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Curiously, the Exotic's missiles are designated the 'Fire' damage type. This means that the missiles themselves (not the explosions they produce mind, merely the impact) deal less damage to enemies with fire type damage resistances such as "
            },
            {
              "t": "ref",
              "v": "Muzzle Wisp",
              "kind": "unresolved"
            },
            {
              "t": "text",
              "v": " or "
            },
            {
              "t": "ref",
              "v": "Muzzle Wisp",
              "kind": "unresolved"
            },
            {
              "t": "text",
              "v": "."
            }
          ]
        }
      ],
      "trivia": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "The Exotic is a reference to the exotic-rarity rocket launcher Gjallarhorn from Destiny, one of the most beloved and memetic exotics in the game. \"Pack of Wolves\" is a reference to the Gjallarhorn's exotic perk; Wolfpack Rounds."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The ghost companion is a reference to the Ghosts from Destiny."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "synref",
              "v": "It's Your Destiny"
            },
            {
              "t": "text",
              "v": " is also a reference to Destiny, as Ice Breaker is also an exotic-rarity sniper in Destiny that has the ability to regenerate its own ammo."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The reason for The Exotic's rockets dealing 'Fire' damage is likely referencing how the Gjallarhorn in Destiny does Solar damage, thus the rockets are made fire as a reference to this damage type."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The main projectile specifically splitting into 7 smaller projectiles is a potential reference to Bungie and Destiny having such a strong connection to the number 7."
            }
          ]
        }
      ]
    }
  },
  {
    "name": "Com4nd0",
    "icon": "https://static.wikia.nocookie.net/enterthegungeon_gamepedia/images/a/af/Com4nd0.png",
    "notes": "Rapidly fires 4 homing rockets.",
    "quote": "You're Fired",
    "quality": "B",
    "type": "Semiautomatic",
    "dps": "54.6",
    "magazine_size": "4",
    "ammo_capacity": "40",
    "damage": "20 (impact) + 25 (explosion)",
    "fire_rate": "0.60",
    "reload_time": "1.5",
    "shot_speed": "14",
    "range": "90",
    "force": "10",
    "spread": "5",
    "class": "EXPLOSIVE",
    "curse": 0.0,
    "coolness": 0.0,
    "wiki": {
      "notes": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "This gun is one of the six wielded by the "
            },
            {
              "t": "ref",
              "v": "Beholster",
              "kind": "shrine"
            },
            {
              "t": "text",
              "v": ". When used by the Beholster, it fires homing rockets visually identical to those fired by the player.\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "As it is held by the Beholster, it can be placed on the "
                },
                {
                  "t": "ref",
                  "v": "Beholster Shrine?action=edit&redlink=1",
                  "kind": "unresolved"
                },
                {
                  "t": "text",
                  "v": "."
                }
              ]
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "This gun is based on the real world "
            },
            {
              "t": "ext",
              "v": "M202 FLASH",
              "url": "https://en.wikipedia.org/wiki/M202_FLASH"
            },
            {
              "t": "text",
              "v": " rocket launcher."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "This gun is a reference to various film performances from the high profile actor "
            },
            {
              "t": "ext",
              "v": "Arnold Schwarzenegger",
              "url": "https://en.wikipedia.org/wiki/Arnold_Schwarzenegger"
            },
            {
              "t": "text",
              "v": ".\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "\"You're fired\"",
                  "style": "i"
                },
                {
                  "t": "text",
                  "v": " is an iconic one-liner from the film "
                },
                {
                  "t": "ext",
                  "v": "True Lies",
                  "url": "https://www.imdb.com/title/tt0111503/"
                },
                {
                  "t": "text",
                  "v": "."
                }
              ]
            },
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "The name "
                },
                {
                  "t": "text",
                  "v": "Com4nd0",
                  "style": "i"
                },
                {
                  "t": "text",
                  "v": " is a reference to the film "
                },
                {
                  "t": "ext",
                  "v": "Commando",
                  "url": "https://www.imdb.com/title/tt0088944/"
                },
                {
                  "t": "text",
                  "v": ", where Arnold Schwarzenegger uses the M202 FLASH."
                }
              ]
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The mechanized walkers in the Ammonomicon entry likely refers to those seen throughout the "
            },
            {
              "t": "text",
              "v": "Metal Gear",
              "style": "i"
            },
            {
              "t": "text",
              "v": " series."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "According to the Ammonomicon, this gun was designed to be attached to a combat vehicle, but is available as a man-portable weapon. It shares this trait with the "
            },
            {
              "t": "ref",
              "v": "Raiden Coil",
              "kind": "gun"
            },
            {
              "t": "text",
              "v": " and the "
            },
            {
              "t": "ref",
              "v": "Void Core Cannon",
              "kind": "gun"
            },
            {
              "t": "text",
              "v": "."
            }
          ]
        }
      ]
    }
  },
  {
    "name": "RC Rocket",
    "icon": "https://static.wikia.nocookie.net/enterthegungeon_gamepedia/images/7/75/RC_Rocket.png",
    "notes": "Fires a slow-moving rocket guided by cursor.",
    "quote": "Avoid User Error",
    "quality": "A",
    "type": "Semiautomatic",
    "dps": "86.7",
    "magazine_size": "1",
    "ammo_capacity": "50",
    "damage": "100 (impact) + 30 (explosion)",
    "fire_rate": "0.60",
    "reload_time": "1.5",
    "shot_speed": "10",
    "range": "200",
    "force": "10",
    "spread": "1",
