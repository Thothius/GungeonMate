    "ammo_capacity": "240",
    "damage": "Uncharged: 32 (4x8) Charged: 42 (6x7)",
    "fire_rate": "0.50",
    "reload_time": "1.5",
    "shot_speed": "26",
    "range": "1,000",
    "force": "26",
    "spread": "20",
    "class": "SHOTGUN",
    "curse": 0.0,
    "coolness": 0.0,
    "wiki": {
      "notes": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "The Zilla Shotgun is in the SHOTGUN "
            },
            {
              "t": "ref",
              "v": "Guns",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": ", and as such benefits from the  "
            },
            {
              "t": "synref",
              "v": "Shotgun Affinity"
            },
            {
              "t": "text",
              "v": " synergy."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Prior to the "
            },
            {
              "t": "ref",
              "v": "Supply Drop Update",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": ", Zilla Shotgun had 100 maximum ammo."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Zilla Shotgun can still fire the charged shot if it has only one shot left in the magazine. This will, however, still consume 4 ammo."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Zilla Industries",
              "style": "i"
            },
            {
              "t": "text",
              "v": " is a reference to a company of the same name from the "
            },
            {
              "t": "ext",
              "v": "Shadow Warrior",
              "url": "https://en.wikipedia.org/wiki/Shadow_Warrior"
            },
            {
              "t": "text",
              "v": " game by 3D Realms which the titular hero fights throughout the game.\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "In Shadow Warrior, the player can also use a quad shotgun."
                }
              ]
            },
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "The orbiting "
                },
                {
                  "t": "ref",
                  "v": "Demon Head",
                  "kind": "gun"
                },
                {
                  "t": "text",
                  "v": " gained through the  "
                },
                {
                  "t": "synref",
                  "v": "Shadow Warrior"
                },
                {
                  "t": "text",
                  "v": " synergy is likely a reference to one of the game's weapons, a demon head that shoots a laser out of its mouth."
                }
              ]
            }
          ]
        }
      ]
    }
  },
  {
    "name": "Ice Breaker",
    "icon": "https://static.wikia.nocookie.net/enterthegungeon_gamepedia/images/5/5a/Ice_Breaker.png",
