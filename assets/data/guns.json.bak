            },
            {
              "t": "text",
              "v": "."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "When Gunther's magazine is fully empty, he will appear to go to sleep."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Gunthers hammer appears to strike him in the side of the face when he is fired, causing him to wince."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Gunther has two reload animations. When reloading a partially empty magazine, the character flips him end over end. When reloading a fully empty magazine, the character tilts Gunther on his side and shakes him."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The quote "
            },
            {
              "t": "text",
              "v": "\"Go team Gungeon!\"",
              "style": "i"
            },
            {
              "t": "text",
              "v": " may be a reference to the catch phrase "
