      "trivia": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "This gun is a reference to the myth of pillows being used as makeshift silencers."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "300 Dead Count",
              "style": "i"
            },
            {
              "t": "text",
              "v": " is a pun on \"Thread Count\", a term often used to measure the quality of sheets. It is also a reference to an episode of American Dad, where the phrase \"200 thread count, 200 dead count\" is used"
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The character of Alben Smallbore mentioned in the Ammonomicon entry of this and the "
            },
            {
              "t": "ref",
              "v": "Flame Hand",
              "kind": "gun"
            },
            {
              "t": "text",
              "v": " is a reference to Headmaster Albus Dumbledore from the "
            },
            {
              "t": "text",
              "v": "Harry Potter",
              "style": "i"
            },
            {
              "t": "text",
              "v": " series."
            }
          ]
        }
      ]
    }
  },
