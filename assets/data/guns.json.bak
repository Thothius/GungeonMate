        {
          "tokens": [
            {
              "t": "text",
              "v": "The  "
            },
            {
              "t": "synref",
              "v": "Spengbab"
            },
            {
              "t": "text",
              "v": " synergy is a reference to the cartoon "
            },
            {
              "t": "ext",
              "v": "Spongebob Squarepants",
              "url": "https://en.m.wikipedia.org/wiki/SpongeBob_SquarePants"
            },
            {
              "t": "text",
              "v": "."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The visual effect of the Tangler originated as a glitch in "
