    "magazine_size": "30",
    "ammo_capacity": "500",
    "damage": "5.5",
    "fire_rate": "0.25",
    "reload_time": "1.5",
    "shot_speed": "23",
    "range": "1,000",
    "force": "9",
    "spread": "4",
    "class": "SILLY",
    "curse": 0.0,
    "coolness": 0.0,
    "wiki": {
      "notes": [
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "synref",
              "v": "The Killing Joke"
            },
            {
              "t": "text",
              "v": " - If the player also has "
            },
            {
              "t": "ref",
              "v": "AK-47",
              "kind": "gun"
            },
            {
              "t": "text",
              "v": ", the two guns are dual-wielded."
