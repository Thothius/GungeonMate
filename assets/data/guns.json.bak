              "url": "https://en.wikipedia.org/wiki/Halo_(series)"
            },
            {
              "t": "text",
              "v": " Franchise.\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "Similar to the "
                },
                {
                  "t": "ref",
                  "v": "Railgun",
