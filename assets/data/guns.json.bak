    "wiki": {
      "notes": [
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "synref",
              "v": "Blade Runner"
            },
            {
              "t": "text",
              "v": " - If the player also has "
            },
            {
              "t": "ref",
              "v": "Deck4rd",
              "kind": "gun"
            },
            {
              "t": "text",
              "v": ", magazine size of both guns is increased by 50%."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "synref",
              "v": "Paperwork"
            },
            {
              "t": "text",
              "v": " - If the player also has the "
            },
            {
              "t": "ref",
              "v": "Ballot",
              "kind": "item"
            },
            {
              "t": "text",
              "v": " or any Table Tech item except for "
            },
            {
              "t": "ref",
              "v": "Table Tech Heat",
              "kind": "item"
            },
            {
              "t": "text",
              "v": " or "
            },
            {
              "t": "ref",
              "v": "Table Tech Shotgun",
              "kind": "item"
            },
            {
              "t": "text",
              "v": " ("
            },
            {
              "t": "ref",
              "v": "Table Tech Blanks",
              "kind": "item"
            },
            {
              "t": "text",
              "v": ", "
            },
            {
              "t": "ref",
              "v": "Table Tech Money",
              "kind": "item"
            },
            {
              "t": "text",
              "v": ", "
            },
            {
              "t": "ref",
              "v": "Table Tech Rage",
              "kind": "item"
            },
            {
              "t": "text",
              "v": ", "
            },
            {
              "t": "ref",
              "v": "Table Tech Rocket",
              "kind": "item"
            },
            {
              "t": "text",
              "v": ", "
            },
            {
              "t": "ref",
              "v": "Table Tech Sight",
              "kind": "item"
            },
            {
              "t": "text",
              "v": ", or "
            },
            {
              "t": "ref",
              "v": "Table Tech Stun",
              "kind": "item"
            },
            {
              "t": "text",
              "v": "), the first shot after reloading will fire three planes."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "synref",
              "v": "Paper Lanterns"
            },
            {
              "t": "text",
              "v": " - If the player has "
            },
            {
              "t": "ref",
              "v": "Balloon Gun",
              "kind": "gun"
            },
            {
              "t": "text",
              "v": ", while holding either gun in a room with enemies, paper lanterns periodically spawn, which drift towards enemies and deal damage."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "synref",
              "v": "Parchmental"
            },
            {
              "t": "text",
              "v": " - If the player has picked up a "
            },
            {
              "t": "ref",
              "v": "Map",
              "kind": "item"
            },
            {
              "t": "text",
              "v": " at any point during the run, the gun changes appearance and two planes are fired per shot. This lasts for the rest of the run even though the Map only lasts for one floor.\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "Saving and quitting will remove this synergy unless another Map is picked up."
                }
              ]
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "If the player has "
            },
            {
              "t": "ref",
              "v": "Helix Bullets",
              "kind": "item"
            },
            {
              "t": "text",
              "v": ", the gun will not follow the crosshair.\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "If the player also has the  "
                },
                {
                  "t": "synref",
                  "v": "Parchmental"
                },
                {
                  "t": "text",
                  "v": " synergy, the planes will tightly follow the same path, and it will only shoot 2 planes instead of the expected 4."
                }
              ]
            }
          ]
        }
      ],
      "trivia": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "The name of the gun comes from origami, the Japanese art of paper-folding."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The synergy  "
            },
            {
              "t": "synref",
              "v": "Blade Runner"
            },
            {
              "t": "text",
              "v": " is a reference to the movie of the same name, in which origami has significance on the plot."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The tagline \"Thousand Cuts\" is a reference to the Asian-origin form of torture of the same name, also known as 'ling-chi'."
            }
          ]
        }
      ]
    }
  },
  {
    "name": "The Kiln",
    "icon": "https://static.wikia.nocookie.net/enterthegungeon_gamepedia/images/4/48/The_Kiln.png",
    "notes": "Fires pots that break into 3 bouncing crystals upon hitting something.",
    "quote": "Fires Pots",
    "quality": "C",
    "type": "Semiautomatic",
    "dps": "16.0",
    "magazine_size": "8",
    "ammo_capacity": "200",
    "damage": "Pots: 8 Crystals: 4",
    "fire_rate": "0.40",
    "reload_time": "1.2",
    "shot_speed": "20",
    "range": "45",
    "force": "6",
    "spread": "0",
    "class": "SHITTY",
    "curse": 0.0,
    "coolness": 0.0,
    "wiki": {
      "notes": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "This gun is a reference to "
            },
            {
              "t": "ext",
              "v": "The Legend of Zelda",
              "url": "https://en.wikipedia.org/wiki/The_Legend_of_Zelda"
            },
            {
              "t": "text",
              "v": " series, where thrown pots can be used to deal damage.\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "The crystals that the pots break into are also a reference to rupees in The Legend of Zelda."
                }
              ]
            },
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "Kiln is also an Anagram for Link, the protagonist of The Legend of Zelda."
                }
              ]
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The synergy  "
            },
            {
              "t": "synref",
              "v": "Don’t Worry About The Vase"
            },
            {
              "t": "text",
              "v": " is a reference to "
            },
            {
              "t": "ext",
              "v": "The Matrix",
              "url": "https://www.imdb.com/title/tt0133093/"
            },
            {
              "t": "text",
              "v": "."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "A kiln is a furnace or oven used for burning, baking, or \"firing\" pottery."
            }
          ]
        }
      ]
    }
  },
