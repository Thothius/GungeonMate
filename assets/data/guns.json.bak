            },
            {
              "t": "text",
              "v": " and "
            },
            {
              "t": "ref",
              "v": "Muzzle Flare",
              "kind": "unresolved"
            },
            {
              "t": "text",
              "v": ", and do not ignite "
            },
            {
              "t": "ref",
              "v": "Coaler",
              "kind": "unresolved"
            },
            {
              "t": "text",
              "v": ". Additionally, these bullets will freeze any "
            },
            {
              "t": "ref",
              "v": "Goop",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": " they pass over."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Despite the "
            },
            {
              "t": "ref",
              "v": "Ammonomicon",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": " entry suggesting otherwise, the metal slugs fired by this gun do "
            },
            {
              "t": "text",
              "v": "not",
              "style": "i"
            },
            {
              "t": "text",
              "v": " deal any more damage to frozen enemies."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Prior to the "
            },
            {
              "t": "ref",
              "v": "Supply Drop Update",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": ", Ice Breaker had 100 maximum ammo."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "This gun is a reference to the "
            },
            {
              "t": "ext",
              "v": "Ice Breaker",
