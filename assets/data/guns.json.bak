    "wiki": {
      "effects": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "Fires a laser beam that reflects off of walls or obstacles once."
            }
          ]
        }
      ],
      "notes": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "This gun is a reference to the "
            },
            {
              "t": "ext",
              "v": "Moonraker laser rifle",
              "url": "https://jamesbond.fandom.com/wiki/Moonraker_Laser_Rifle"
            },
            {
              "t": "text",
              "v": " from the 1979 James Bond movie "
            },
            {
              "t": "text",
              "v": "Moonraker",
              "style": "i"
            },
            {
              "t": "text",
              "v": ", as well as the Moonraker Laser weapon from the Nintendo 64 game, "
            },
            {
              "t": "text",
              "v": "GoldenEye 007.",
              "style": "i"
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The synergy  "
            },
            {
              "t": "synref",
              "v": "Land Among The Stars"
            },
            {
              "t": "text",
              "v": " references the idiom, "
            },
            {
              "t": "text",
              "v": "\"Shoot for the moon; even if you miss, you’ll land among the stars.\"",
              "style": "i"
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The synergy  "
            },
            {
              "t": "synref",
              "v": "Jumping... Is Useless"
            },
            {
              "t": "text",
              "v": " quotes "
            },
            {
              "t": "ext",
              "v": "a scene",
              "url": "https://www.youtube.com/watch?v=1WO04CT9N0Y"
            },
            {
              "t": "text",
              "v": " in the show "
            },
            {
              "t": "text",
              "v": "Aqua Teen Hunger Force",
              "style": "i"
            },
            {
              "t": "text",
              "v": " where characters known as the "
            },
            {
              "t": "ext",
              "v": "Mooninites",
              "url": "https://aqua-teen-hunger-force.fandom.com/wiki/The_Mooninites"
            },
            {
              "t": "text",
              "v": " use the Quad Laser in an underwhelming battle against a character who retaliates with laser eyes."
            }
          ]
        }
      ]
    }
  },
  {
    "name": "Barrel",
