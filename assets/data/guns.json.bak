    "quality": "B",
    "type": "Semiautomatic",
    "dps": "32.5",
    "magazine_size": "9",
    "ammo_capacity": "400",
    "damage": "7.5",
    "fire_rate": "0.15",
    "reload_time": "1.0",
    "shot_speed": "30",
    "range": "1,000",
    "force": "9",
    "spread": "7",
    "class": "PISTOL",
    "curse": 0.0,
    "coolness": 0.0,
    "wiki": {
      "effects": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "A green bullet that deals 4 damage and poisons enemies it impacts."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "A flare that deals 4 damage and burns enemies it impacts."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "A blue bullet that deals 3 damage and freezes enemies it impacts."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "An orange shot that deals 10 impact damage and explodes, dealing 25 additional damage."
            }
          ]
        }
      ],
      "item_interactions": [
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "ref",
              "v": "Easy Reload Bullets",
              "kind": "item"
            },
            {
              "t": "text",
              "v": " - Dodge rolling can be used to reload the final shot of the magazine repeatedly, allowing the player to rapid-fire special projectiles without needing to go through the rest of the magazine first."
            }
          ]
        }
      ],
      "notes": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "This gun is a reference to "
            },
            {
              "t": "ext",
              "v": "Judge Dredd's",
              "url": "https://en.wikipedia.org/wiki/Judge_Dredd"
            },
            {
              "t": "text",
              "v": " gun, the "
            },
            {
              "t": "ext",
              "v": "Lawgiver",
              "url": "https://en.wikipedia.org/wiki/Lawgiver_(Judge_Dredd)"
            },
            {
              "t": "text",
              "v": ".\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "The pickup quote \"Hot Shot\" is one of the Lawgiver's settings."
                }
              ]
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The entry for The Judge in the "
            },
            {
              "t": "ref",
              "v": "Physical Ammonomicon",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": " has a small doodle of a round-faced figure holding a gun."
            }
          ]
        }
      ]
    }
  },
  {
    "name": "Mourning Star",
    "icon": "https://static.wikia.nocookie.net/enterthegungeon_gamepedia/images/3/36/Mourning_Star.png",
    "notes": "Calls down a controllable orbital laser.",
    "quote": "Satellite Rain",
    "quality": "1S",
    "type": "Beam",
    "dps": "110.0",
    "magazine_size": "800",
    "ammo_capacity": "800",
    "damage": "~110/s",
    "fire_rate": "0.3",
    "reload_time": "?",
    "shot_speed": "?",
    "range": "?",
    "force": "?",
    "spread": "?",
    "class": "SILLY",
    "curse": 0.0,
    "coolness": 0.0,
    "wiki": {
      "effects": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "Fires a thin red targeting laser that does no damage."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Focusing the targeting beam on an enemy will, after a short delay, call down an extremely powerful orbital laser strike at their location.\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "After an orbital laser has been called in, it will persist as long as the trigger is held. Extant orbital lasers will slowly move in the direction of the player's crosshair."
                }
              ]
            },
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "Orbital laser strikes leave a trail of burning "
                },
                {
                  "t": "ref",
                  "v": "Goop",
                  "kind": "lore"
                },
                {
                  "t": "text",
                  "v": " at their point of impact."
                }
              ]
            }
          ]
        }
      ],
      "notes": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "Inactive mimics will not be activated by the tracking beam, and cannot be targeted for a strike."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The tracking beam will destroy destructibles, such as the "
            },
            {
              "t": "ref",
              "v": "Beholster",
              "kind": "shrine"
            },
            {
              "t": "text",
              "v": " RC rockets."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The impact damage of the beam is unaffected by passive items."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Only the head of the "
            },
            {
              "t": "ref",
              "v": "Ammoconda",
              "kind": "unresolved"
            },
            {
              "t": "text",
              "v": " can be targeted to call down a strike."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "If the player has a shot-multiplying item like "
            },
            {
              "t": "ref",
              "v": "Helix Bullets",
              "kind": "item"
            },
            {
              "t": "text",
              "v": " or "
            },
            {
              "t": "ref",
              "v": "Scattershot",
              "kind": "item"
            },
            {
              "t": "text",
              "v": ", it is possible to call down multiple strikes simultaneously; a strike occurs for every tracking beam that is in contact with an enemy during the targeting period.\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "This is also possible with "
                },
                {
                  "t": "ref",
                  "v": "Bouncy Bullets",
                  "kind": "item"
                },
                {
                  "t": "text",
                  "v": ", provided that the rebound of the tracking beam also comes in contact with an enemy."
                }
              ]
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "This gun's appearance and effect are based on the "
            },
            {
              "t": "ext",
              "v": "Hammer of Dawn",
              "url": "http://gearsofwar.wikia.com/wiki/Hammer_of_Dawn"
            },
            {
              "t": "text",
              "v": " from "
            },
            {
              "t": "ext",
              "v": "Gears of War videogame series",
              "url": "https://en.wikipedia.org/wiki/Gears_of_War"
            },
            {
              "t": "text",
              "v": ". The synergy with the weapon and "
            },
            {
              "t": "ref",
              "v": "Cog of Battle",
              "kind": "item"
            },
            {
              "t": "text",
              "v": " is a reference to the same video game series."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "This gun's name is possibly based off of the medieval weapon known as a morning star, which is a club with a spiked sphere on the end."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The entry for the Mourning Star in the "
            },
            {
              "t": "ref",
              "v": "Physical Ammonomicon",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": " has a small doodle of a skull being sawed through with a chainsaw. This may be a reference to the "
            },
            {
              "t": "ext",
              "v": "Chainsaw Bayonet",
              "url": "https://gearsofwar.fandom.com/wiki/Chainsaw_Bayonet"
            },
            {
              "t": "text",
              "v": " from the "
            },
            {
              "t": "text",
              "v": "Gears of War",
              "style": "i"
            },
            {
              "t": "text",
              "v": " franchise."
            }
          ]
        }
      ]
    }
  },
  {
    "name": "Alien Sidearm",
