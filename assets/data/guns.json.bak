              "v": " synergy."
            }
          ]
        }
      ],
      "trivia": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "The gun's description is a mathematical inequality stating that three is greater than one, alluding to the fact that the Triple Crossbow's three-shot fire gives it greater offensive power than a standard crossbow."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "In spite of this description, Triple Crossbow actually does less damage per shot than regular "
            },
            {
              "t": "ref",
              "v": "Crossbow",
              "kind": "gun"
            },
            {
              "t": "text",
              "v": " (21 from Triple Bolts versus regular Crossbow's 22)."
            }
          ]
        }
      ]
    }
  },
  {
    "name": "Crescent Crossbow",
    "icon": "https://static.wikia.nocookie.net/enterthegungeon_gamepedia/images/1/18/Crescent_Crossbow.png",
    "notes": "Fires stars that split into smaller bouncing stars.",
    "quote": "Moon Shot",
    "quality": "A",
    "type": "Charged",
    "dps": "19.5+",
    "magazine_size": "12",
    "ammo_capacity": "100",
    "damage": "Large: 22 Medium: 8 Small: 3",
    "fire_rate": "0.20",
    "reload_time": "1.5",
    "shot_speed": "32",
    "range": "1,000",
    "force": "20",
    "spread": "0",
    "class": "CHARM",
    "curse": 0.0,
    "coolness": 0.0,
    "wiki": {
      "effects": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "Fires medium-sized star projectiles. These stars split into 3 smaller, bouncing stars upon impact.\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "These extra stars are created at the end of the medium star's small trail, causing them to appear slightly away from the wall, enemy, or obstacle the initial star impacted."
                }
              ]
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "When fully charged, fires a large star. This star splits into 10 medium-size stars, which in turn each split into 3 smaller stars.\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "Firing a fully charged shot costs 3 ammo."
                }
              ]
            },
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "The amount of bouncing, lingering projectiles from the charged shot tends to fill rooms with bullets."
                }
              ]
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Split stars will harmlessly fly through enemies for a second before they are able to do damage, meaning that shooting an enemy directly often only hits with the initial star."
            }
          ]
        }
      ],
      "item_interactions": [
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "ref",
              "v": "Scattershot",
              "kind": "item"
            },
            {
              "t": "text",
              "v": " /  "
            },
            {
              "t": "ref",
              "v": "Helix Bullets",
              "kind": "item"
            },
            {
              "t": "text",
              "v": " /  "
            },
            {
              "t": "ref",
              "v": "Double Vision",
              "kind": "item"
            },
            {
              "t": "text",
              "v": " /  "
            },
            {
              "t": "ref",
              "v": "Backup Gun",
              "kind": "item"
            },
            {
              "t": "text",
              "v": " /  "
            },
            {
              "t": "ref",
              "v": "Table Tech Sight",
              "kind": "item"
            },
            {
              "t": "text",
              "v": " - Firing a charged star shot with items that increase the number of bullets fired will increase the amount of ammo consumed by 3 "
            },
            {
              "t": "text",
              "v": "per extra shot fired",
              "style": "i"
            },
            {
              "t": "text",
              "v": ". For example, with "
            },
            {
              "t": "ref",
              "v": "Scattershot",
              "kind": "item"
            },
            {
              "t": "text",
              "v": ", firing a charged shot consumes 9 ammo."
            }
          ]
        }
      ],
      "notes": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "The Crescent Crossbow is peculiarly a part of the CHARM "
            },
            {
              "t": "ref",
              "v": "Guns",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": " despite not charming enemies."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "This gun is a reference to the "
            },
            {
              "t": "ext",
              "v": "Crescent Moon Wand",
              "url": "https://sailormoondub.fandom.com/wiki/Crescent_Moon_Wand"
            },
            {
              "t": "text",
              "v": " and "
            },
            {
              "t": "ext",
              "v": "Moon Scepter",
              "url": "https://sailormoondub.fandom.com/wiki/Moon_Scepter"
            },
            {
              "t": "text",
              "v": " weapons in the "
            },
            {
              "t": "text",
              "v": "Sailor Moon",
              "style": "i"
            },
            {
              "t": "text",
              "v": " franchise, which use moonlight to combat evil.\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "It is also a reference to the terms "
                },
                {
                  "t": "text",
                  "v": "\"",
                  "style": "i"
                },
                {
                  "t": "ext",
                  "v": "shooting star",
                  "url": "https://en.wiktionary.org/wiki/shooting_star"
                },
                {
                  "t": "text",
                  "v": "\"",
                  "style": "i"
                },
                {
                  "t": "text",
                  "v": " (in reference to meteors) and "
                },
                {
                  "t": "text",
                  "v": "\"",
                  "style": "i"
                },
                {
                  "t": "ext",
                  "v": "moon shot",
                  "url": "https://en.wiktionary.org/wiki/moon_shot"
                },
                {
                  "t": "text",
                  "v": "\"",
                  "style": "i"
                },
                {
                  "t": "text",
                  "v": " (referring either to a literal moon-landing mission or a metaphor for a task of great difficulty)."
                }
              ]
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The synergy  "
            },
            {
              "t": "synref",
              "v": "Alas, Sniperion"
            },
            {
              "t": "text",
              "v": " may be a reference to "
            },
            {
              "t": "ext",
              "v": "Alas, Babylon",
              "url": "https://en.wikipedia.org/wiki/Alas,_Babylon"
            },
            {
              "t": "text",
              "v": ", a book by Pat Frank."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "synref",
              "v": "Alas, Sniperion"
            },
            {
              "t": "text",
              "v": " is a reference to "
            },
            {
              "t": "ref",
              "v": "Sniperion",
              "kind": "unresolved"
            },
            {
              "t": "text",
              "v": ", one of the moons of Gunymede."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The entry for the Crescent Crossbow in the "
            },
            {
              "t": "ref",
              "v": "Physical Ammonomicon",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": " has a small doodle of a smiling crescent moon."
            }
          ]
        }
      ]
    }
  },
  {
    "name": "Gunbow",
    "icon": "https://static.wikia.nocookie.net/enterthegungeon_gamepedia/images/e/e6/Gunbow.png",
    "notes": "Fires a fast, piercing projectile that ricochets many times.",
    "quote": "Failed Experiment",
