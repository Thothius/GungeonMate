    "wiki": {
      "effects": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "Quickly fires small balls of electricity."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": " Any pools of "
            },
            {
              "t": "ref",
              "v": "Goop",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": " that these balls pass over will be electrified, dealing considerable damage to enemies.\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "This gun does "
                },
                {
                  "t": "text",
                  "v": "not",
                  "style": "i"
                },
                {
                  "t": "text",
                  "v": " grant electricity immunity. As such, electrified pools of water also pose considerable danger to the player."
                }
              ]
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": " Creates a blue aura with a 5 tile radius around the player while reloading. Enemies within this aura take 5 damage per second.\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "The amount of damage dealt by this aura is "
                },
                {
                  "t": "text",
                  "v": "not",
