            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Many of the final shot's effects are references to real mail-related attacks:\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "The option of a box filled with glitter is a reference to "
