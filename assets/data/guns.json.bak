            },
            {
              "t": "text",
              "v": "."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The  "
            },
            {
              "t": "synref",
              "v": "Frosty the Bullet Tyrant"
            },
            {
              "t": "text",
              "v": " synergy may be a reference to the boss "
            },
            {
              "t": "ext",
