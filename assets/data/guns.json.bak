  {
    "name": "Dart Gun",
    "icon": "https://static.wikia.nocookie.net/enterthegungeon_gamepedia/images/4/43/Dart_Gun.png/revision/latest?cb=20160310050541",
    "notes": "Fires sticky darts. Starting gun of The Cultist . Does not crack secret walls . Only available in co-op.",
    "quote": "Sticky",
    "quality": "N",
    "type": "Semiautomatic",
    "dps": "18.0",
    "magazine_size": "6",
    "ammo_capacity": "",
    "damage": "6",
    "fire_rate": "0.20",
    "reload_time": "1.0",
    "shot_speed": "20",
    "range": "25",
    "force": "2",
    "spread": "5",
    "class": "SHITTY",
    "curse": 0.0,
    "coolness": 0.0,
    "wiki": {
      "notes": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "The Dart Gun may be a reference to the "
            },
            {
              "t": "text",
              "v": "Nerf",
              "style": "i"
            },
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "ext",
              "v": "Maverick REV-6",
              "url": "https://nerf.fandom.com/wiki/Maverick_REV-6"
            },
            {
              "t": "text",
              "v": ", a toy foam dart blaster that has the same shape, similar color pattern (albeit purple instead of yellow), and also holds six darts."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The Dart Gun is a replacement toy for the Cultist, after they lost their previous toy blaster (the  "
            },
            {
              "t": "ref",
              "v": "Light Gun",
              "kind": "gun"
            },
            {
              "t": "text",
              "v": ") down a pit."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The alternate skin of this gun resembles a worm, in order to match the Cultists apple alt skin."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": " Fixed Bug Prior to "
            },
            {
              "t": "ref",
              "v": "Version History",
              "kind": "unresolved"
            },
            {
              "t": "text",
              "v": ", darts would not stick to secret walls, effectively allowing secret rooms to be found."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The entry for the Dart Gun in the "
            },
            {
              "t": "ref",
              "v": "Physical Ammonomicon",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": " has a small doodle of the "
            },
            {
              "t": "ref",
              "v": "Cultist",
              "kind": "unresolved"
            },
            {
              "t": "text",
              "v": "."
            }
          ]
        }
      ]
    }
