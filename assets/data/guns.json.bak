            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "With enough damage, this gun can fully recharge itself, where it then reloads like normal."
                }
              ]
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "ref",
              "v": "Hip Holster",
              "kind": "item"
            },
            {
              "t": "text",
              "v": " grants an extra shot immediately after firing.\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "With Hip Holster as well as "
