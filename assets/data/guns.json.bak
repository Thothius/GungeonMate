  {
    "name": "Shades's Revolver",
    "icon": "https://static.wikia.nocookie.net/enterthegungeon_gamepedia/images/4/43/Shades%27s_Revolver.png",
    "notes": "Increases coolness by 3.",
    "quote": "Someone Loses An Eye",
    "quality": "C",
    "type": "Semiautomatic",
    "dps": "30.0",
    "magazine_size": "6",
    "ammo_capacity": "150",
    "damage": "15",
    "fire_rate": "0.30",
    "reload_time": "1.5",
    "shot_speed": "23",
    "range": "60",
    "force": "30",
    "spread": "6",
    "class": "PISTOL",
    "curse": 0.0,
    "coolness": 3.0,
    "wiki": {
      "effects": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "Increases "
            },
            {
              "t": "ref",
              "v": "Coolness",
              "kind": "stat"
            },
            {
              "t": "text",
              "v": " by 3 while in the players inventory, decreasing the cooldown of active items and increasing the chance of items dropping upon clearing a room."
            }
          ]
        }
      ],
      "notes": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "The pickup line \""
            },
            {
              "t": "text",
              "v": "Someone Loses An Eye\",",
              "style": "i"
            },
            {
              "t": "text",
              "v": " could be a reference to the latter part of the phrase \""
            },
            {
              "t": "text",
              "v": "It's all fun and games until someone loses an eye",
              "style": "i"
            },
            {
              "t": "text",
              "v": ".\"\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "The corresponding pickup line of "
                },
                {
                  "t": "ref",
                  "v": "Smiley's Revolver",
                  "kind": "gun"
                },
                {
                  "t": "text",
                  "v": ", \""
                },
                {
                  "t": "text",
                  "v": "All Smiles,",
                  "style": "i"
                },
                {
                  "t": "text",
                  "v": "\" is likely a corruption of the first part of the phrase."
                }
              ]
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The \"notches\" referenced in the Ammonomicon Entry are usually indicative of a soldier's confirmed kills. As such, it is implied that Shades has killed 17 "
            },
