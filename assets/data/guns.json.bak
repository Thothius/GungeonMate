              "t": "text",
              "v": "."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Gunthers idle animation, continually glancing left to right, is likely a reference to the "
            },
            {
              "t": "ext",
              "v": "Status bar face",
              "url": "https://doom.fandom.com/wiki/Status_bar_face"
            },
            {
              "t": "text",
