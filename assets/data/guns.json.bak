            {
              "t": "text",
              "v": "."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "The synergy \"Willing to Sacrifice\" is a reference to the 1977 song "
            },
            {
              "t": "ext",
              "v": "Cold As Ice",
              "url": "https://www.youtube.com/watch?v=mjwV5w0IrcA"
            },
            {
              "t": "text",
              "v": " by Foreigner."
            }
          ]
        }
      ]
    }
  },
