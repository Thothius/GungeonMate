    "coolness": 0.0,
    "wiki": {
      "effects": [
        {
          "tokens": [
            {
              "t": "text",
              "v": " These rockets behave with the effect of  "
            },
            {
              "t": "ref",
              "v": "Remote Bullets",
              "kind": "item"
            },
            {
              "t": "text",
              "v": ".\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "On keyboard and mouse controls, these rockets home in towards the players crosshair."
                }
              ]
            },
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "On gamepad controls, these rockets continually update their direction to match the players currently aimed direction."
                }
              ]
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": " These rockets automatically home in on enemies."
            }
          ]
        }
      ],
      "item_interactions": [
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "ref",
              "v": "Helix Bullets",
              "kind": "item"
            },
            {
              "t": "text",
              "v": " - Removes the ability to guide the rockets."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "ref",
              "v": "Angry Bullets",
              "kind": "item"
            },
            {
              "t": "text",
              "v": " - Rockets bounce off enemies instead of exploding, allowing them to be guided into the same enemy multiple times for repeat hits."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "ref",
              "v": "Remote Bullets",
              "kind": "item"
            },
            {
              "t": "text",
              "v": " - Increases the guiding force of the rockets, causing them to turn much more sharply toward the players cursor/aim direction. This grants much better control over the rockets direction."
            }
          ]
        }
      ],
      "notes": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "This gun is a reference to the Nikita remote-controlled missile launcher from Metal Gear Solid, which fires controllable missiles. As mentioned in the description, in Metal Gear Solid, you use the gun to traverse an electrified corridor by destroying its power source at the end of it."
            }
          ]
        }
      ]
    }
  },
