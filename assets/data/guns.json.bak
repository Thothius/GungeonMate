            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Grants an "
            },
            {
              "t": "text",
              "v": "empty",
              "style": "i"
            },
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "ref",
              "v": "Health",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": "."
            }
          ]
        }
      ],
      "notes": [
        {
          "tokens": [
            {
              "t": "text",
              "v": "This gun is a reference to the game "
            },
            {
              "t": "ext",
              "v": "Super Meat Boy",
              "url": "https://en.wikipedia.org/wiki/Super_Meat_Boy"
            },
            {
              "t": "text",
              "v": ".\n"
            }
          ],
          "sub": [
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "The sawblades fired by Super Meat Gun are a reference to the abundance of sawblade traps in every area of "
                },
                {
                  "t": "text",
                  "v": "Super Meat Boy",
                  "style": "i"
                },
                {
                  "t": "text",
                  "v": "."
                }
              ]
            },
            {
              "tokens": [
                {
                  "t": "text",
                  "v": "The "
                },
                {
                  "t": "ref",
                  "v": "Ammonomicon",
                  "kind": "lore"
                },
                {
                  "t": "text",
                  "v": " quote "
                },
                {
                  "t": "text",
                  "v": "\"Very Fast\"",
                  "style": "i"
                },
                {
                  "t": "text",
                  "v": " and the first line of the description "
                },
                {
                  "t": "text",
                  "v": "\"Made of Meat\"",
                  "style": "i"
                },
                {
                  "t": "text",
                  "v": " are references to the character Meat Boy's description in the character select menu "
                },
                {
                  "t": "text",
                  "v": "\"Very fast. Made of meat!\"",
                  "style": "i"
                },
                {
                  "t": "text",
                  "v": "."
                }
              ]
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "This is the only "
            },
            {
              "t": "ref",
              "v": "Health",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": "-up item in the game that doesn't grant a filled heart container on first pickup."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "Dodge rolling temporarily grants a significant fire rate increase, much like the "
            },
            {
              "t": "ref",
              "v": "Derringer",
              "kind": "gun"
            },
            {
              "t": "text",
              "v": "."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": " "
            },
            {
              "t": "synref",
              "v": "I Studied The Blade"
            },
            {
              "t": "text",
              "v": " is a reference to "
            },
            {
              "t": "ext",
              "v": "an infamous internet meme",
              "url": "https://knowyourmeme.com/memes/i-studied-the-blade"
            },
            {
              "t": "text",
              "v": " originating in the subreddit /r/justneckbeardthings. The post mocks the unselfawareness and embarassing behaviour of 'neckbeards', particularly those who own cheap katanas out of a superficial love for Japanese culture born primarily out of anime viewership."
            }
          ]
        },
        {
          "tokens": [
            {
              "t": "text",
              "v": "  Possible Bug The special UI icon for Super Meat Gun in the "
            },
            {
              "t": "ref",
              "v": "Chinese Mobile Version",
              "kind": "lore"
            },
            {
              "t": "text",
              "v": " of "
            },
            {
              "t": "text",
              "v": "Enter the Gungeon",
              "style": "i"
            },
            {
              "t": "text",
              "v": " appears blue. This is likely due to incorrect colour encoding issues when saving the file, as the same thing can be seen in other UI textures."
            }
          ]
        }
      ]
    }
